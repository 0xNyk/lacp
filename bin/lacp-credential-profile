#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage:
  lacp-credential-profile list [--json]
  lacp-credential-profile render --profile <name> [--json]
  lacp-credential-profile input-contract --profile <name> [--json]

Profile source:
  config/credential-profiles.json
EOF
}

sub="${1:-}"
if [[ -z "${sub}" ]]; then
  usage
  exit 1
fi
shift || true

PROFILES_FILE="${ROOT}/config/credential-profiles.json"
require_file "${PROFILES_FILE}"
require_cmd jq

list_cmd() {
  local as_json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) as_json=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "Unknown argument: $1" ;;
    esac
  done
  if [[ "${as_json}" -eq 1 ]]; then
    jq '{
      ok: true,
      schema_version: (.version // "1"),
      profiles: ((.profiles // {}) | to_entries | map({
        name: .key,
        description: (.value.description // ""),
        defaults: (.value.defaults // {})
      }))
    }' "${PROFILES_FILE}"
  else
    jq -r '.profiles | to_entries[] | "- \(.key): \(.value.description // "")"' "${PROFILES_FILE}"
  fi
}

render_profile() {
  local profile="$1"
  local as_json="$2"
  python3 - <<'PY' "${PROFILES_FILE}" "${profile}" "${as_json}"
import json
import sys
from pathlib import Path

cfg_path = Path(sys.argv[1])
profile_name = sys.argv[2]
as_json = sys.argv[3] == "1"

cfg = json.loads(cfg_path.read_text())
profiles = cfg.get("profiles") or {}
if profile_name not in profiles:
    print(json.dumps({"ok": False, "error": f"unknown profile: {profile_name}"}))
    raise SystemExit(2)

profile = profiles[profile_name]
payload = {
    "ok": True,
    "schema_version": str(cfg.get("version", "1")),
    "profile": profile_name,
    "description": profile.get("description", ""),
    "defaults": profile.get("defaults") or {},
    "input_contract": profile.get("input_contract") or {},
}
print(json.dumps(payload, indent=2 if as_json else None))
PY
}

render_cmd() {
  local profile=""
  local as_json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile) profile="$2"; shift 2 ;;
      --json) as_json=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "Unknown argument: $1" ;;
    esac
  done
  [[ -n "${profile}" ]] || die "--profile is required"

  local rendered
  rendered="$(render_profile "${profile}" "${as_json}")"
  if [[ "${as_json}" -eq 1 ]]; then
    printf '%s\n' "${rendered}"
  else
    local ok
    ok="$(jq -r '.ok // false' <<<"${rendered}")"
    if [[ "${ok}" != "true" ]]; then
      local err
      err="$(jq -r '.error // "unknown error"' <<<"${rendered}")"
      die "${err}"
    fi
    jq -c '{defaults,input_contract}' <<<"${rendered}"
  fi
}

input_contract_cmd() {
  local profile=""
  local as_json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile) profile="$2"; shift 2 ;;
      --json) as_json=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "Unknown argument: $1" ;;
    esac
  done
  [[ -n "${profile}" ]] || die "--profile is required"

  local rendered
  rendered="$(render_profile "${profile}" 1)"
  local ok
  ok="$(jq -r '.ok // false' <<<"${rendered}")"
  if [[ "${ok}" != "true" ]]; then
    local err
    err="$(jq -r '.error // "unknown error"' <<<"${rendered}")"
    die "${err}"
  fi
  if [[ "${as_json}" -eq 1 ]]; then
    jq '{ok:true,profile:.profile,input_contract:.input_contract}' <<<"${rendered}"
  else
    jq -c '.input_contract' <<<"${rendered}"
  fi
}

case "${sub}" in
  list) list_cmd "$@" ;;
  render) render_cmd "$@" ;;
  input-contract) input_contract_cmd "$@" ;;
  -h|--help|help) usage ;;
  *) die "Unknown subcommand: ${sub}" ;;
esac

