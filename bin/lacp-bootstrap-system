#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: lacp-bootstrap-system [--profile starter|existing] [--with-verify] [--hours N] [--force-scaffold] [--no-auto-deps] [--auto-deps-dry-run] [--auto-deps-force] [--no-auto-adopt] [--json]

Runs a full first-run bootstrap flow:
  1) install/onboard flow
  2) doctor summary
EOF
}

PROFILE="starter"
WITH_VERIFY=1
HOURS=""
FORCE_SCAFFOLD=0
AUTO_DEPS_DRY_RUN=0
AUTO_DEPS_FORCE=0
NO_AUTO_DEPS=0
NO_AUTO_ADOPT=0
JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE="$2"
      shift 2
      ;;
    --with-verify)
      WITH_VERIFY=1
      shift
      ;;
    --skip-verify)
      WITH_VERIFY=0
      shift
      ;;
    --hours)
      HOURS="$2"
      shift 2
      ;;
    --force-scaffold)
      FORCE_SCAFFOLD=1
      shift
      ;;
    --no-auto-deps)
      NO_AUTO_DEPS=1
      shift
      ;;
    --auto-deps-dry-run)
      AUTO_DEPS_DRY_RUN=1
      shift
      ;;
    --auto-deps-force)
      AUTO_DEPS_FORCE=1
      shift
      ;;
    --no-auto-adopt)
      NO_AUTO_ADOPT=1
      shift
      ;;
    --json)
      JSON=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "[lacp] ERROR: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

case "${PROFILE}" in
  starter|existing) ;;
  *)
    echo "[lacp] ERROR: --profile must be starter|existing" >&2
    exit 1
    ;;
esac

INSTALL_ARGS=(--profile "${PROFILE}")

if [[ "${WITH_VERIFY}" -eq 1 ]]; then
  INSTALL_ARGS+=(--with-verify)
fi
if [[ -n "${HOURS}" ]]; then
  INSTALL_ARGS+=(--hours "${HOURS}")
fi
if [[ "${FORCE_SCAFFOLD}" -eq 1 ]]; then
  INSTALL_ARGS+=(--force-scaffold)
fi
if [[ "${NO_AUTO_DEPS}" -eq 1 ]]; then
  INSTALL_ARGS+=(--no-auto-deps)
fi
if [[ "${AUTO_DEPS_DRY_RUN}" -eq 1 ]]; then
  INSTALL_ARGS+=(--auto-deps-dry-run)
fi
if [[ "${AUTO_DEPS_FORCE}" -eq 1 ]]; then
  INSTALL_ARGS+=(--auto-deps-force)
fi
if [[ "${NO_AUTO_ADOPT}" -eq 1 ]]; then
  INSTALL_ARGS+=(--no-auto-adopt)
fi

"${ROOT}/bin/lacp-install" "${INSTALL_ARGS[@]}"

doctor_out="$("${ROOT}/bin/lacp-doctor" --json)"
doctor_json="$(printf '%s\n' "${doctor_out}" | sed -n '/^{/,$p')"

if [[ "${JSON}" -eq 1 ]]; then
  python3 - <<'PY' "${doctor_json}" "${PROFILE}" "${WITH_VERIFY}" "${NO_AUTO_DEPS}"
import json
import sys

doctor = json.loads(sys.argv[1])
payload = {
    "ok": bool(doctor.get("ok")),
    "kind": "bootstrap_system",
    "profile": sys.argv[2],
    "with_verify": sys.argv[3] == "1",
    "auto_deps_enabled": sys.argv[4] != "1",
    "doctor_summary": doctor.get("summary", {}),
}
print(json.dumps(payload, indent=2))
PY
  exit 0
fi

printf '%s\n' "${doctor_out}"
