#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: lacp-bootstrap-system [--profile starter|existing] [--with-verify] [--hours N] [--force-scaffold] [--no-auto-deps] [--auto-deps-dry-run] [--auto-deps-force] [--with-obsidian-setup] [--no-obsidian-setup] [--no-auto-adopt] [--fresh-check] [--skip-fresh-check] [--json]

Runs a full first-run bootstrap flow:
  1) install/onboard flow
  2) doctor summary
  3) fresh-machine confidence checks (quick isolated suite + core command health)
EOF
}

PROFILE="starter"
WITH_VERIFY=1
HOURS=""
FORCE_SCAFFOLD=0
AUTO_DEPS_DRY_RUN=0
AUTO_DEPS_FORCE=0
NO_AUTO_DEPS=0
NO_AUTO_ADOPT=0
OBSIDIAN_SETUP=1
FRESH_CHECK=1
JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE="$2"
      shift 2
      ;;
    --with-verify)
      WITH_VERIFY=1
      shift
      ;;
    --skip-verify)
      WITH_VERIFY=0
      shift
      ;;
    --hours)
      HOURS="$2"
      shift 2
      ;;
    --force-scaffold)
      FORCE_SCAFFOLD=1
      shift
      ;;
    --no-auto-deps)
      NO_AUTO_DEPS=1
      shift
      ;;
    --auto-deps-dry-run)
      AUTO_DEPS_DRY_RUN=1
      shift
      ;;
    --auto-deps-force)
      AUTO_DEPS_FORCE=1
      shift
      ;;
    --no-auto-adopt)
      NO_AUTO_ADOPT=1
      shift
      ;;
    --with-obsidian-setup)
      OBSIDIAN_SETUP=1
      shift
      ;;
    --no-obsidian-setup)
      OBSIDIAN_SETUP=0
      shift
      ;;
    --fresh-check)
      FRESH_CHECK=1
      shift
      ;;
    --skip-fresh-check)
      FRESH_CHECK=0
      shift
      ;;
    --json)
      JSON=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "[lacp] ERROR: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

case "${PROFILE}" in
  starter|existing) ;;
  *)
    echo "[lacp] ERROR: --profile must be starter|existing" >&2
    exit 1
    ;;
esac

INSTALL_ARGS=(--profile "${PROFILE}")

if [[ "${WITH_VERIFY}" -eq 1 ]]; then
  INSTALL_ARGS+=(--with-verify)
fi
if [[ -n "${HOURS}" ]]; then
  INSTALL_ARGS+=(--hours "${HOURS}")
fi
if [[ "${FORCE_SCAFFOLD}" -eq 1 ]]; then
  INSTALL_ARGS+=(--force-scaffold)
fi
if [[ "${NO_AUTO_DEPS}" -eq 1 ]]; then
  INSTALL_ARGS+=(--no-auto-deps)
fi
if [[ "${AUTO_DEPS_DRY_RUN}" -eq 1 ]]; then
  INSTALL_ARGS+=(--auto-deps-dry-run)
fi
if [[ "${AUTO_DEPS_FORCE}" -eq 1 ]]; then
  INSTALL_ARGS+=(--auto-deps-force)
fi
if [[ "${NO_AUTO_ADOPT}" -eq 1 ]]; then
  INSTALL_ARGS+=(--no-auto-adopt)
fi
if [[ "${OBSIDIAN_SETUP}" -eq 1 ]]; then
  INSTALL_ARGS+=(--with-obsidian-setup)
else
  INSTALL_ARGS+=(--no-obsidian-setup)
fi

"${ROOT}/bin/lacp-install" "${INSTALL_ARGS[@]}"

doctor_out="$("${ROOT}/bin/lacp-doctor" --json)"
doctor_json="$(printf '%s\n' "${doctor_out}" | sed -n '/^{/,$p')"

fresh_check_json='{"enabled":false,"ok":true,"tests":{"quick_isolated":{"ok":null}},"commands":{}}'
if [[ "${FRESH_CHECK}" -eq 1 ]]; then
  test_rc=0
  set +e
  "${ROOT}/bin/lacp-test" --quick --isolated >/dev/null
  test_rc=$?
  set -e

  cmd_orchestrate=0
  cmd_worktree=0
  cmd_swarm=0
  set +e
  "${ROOT}/bin/lacp" orchestrate doctor --json >/dev/null 2>&1
  cmd_orchestrate=$?
  "${ROOT}/bin/lacp" worktree list --json >/dev/null 2>&1
  cmd_worktree=$?
  "${ROOT}/bin/lacp" swarm --help >/dev/null 2>&1
  cmd_swarm=$?
  set -e

  fresh_check_json="$(jq -n \
    --argjson test_rc "${test_rc}" \
    --argjson cmd_orchestrate "${cmd_orchestrate}" \
    --argjson cmd_worktree "${cmd_worktree}" \
    --argjson cmd_swarm "${cmd_swarm}" \
    '{
      enabled:true,
      ok:($test_rc == 0 and $cmd_orchestrate == 0 and $cmd_worktree == 0 and $cmd_swarm == 0),
      tests:{
        quick_isolated:{ok:($test_rc == 0), rc:$test_rc}
      },
      commands:{
        orchestrate_doctor:{ok:($cmd_orchestrate == 0), rc:$cmd_orchestrate},
        worktree_list:{ok:($cmd_worktree == 0), rc:$cmd_worktree},
        swarm_help:{ok:($cmd_swarm == 0), rc:$cmd_swarm}
      }
    }')"
fi

if [[ "$(echo "${fresh_check_json}" | jq -r '.ok')" != "true" ]]; then
  if [[ "${JSON}" -ne 1 ]]; then
    echo "[lacp] ERROR: fresh-check failed" >&2
  fi
  exit 1
fi

if [[ "${JSON}" -eq 1 ]]; then
  python3 - <<'PY' "${doctor_json}" "${PROFILE}" "${WITH_VERIFY}" "${NO_AUTO_DEPS}" "${fresh_check_json}"
import json
import sys

doctor = json.loads(sys.argv[1])
fresh = json.loads(sys.argv[5])
payload = {
    "ok": bool(doctor.get("ok")) and bool(fresh.get("ok")),
    "kind": "bootstrap_system",
    "profile": sys.argv[2],
    "with_verify": sys.argv[3] == "1",
    "auto_deps_enabled": sys.argv[4] != "1",
    "doctor_summary": doctor.get("summary", {}),
    "fresh_check": fresh,
}
print(json.dumps(payload, indent=2))
PY
  exit 0
fi

printf '%s\n' "${doctor_out}"
