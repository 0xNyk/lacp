#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

PROVENANCE_ROOT="${HOME}/.lacp/provenance"
CHAIN_FILE="${PROVENANCE_ROOT}/chain.jsonl"

usage() {
  cat <<'EOF'
Usage:
  lacp-provenance start [--json]
  lacp-provenance end [--json]
  lacp-provenance verify [--json]
  lacp-provenance log [--last N] [--json]
  lacp-provenance export [--json]

Cryptographic session provenance chain. Each session receipt is SHA-256
hash-chained to the previous receipt, creating a tamper-evident continuity proof.

Subcommands:
  start    Record session start (creates pending receipt)
  end      Record session end, compute hashes, seal receipt into chain
  verify   Walk chain and verify all prev_hash links
  log      Show recent chain entries (default: last 10)
  export   Export full chain for external audit
EOF
}

sub="${1:-}"
if [[ -z "${sub}" || "${sub}" == "-h" || "${sub}" == "--help" || "${sub}" == "help" ]]; then
  usage
  exit 0
fi
shift || true

AS_JSON=0
LOG_LAST=10

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) AS_JSON=1; shift ;;
    --last) LOG_LAST="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown argument: $1" ;;
  esac
done

ensure_chain() {
  mkdir -p "${PROVENANCE_ROOT}"
  touch "${CHAIN_FILE}"
}

get_agent_id() {
  # Try to get agent_id for current project; fall back to "unknown"
  if [[ -x "${ROOT}/bin/lacp-agent-id" ]]; then
    "${ROOT}/bin/lacp-agent-id" show --json 2>/dev/null | jq -r '.agent_id // "unknown"' 2>/dev/null || echo "unknown"
  else
    echo "unknown"
  fi
}

get_session_fingerprint() {
  if [[ -x "${ROOT}/bin/lacp-session-fingerprint" ]]; then
    "${ROOT}/bin/lacp-session-fingerprint" --json 2>/dev/null | jq -r '.fingerprint // "unknown"' 2>/dev/null || echo "unknown"
  else
    echo "unknown"
  fi
}

project_slug() {
  pwd | tr '/' '-'
}

memory_hash() {
  local slug
  slug="$(project_slug)"
  local mem_file="${HOME}/.claude/projects/${slug}/memory/MEMORY.md"
  if [[ -f "${mem_file}" ]]; then
    python3 -c "import hashlib,sys; print(hashlib.sha256(open(sys.argv[1],'rb').read()).hexdigest()[:24])" "${mem_file}" 2>/dev/null || echo "none"
  else
    echo "none"
  fi
}

start_cmd() {
  ensure_chain

  local agent_id fingerprint slug now pending_file
  agent_id="$(get_agent_id)"
  fingerprint="$(get_session_fingerprint)"
  slug="$(project_slug)"
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  pending_file="${PROVENANCE_ROOT}/pending.json"

  # Touch agent to increment session count
  if [[ -x "${ROOT}/bin/lacp-agent-id" ]]; then
    "${ROOT}/bin/lacp-agent-id" touch --json >/dev/null 2>&1 || true
  fi

  python3 - <<'PY' "${pending_file}" "${agent_id}" "${fingerprint}" "${slug}" "${now}"
import json, sys

pending_path = sys.argv[1]
data = {
    "agent_id": sys.argv[2],
    "session_fingerprint": sys.argv[3],
    "project_slug": sys.argv[4],
    "started_at": sys.argv[5],
    "status": "pending"
}

with open(pending_path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY

  local result
  result="$(cat "${pending_file}")"

  if [[ "${AS_JSON}" -eq 1 ]]; then
    printf '%s\n' "${result}" | jq '{schema_version:"1",kind:"provenance_start",ok:true} + .'
  else
    echo "provenance: session started"
    echo "  agent: ${agent_id}"
    echo "  project: ${slug}"
  fi
}

end_cmd() {
  ensure_chain

  local pending_file="${PROVENANCE_ROOT}/pending.json"
  if [[ ! -f "${pending_file}" ]]; then
    if [[ "${AS_JSON}" -eq 1 ]]; then
      jq -n '{schema_version:"1",kind:"provenance_end",ok:false,error:"no pending session"}'
    else
      echo "Error: no pending session to end" >&2
    fi
    return 1
  fi

  local now mem_h
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  mem_h="$(memory_hash)"

  python3 - <<'PY' "${pending_file}" "${CHAIN_FILE}" "${now}" "${mem_h}"
import json, sys, hashlib

pending_path = sys.argv[1]
chain_path = sys.argv[2]
ended_at = sys.argv[3]
mem_hash = sys.argv[4]

pending = json.load(open(pending_path))

# Get prev_hash from last chain entry
prev_hash = "genesis"
try:
    with open(chain_path) as f:
        lines = [l.strip() for l in f if l.strip()]
    if lines:
        last = json.loads(lines[-1])
        prev_hash = last.get("receipt_hash", "genesis")
except Exception:
    pass

# Build receipt
receipt = {
    "receipt_id": f"r-{ended_at.replace(':','').replace('-','')}",
    "agent_id": pending.get("agent_id", "unknown"),
    "session_fingerprint": pending.get("session_fingerprint", "unknown"),
    "project_slug": pending.get("project_slug", "unknown"),
    "started_at": pending.get("started_at", "unknown"),
    "ended_at": ended_at,
    "memory_hash": mem_hash,
    "prev_hash": prev_hash,
}

# Compute receipt_hash over the canonical JSON (without receipt_hash itself)
canonical = json.dumps(receipt, sort_keys=True, separators=(",", ":"))
receipt["receipt_hash"] = hashlib.sha256(canonical.encode("utf-8")).hexdigest()[:24]

# Append to chain
with open(chain_path, "a") as f:
    f.write(json.dumps(receipt, separators=(",", ":")) + "\n")

# Remove pending
import os
os.remove(pending_path)

PY

  local result
  result="$(tail -1 "${CHAIN_FILE}")"

  if [[ "${AS_JSON}" -eq 1 ]]; then
    printf '%s\n' "${result}" | jq '{schema_version:"1",kind:"provenance_end",ok:true} + .'
  else
    local receipt_id
    receipt_id="$(printf '%s' "${result}" | jq -r '.receipt_id')"
    echo "provenance: session sealed"
    echo "  receipt: ${receipt_id}"
    echo "  prev_hash: $(printf '%s' "${result}" | jq -r '.prev_hash')"
    echo "  receipt_hash: $(printf '%s' "${result}" | jq -r '.receipt_hash')"
  fi
}

verify_cmd() {
  ensure_chain

  python3 - <<'PY' "${CHAIN_FILE}"
import json, sys, hashlib

chain_path = sys.argv[1]
try:
    with open(chain_path) as f:
        lines = [l.strip() for l in f if l.strip()]
except Exception:
    lines = []

if not lines:
    print(json.dumps({
        "schema_version": "1",
        "kind": "provenance_verify",
        "ok": True,
        "chain_length": 0,
        "breaks": [],
        "agent_ids": []
    }))
    sys.exit(0)

breaks = []
agent_ids = set()
prev_expected = "genesis"

for i, line in enumerate(lines):
    try:
        entry = json.loads(line)
    except Exception:
        breaks.append({"index": i, "error": "invalid JSON"})
        continue

    agent_ids.add(entry.get("agent_id", "unknown"))

    # Check prev_hash linkage
    actual_prev = entry.get("prev_hash", "")
    if actual_prev != prev_expected:
        breaks.append({
            "index": i,
            "receipt_id": entry.get("receipt_id", "?"),
            "error": "prev_hash mismatch",
            "expected": prev_expected,
            "got": actual_prev
        })

    # Verify receipt_hash
    receipt_hash = entry.pop("receipt_hash", None)
    canonical = json.dumps(entry, sort_keys=True, separators=(",", ":"))
    computed = hashlib.sha256(canonical.encode("utf-8")).hexdigest()[:24]
    if receipt_hash != computed:
        breaks.append({
            "index": i,
            "receipt_id": entry.get("receipt_id", "?"),
            "error": "receipt_hash tampered",
            "expected": computed,
            "got": receipt_hash
        })

    prev_expected = receipt_hash if receipt_hash else computed
    entry["receipt_hash"] = receipt_hash  # restore for next iteration

first_receipt = json.loads(lines[0]).get("started_at", "?") if lines else None
last_receipt = json.loads(lines[-1]).get("ended_at", "?") if lines else None

result = {
    "schema_version": "1",
    "kind": "provenance_verify",
    "ok": len(breaks) == 0,
    "chain_length": len(lines),
    "first_receipt": first_receipt,
    "last_receipt": last_receipt,
    "breaks": breaks,
    "agent_ids": sorted(agent_ids)
}
print(json.dumps(result))
PY

  local result
  result="$(python3 - <<'PY2' "${CHAIN_FILE}"
import json, sys, hashlib

chain_path = sys.argv[1]
try:
    with open(chain_path) as f:
        lines = [l.strip() for l in f if l.strip()]
except Exception:
    lines = []

if not lines:
    print(json.dumps({"ok": True, "chain_length": 0, "breaks": [], "agent_ids": []}))
    sys.exit(0)

breaks = []
agent_ids = set()
prev_expected = "genesis"

for i, line in enumerate(lines):
    try:
        entry = json.loads(line)
    except Exception:
        breaks.append({"index": i, "error": "invalid JSON"})
        continue

    agent_ids.add(entry.get("agent_id", "unknown"))
    actual_prev = entry.get("prev_hash", "")
    if actual_prev != prev_expected:
        breaks.append({"index": i, "receipt_id": entry.get("receipt_id", "?"), "error": "prev_hash mismatch"})

    receipt_hash = entry.pop("receipt_hash", None)
    canonical = json.dumps(entry, sort_keys=True, separators=(",", ":"))
    computed = hashlib.sha256(canonical.encode("utf-8")).hexdigest()[:24]
    if receipt_hash != computed:
        breaks.append({"index": i, "receipt_id": entry.get("receipt_id", "?"), "error": "receipt_hash tampered"})
    entry["receipt_hash"] = receipt_hash
    prev_expected = receipt_hash if receipt_hash else computed

print(json.dumps({
    "schema_version": "1", "kind": "provenance_verify", "ok": len(breaks) == 0,
    "chain_length": len(lines),
    "first_receipt": json.loads(lines[0]).get("started_at", "?"),
    "last_receipt": json.loads(lines[-1]).get("ended_at", "?"),
    "breaks": breaks, "agent_ids": sorted(agent_ids)
}))
PY2
)"

  if [[ "${AS_JSON}" -eq 1 ]]; then
    printf '%s\n' "${result}" | jq .
  else
    local ok chain_len breaks_count
    ok="$(printf '%s' "${result}" | jq -r '.ok')"
    chain_len="$(printf '%s' "${result}" | jq -r '.chain_length')"
    breaks_count="$(printf '%s' "${result}" | jq -r '.breaks | length')"
    if [[ "${ok}" == "true" ]]; then
      echo "provenance: chain intact (${chain_len} receipts, 0 breaks)"
    else
      echo "provenance: CHAIN BROKEN (${chain_len} receipts, ${breaks_count} breaks)" >&2
      printf '%s' "${result}" | jq -r '.breaks[] | "  break at index \(.index): \(.error)"' >&2
    fi
    printf '%s' "${result}" | jq -r '.agent_ids[] | "  agent: \(.)"'
  fi
}

log_cmd() {
  ensure_chain

  if [[ ! -s "${CHAIN_FILE}" ]]; then
    if [[ "${AS_JSON}" -eq 1 ]]; then
      jq -n '{schema_version:"1",kind:"provenance_log",ok:true,entries:[]}'
    else
      echo "provenance: no receipts yet"
    fi
    return
  fi

  if [[ "${AS_JSON}" -eq 1 ]]; then
    python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    lines = [l.strip() for l in f if l.strip()]
last_n = int(sys.argv[2])
entries = [json.loads(l) for l in lines[-last_n:]]
print(json.dumps({'schema_version':'1','kind':'provenance_log','ok':True,'total':len(lines),'showing':len(entries),'entries':entries}))
" "${CHAIN_FILE}" "${LOG_LAST}"
  else
    echo "provenance log (last ${LOG_LAST}):"
    tail -"${LOG_LAST}" "${CHAIN_FILE}" | python3 -c "
import json, sys
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    e = json.loads(line)
    print(f'  {e.get(\"receipt_id\",\"?\")}  agent={e.get(\"agent_id\",\"?\")}  project={e.get(\"project_slug\",\"?\")}  {e.get(\"started_at\",\"?\")} -> {e.get(\"ended_at\",\"?\")}')
"
  fi
}

export_cmd() {
  ensure_chain

  if [[ "${AS_JSON}" -eq 1 ]]; then
    python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    lines = [l.strip() for l in f if l.strip()]
entries = [json.loads(l) for l in lines]
print(json.dumps({'schema_version':'1','kind':'provenance_export','ok':True,'chain_length':len(entries),'chain':entries}, indent=2))
" "${CHAIN_FILE}"
  else
    cat "${CHAIN_FILE}"
  fi
}

case "${sub}" in
  start) start_cmd ;;
  end) end_cmd ;;
  verify) verify_cmd ;;
  log) log_cmd ;;
  export) export_cmd ;;
  *) die "Unknown subcommand: ${sub}" ;;
esac
