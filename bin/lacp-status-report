#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-status-report [--print] [--json]

Options:
  --print   Print markdown report to stdout instead of writing file
  --json    Print JSON payload to stdout

Default:
  Writes markdown report to docs/system-status.md
EOF
}

MODE="write"
FORMAT="md"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --print)
      MODE="print"
      shift
      ;;
    --json)
      FORMAT="json"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

require_cmd jq

MODE_JSON="$("${ROOT}/bin/lacp-mode" show --json)"
DOCTOR_JSON="$("${ROOT}/bin/lacp-doctor" --json 2>/dev/null || true)"
if [[ -z "${DOCTOR_JSON}" ]]; then
  DOCTOR_JSON='{"ok":false,"summary":{"pass":0,"warn":0,"fail":1}}'
fi

POLICY_PROVIDER="$(jq -r '.routing.remote_provider // "daytona"' "${LACP_SANDBOX_POLICY_FILE}")"
ALLOW_REMOTE="$(echo "${MODE_JSON}" | jq -r '.allow_external_remote')"
MODE_NAME="$(echo "${MODE_JSON}" | jq -r '.mode')"
APPROVAL_VALID="$(echo "${MODE_JSON}" | jq -r '.remote_approval.valid // false')"
APPROVAL_EXPIRES_AT="$(echo "${MODE_JSON}" | jq -r '.remote_approval.expires_at_utc // ""')"

PASS_COUNT="$(echo "${DOCTOR_JSON}" | jq -r '.summary.pass')"
WARN_COUNT="$(echo "${DOCTOR_JSON}" | jq -r '.summary.warn')"
FAIL_COUNT="$(echo "${DOCTOR_JSON}" | jq -r '.summary.fail')"
DOCTOR_OK="$(echo "${DOCTOR_JSON}" | jq -r '.ok')"

as_json_int() {
  local raw="${1:-}"
  if [[ "${raw}" =~ ^-?[0-9]+$ ]]; then
    echo "${raw}"
  else
    echo "0"
  fi
}

PASS_COUNT_JSON="$(as_json_int "${PASS_COUNT}")"
WARN_COUNT_JSON="$(as_json_int "${WARN_COUNT}")"
FAIL_COUNT_JSON="$(as_json_int "${FAIL_COUNT}")"

latest_or_none() {
  local pattern="$1"
  local found
  found="$(latest_file "${pattern}" || true)"
  if [[ -z "${found}" ]]; then
    echo ""
  else
    echo "${found}"
  fi
}

LATEST_BENCH="$(latest_or_none "${LACP_KNOWLEDGE_ROOT}/data/benchmarks/benchmark-*.json")"
LATEST_SNAPSHOT="$(latest_or_none "${LACP_AUTOMATION_ROOT}/data/snapshots/snapshot-*.json")"
LATEST_SANDBOX_RUN="$(latest_or_none "${LACP_KNOWLEDGE_ROOT}/data/sandbox-runs/run-*.json")"
LATEST_REMOTE_SMOKE="$(latest_or_none "${LACP_KNOWLEDGE_ROOT}/data/remote-smoke/smoke-*.json")"

BENCH_SUMMARY="n/a"
BENCH_GATE_JSON="null"
BENCH_GATE_LABEL="unknown"
if [[ -n "${LATEST_BENCH}" ]]; then
  BENCH_GATE_JSON="$(jq -c '.gate_ok // null' "${LATEST_BENCH}" 2>/dev/null || echo "null")"
  if [[ "${BENCH_GATE_JSON}" == "true" || "${BENCH_GATE_JSON}" == "false" ]]; then
    BENCH_GATE_LABEL="${BENCH_GATE_JSON}"
  else
    BENCH_GATE_LABEL="unknown"
  fi
  BENCH_SUMMARY="$(jq -r '"hit@\(.summary.hit_rate_at_k // "n/a"), mrr@\(.summary.mrr_at_k // "n/a"), ndcg@\(.summary.ndcg_at_k // "n/a")"' "${LATEST_BENCH}" 2>/dev/null || echo "n/a")"
fi

# Brain health (optional, best-effort)
BRAIN_OK="unknown"
BRAIN_PASS=0
BRAIN_WARN=0
BRAIN_FAIL=0
if [[ -x "${ROOT}/bin/lacp-brain-doctor" ]]; then
  brain_json="$("${ROOT}/bin/lacp-brain-doctor" --json 2>/dev/null || echo '{"ok":null}')"
  BRAIN_OK="$(echo "${brain_json}" | jq -r '.ok // "unknown"')"
  BRAIN_PASS="$(echo "${brain_json}" | jq -r '.summary.pass // 0')"
  BRAIN_WARN="$(echo "${brain_json}" | jq -r '.summary.warn // 0')"
  BRAIN_FAIL="$(echo "${brain_json}" | jq -r '.summary.fail // 0')"
fi
BRAIN_PASS_JSON="$(as_json_int "${BRAIN_PASS}")"
BRAIN_WARN_JSON="$(as_json_int "${BRAIN_WARN}")"
BRAIN_FAIL_JSON="$(as_json_int "${BRAIN_FAIL}")"

REPORT_TIME_UTC="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
REPORT_FILE="${ROOT}/docs/system-status.md"

if [[ "${FORMAT}" == "json" ]]; then
  jq -n \
    --arg generated_at "${REPORT_TIME_UTC}" \
    --arg mode "${MODE_NAME}" \
    --arg allow_remote "${ALLOW_REMOTE}" \
    --arg remote_provider "${POLICY_PROVIDER}" \
    --arg approval_valid "${APPROVAL_VALID}" \
    --arg approval_expires_at "${APPROVAL_EXPIRES_AT}" \
    --argjson doctor_ok "$([[ "${DOCTOR_OK}" == "true" ]] && echo true || echo false)" \
    --argjson pass_count "${PASS_COUNT_JSON}" \
    --argjson warn_count "${WARN_COUNT_JSON}" \
    --argjson fail_count "${FAIL_COUNT_JSON}" \
    --arg latest_benchmark "${LATEST_BENCH}" \
    --argjson benchmark_gate_ok "${BENCH_GATE_JSON}" \
    --arg benchmark_gate_label "${BENCH_GATE_LABEL}" \
    --arg benchmark_summary "${BENCH_SUMMARY}" \
    --arg latest_snapshot "${LATEST_SNAPSHOT}" \
    --arg latest_sandbox_run "${LATEST_SANDBOX_RUN}" \
    --arg latest_remote_smoke "${LATEST_REMOTE_SMOKE}" \
    --arg brain_ok "${BRAIN_OK}" \
    --argjson brain_pass "${BRAIN_PASS_JSON}" \
    --argjson brain_warn "${BRAIN_WARN_JSON}" \
    --argjson brain_fail "${BRAIN_FAIL_JSON}" \
    '{
      schema_version: "1",
      kind: "status",
      generated_at_utc: $generated_at,
      ok: ($doctor_ok and (($benchmark_gate_ok == null) or ($benchmark_gate_ok == true))),
      summary: {
        mode: $mode,
        doctor_ok: $doctor_ok,
        doctor_pass: $pass_count,
        doctor_warn: $warn_count,
        doctor_fail: $fail_count,
        benchmark_gate_ok: $benchmark_gate_ok
      },
      mode: $mode,
      allow_external_remote: $allow_remote,
      remote_provider: $remote_provider,
      remote_approval: {
        valid: $approval_valid,
        expires_at_utc: (if $approval_expires_at == "" then null else $approval_expires_at end)
      },
      doctor: {
        ok: $doctor_ok,
        pass: $pass_count,
        warn: $warn_count,
        fail: $fail_count
      },
      brain: {
        ok: $brain_ok,
        pass: $brain_pass,
        warn: $brain_warn,
        fail: $brain_fail
      },
      artifacts: {
        latest_benchmark: $latest_benchmark,
        benchmark_gate_ok: $benchmark_gate_ok,
        benchmark_gate_label: $benchmark_gate_label,
        benchmark_summary: $benchmark_summary,
        latest_snapshot: $latest_snapshot,
        latest_sandbox_run: $latest_sandbox_run,
        latest_remote_smoke: $latest_remote_smoke
      }
    }'
  exit 0
fi

REPORT_MD=$(cat <<EOF
# LACP System Status

Generated (UTC): \`${REPORT_TIME_UTC}\`

## Mode

- Mode: \`${MODE_NAME}\`
- External remote allowed: \`${ALLOW_REMOTE}\`
- Policy remote provider: \`${POLICY_PROVIDER}\`
- Remote approval valid: \`${APPROVAL_VALID}\`
- Remote approval expires: \`${APPROVAL_EXPIRES_AT:-<none>}\`

## Doctor

- Overall OK: \`${DOCTOR_OK}\`
- Pass: \`${PASS_COUNT}\`
- Warn: \`${WARN_COUNT}\`
- Fail: \`${FAIL_COUNT}\`

## Brain

- Brain OK: \`${BRAIN_OK}\`
- Pass: \`${BRAIN_PASS}\`
- Warn: \`${BRAIN_WARN}\`
- Fail: \`${BRAIN_FAIL}\`

## Artifacts

- Latest benchmark: \`${LATEST_BENCH:-<none>}\`
- Benchmark gate: \`${BENCH_GATE_LABEL}\`
- Benchmark summary: \`${BENCH_SUMMARY}\`
- Latest snapshot: \`${LATEST_SNAPSHOT:-<none>}\`
- Latest sandbox run: \`${LATEST_SANDBOX_RUN:-<none>}\`
- Latest remote smoke: \`${LATEST_REMOTE_SMOKE:-<none>}\`
EOF
)

if [[ "${MODE}" == "print" ]]; then
  printf '%s\n' "${REPORT_MD}"
else
  printf '%s\n' "${REPORT_MD}" > "${REPORT_FILE}"
  log "status report written: ${REPORT_FILE}"
fi
