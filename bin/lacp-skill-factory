#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-skill-factory <command> [args...]

Commands:
  record       Record workflow execution JSON from stdin
  capture      Run validation command capture helper
  lifecycle    Manage workflow lifecycle (dry-run/apply)
  recluster    Merge fragmented historical signatures
  revalidate   Revalidate generated autogen skills
  migrate-bundles Migrate one-off autogen skills to categorized bundles
  summary      Print compact ledger + autogen summary

Options:
  --root <dir> Override auto-skill-factory root

Examples:
  lacp-skill-factory summary
  lacp-skill-factory capture --cmd "cargo test"
  cat payload.json | lacp-skill-factory record
EOF
}

SKILL_FACTORY_ROOT="${LACP_SKILL_FACTORY_ROOT:-$HOME/.agents/skills/auto-skill-factory}"

if [[ $# -lt 1 ]]; then
  usage
  exit 0
fi

cmd=""
args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --root)
      [[ $# -ge 2 ]] || die "--root requires a value"
      SKILL_FACTORY_ROOT="$2"
      shift 2
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    --*)
      die "Unknown global option: $1"
      ;;
    *)
      if [[ -z "${cmd}" ]]; then
        cmd="$1"
      else
        args+=("$1")
      fi
      shift
      ;;
  esac
done

[[ -n "${cmd}" ]] || die "Missing command. Run --help for usage."

script_path() {
  local name="$1"
  printf '%s/scripts/%s' "${SKILL_FACTORY_ROOT}" "${name}"
}

require_skill_factory() {
  require_dir "${SKILL_FACTORY_ROOT}"
  require_file "$(script_path record_workflow.py)"
}

require_script() {
  local script_name="$1"
  local path
  path="$(script_path "${script_name}")"
  if [[ ! -f "${path}" ]]; then
    die "Missing required script for command '${cmd}': ${path}"
  fi
}

run_summary() {
  python3 - <<'PY' "${SKILL_FACTORY_ROOT}"
import json
from pathlib import Path
import sys

root = Path(sys.argv[1]).expanduser()
ledger_path = root / "state" / "workflow_ledger.json"
skills_root = root.parent
if not ledger_path.exists():
    print(json.dumps({"ok": False, "error": "ledger_missing", "ledger_path": str(ledger_path)}))
    raise SystemExit(1)

ledger = json.loads(ledger_path.read_text())
workflows = ledger.get("workflows", {})
if not isinstance(workflows, dict):
    print(json.dumps({"ok": False, "error": "invalid_ledger", "ledger_path": str(ledger_path)}))
    raise SystemExit(1)

counts = [int(v.get("count", 0)) for v in workflows.values() if isinstance(v, dict)]
linked = [
    v.get("autogen_skill")
    for v in workflows.values()
    if isinstance(v, dict) and isinstance(v.get("autogen_skill"), str) and v.get("autogen_skill")
]
autogen_dirs = sorted(p.name for p in skills_root.glob("autogen-*") if p.is_dir())

print(
    json.dumps(
        {
            "ok": True,
            "ledger_path": str(ledger_path),
            "workflow_count": len(counts),
            "workflows_gt1": sum(1 for c in counts if c > 1),
            "workflows_gte5": sum(1 for c in counts if c >= 5),
            "max_count": max(counts) if counts else 0,
            "linked_count": len(linked),
            "linked_unique_skills": sorted(set(linked)),
            "autogen_skill_dirs": autogen_dirs,
        }
    )
)
PY
}

case "${cmd}" in
  record)
    require_skill_factory
    require_script record_workflow.py
    exec python3 "$(script_path record_workflow.py)" "${args[@]}"
    ;;
  capture)
    require_skill_factory
    require_script capture_validation.py
    exec python3 "$(script_path capture_validation.py)" "${args[@]}"
    ;;
  lifecycle)
    require_skill_factory
    require_script manage_lifecycle.py
    exec python3 "$(script_path manage_lifecycle.py)" "${args[@]}"
    ;;
  recluster)
    require_skill_factory
    require_script recluster_workflows.py
    exec python3 "$(script_path recluster_workflows.py)" "${args[@]}"
    ;;
  revalidate)
    require_skill_factory
    require_script revalidate_autogen_skills.py
    exec python3 "$(script_path revalidate_autogen_skills.py)" "${args[@]}"
    ;;
  migrate-bundles)
    require_skill_factory
    require_script migrate_category_bundles.py
    exec python3 "$(script_path migrate_category_bundles.py)" "${args[@]}"
    ;;
  summary)
    require_skill_factory
    run_summary
    ;;
  *)
    die "Unknown command: ${cmd}"
    ;;
esac
