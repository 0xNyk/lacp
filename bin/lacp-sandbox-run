#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-sandbox-run --task "<summary>" [routing options] [--dry-run] [--json] -- <command> [args...]

Routing options:
  --repo-trust trusted|unknown|untrusted   (default: unknown)
  --internet true|false                    (default: false)
  --external-code true|false               (default: false)
  --sensitive-data true|false              (default: false)
  --cpu-heavy true|false                   (default: false)
  --long-run true|false                    (default: false)
  --remote-provider auto|daytona|e2b       (default: auto)

Execution options:
  --dry-run      Do not execute the command
  --json         Emit JSON result
  --confirm-critical true|false
                 Required=true when route risk_tier is critical.
  --estimated-cost-usd <number>
                 Estimated cost of this run used for per-tier budget gates.
  --confirm-budget true|false
                 Allow explicit override when estimated cost exceeds tier ceiling.
  --input-contract '<json>'
                 Structured preflight contract required for risky runs when
                 LACP_REQUIRE_INPUT_CONTRACT=true.

Environment:
  LACP_LOCAL_SANDBOX_RUNNER   Optional executable for local_sandbox tier. Called as:
                              <runner> -- <command> [args...]
  LACP_REMOTE_SANDBOX_RUNNER  Optional executable for remote_sandbox tier. Called as:
                              <runner> -- <command> [args...]
EOF
}

validate_input_contract() {
  local raw_json="$1"
  local min_confidence="$2"
  python3 - <<'PY' "${raw_json}" "${min_confidence}"
import json
import sys

raw = sys.argv[1]
min_conf = float(sys.argv[2])
try:
    obj = json.loads(raw)
except Exception as exc:
    print(f"invalid json: {exc}")
    raise SystemExit(1)

if not isinstance(obj, dict):
    print("contract must be a json object")
    raise SystemExit(1)

required = ("source", "intent", "allowed_actions", "denied_actions", "confidence")
missing = [k for k in required if k not in obj]
if missing:
    print(f"missing keys: {','.join(missing)}")
    raise SystemExit(1)

if not isinstance(obj["source"], str) or not obj["source"].strip():
    print("source must be non-empty string")
    raise SystemExit(1)
if not isinstance(obj["intent"], str) or not obj["intent"].strip():
    print("intent must be non-empty string")
    raise SystemExit(1)
if not isinstance(obj["allowed_actions"], list) or not obj["allowed_actions"]:
    print("allowed_actions must be a non-empty array")
    raise SystemExit(1)
if not isinstance(obj["denied_actions"], list):
    print("denied_actions must be an array")
    raise SystemExit(1)
if not all(isinstance(x, str) and x.strip() for x in obj["allowed_actions"]):
    print("allowed_actions must contain non-empty strings")
    raise SystemExit(1)
if not all(isinstance(x, str) and x.strip() for x in obj["denied_actions"]):
    print("denied_actions must contain non-empty strings")
    raise SystemExit(1)
if not isinstance(obj["confidence"], (int, float)):
    print("confidence must be numeric")
    raise SystemExit(1)
if float(obj["confidence"]) < min_conf or float(obj["confidence"]) > 1.0:
    print(f"confidence must be between {min_conf} and 1.0")
    raise SystemExit(1)
PY
}

as_bool() {
  case "$1" in
    true|false) printf '%s' "$1" ;;
    *) die "Expected true|false, got: $1" ;;
  esac
}

json_escape_cmd() {
  printf '%s\0' "$@" | xargs -0 -n1 printf '%s\n' | jq -R . | jq -s .
}

now_ms() {
  python3 - <<'PY'
import time
print(int(time.time() * 1000))
PY
}

approval_state_json() {
  local approval_file="${LACP_REMOTE_APPROVAL_FILE}"
  local expires_at_utc ttl_min valid status reason

  if [[ ! -f "${approval_file}" ]]; then
    jq -n --arg file "${approval_file}" '{
      file: $file,
      status: "missing",
      valid: false,
      reason: "approval file missing"
    }'
    return 0
  fi

  if ! jq -e . "${approval_file}" >/dev/null 2>&1; then
    jq -n --arg file "${approval_file}" '{
      file: $file,
      status: "invalid",
      valid: false,
      reason: "approval file is not valid json"
    }'
    return 0
  fi

  expires_at_utc="$(jq -r '.expires_at_utc // ""' "${approval_file}")"
  ttl_min="$(jq -r '.ttl_min // 0' "${approval_file}")"
  if [[ -z "${expires_at_utc}" ]]; then
    jq -n \
      --arg file "${approval_file}" \
      --argjson ttl_min "${ttl_min}" \
      '{
        file: $file,
        status: "invalid",
        valid: false,
        ttl_min: $ttl_min,
        reason: "expires_at_utc missing in approval file"
      }'
    return 0
  fi

  if python3 - <<'PY' "${expires_at_utc}"
import datetime as dt
import sys

try:
    expires = dt.datetime.strptime(sys.argv[1], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=dt.timezone.utc)
except Exception:
    raise SystemExit(1)
now = dt.datetime.now(dt.timezone.utc)
raise SystemExit(0 if expires > now else 1)
PY
  then
    valid="true"
    status="active"
    reason="approval valid"
  else
    valid="false"
    status="expired"
    reason="approval expired"
  fi

  jq -n \
    --arg file "${approval_file}" \
    --arg status "${status}" \
    --arg reason "${reason}" \
    --arg expires_at_utc "${expires_at_utc}" \
    --argjson ttl_min "${ttl_min}" \
    --argjson valid "$([[ "${valid}" == "true" ]] && echo true || echo false)" \
    '{
      file: $file,
      status: $status,
      valid: $valid,
      expires_at_utc: $expires_at_utc,
      ttl_min: $ttl_min,
      reason: $reason
    }'
}

TASK=""
REPO_TRUST="unknown"
INTERNET="false"
EXTERNAL_CODE="false"
SENSITIVE_DATA="false"
CPU_HEAVY="false"
LONG_RUN="false"
REMOTE_PROVIDER_OVERRIDE="auto"
DRY_RUN=0
AS_JSON=0
CONFIRM_CRITICAL="false"
ESTIMATED_COST_USD="0"
CONFIRM_BUDGET="false"
INPUT_CONTRACT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --task)
      TASK="$2"
      shift 2
      ;;
    --repo-trust)
      REPO_TRUST="$2"
      shift 2
      ;;
    --internet)
      INTERNET="$(as_bool "$2")"
      shift 2
      ;;
    --external-code)
      EXTERNAL_CODE="$(as_bool "$2")"
      shift 2
      ;;
    --sensitive-data)
      SENSITIVE_DATA="$(as_bool "$2")"
      shift 2
      ;;
    --cpu-heavy)
      CPU_HEAVY="$(as_bool "$2")"
      shift 2
      ;;
    --long-run)
      LONG_RUN="$(as_bool "$2")"
      shift 2
      ;;
    --remote-provider)
      REMOTE_PROVIDER_OVERRIDE="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --json)
      AS_JSON=1
      shift
      ;;
    --confirm-critical)
      CONFIRM_CRITICAL="$(as_bool "$2")"
      shift 2
      ;;
    --estimated-cost-usd)
      ESTIMATED_COST_USD="$2"
      shift 2
      ;;
    --confirm-budget)
      CONFIRM_BUDGET="$(as_bool "$2")"
      shift 2
      ;;
    --input-contract)
      INPUT_CONTRACT="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

[[ -n "${TASK}" ]] || die "--task is required"
case "${REPO_TRUST}" in
  trusted|unknown|untrusted) ;;
  *) die "--repo-trust must be trusted|unknown|untrusted" ;;
esac
case "${REMOTE_PROVIDER_OVERRIDE}" in
  auto|daytona|e2b) ;;
  *) die "--remote-provider must be auto|daytona|e2b" ;;
esac

if [[ "${DRY_RUN}" -eq 0 && $# -eq 0 ]]; then
  die "No command provided. Use -- <command> [args...]"
fi

CMD=("$@")
ROUTE_JSON="$("${ROOT}/bin/lacp-route" \
  --task "${TASK}" \
  --repo-trust "${REPO_TRUST}" \
  --internet "${INTERNET}" \
  --external-code "${EXTERNAL_CODE}" \
  --sensitive-data "${SENSITIVE_DATA}" \
  --cpu-heavy "${CPU_HEAVY}" \
  --long-run "${LONG_RUN}" \
  --remote-provider "${REMOTE_PROVIDER_OVERRIDE}" \
  --json)"

ROUTE="$(printf '%s' "${ROUTE_JSON}" | jq -r '.route')"
REMOTE_PROVIDER="$(printf '%s' "${ROUTE_JSON}" | jq -r '.remote_provider // empty')"
RISK_TIER="$(printf '%s' "${ROUTE_JSON}" | jq -r '.risk_tier // "review"')"
COST_CEILING_USD="$(printf '%s' "${ROUTE_JSON}" | jq -r '.cost_ceiling_usd // 0')"
REASONS_JSON="$(printf '%s' "${ROUTE_JSON}" | jq -c '.reasons')"

if ! [[ "${ESTIMATED_COST_USD}" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
  die "--estimated-cost-usd must be a non-negative number"
fi

RUNNER_TYPE=""
RUNNER_PATH=""
EXEC_RC=0
EXECUTED=0
ERROR_MSG=""
START_MS="$(now_ms)"
STARTED_AT_UTC="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
APPROVAL_JSON="null"
INPUT_CONTRACT_VALID="false"
INPUT_CONTRACT_REQUIRED="false"
INPUT_CONTRACT_ERROR=""

if [[ "${DRY_RUN}" -eq 0 ]]; then
  if [[ "${LACP_REQUIRE_INPUT_CONTRACT}" == "true" ]] && [[ "${RISK_TIER}" != "safe" ]] && [[ "${INTERNET}" == "true" || "${EXTERNAL_CODE}" == "true" || "${SENSITIVE_DATA}" == "true" ]]; then
    INPUT_CONTRACT_REQUIRED="true"
  fi

  if [[ "${INPUT_CONTRACT_REQUIRED}" == "true" ]]; then
    if [[ -z "${INPUT_CONTRACT}" ]]; then
      EXEC_RC=11
      ERROR_MSG="blocked by structured input gate: pass --input-contract with source/intent/allowed_actions/denied_actions/confidence"
    elif validate_input_contract "${INPUT_CONTRACT}" "${LACP_INPUT_CONTRACT_CONFIDENCE_MIN}" >/dev/null 2>&1; then
      INPUT_CONTRACT_VALID="true"
    else
      INPUT_CONTRACT_ERROR="$(validate_input_contract "${INPUT_CONTRACT}" "${LACP_INPUT_CONTRACT_CONFIDENCE_MIN}" 2>&1 || true)"
      EXEC_RC=11
      ERROR_MSG="blocked by structured input gate: invalid --input-contract (${INPUT_CONTRACT_ERROR})"
    fi
  fi

  if [[ "${EXEC_RC}" -ne 0 ]]; then
    EXECUTED=0
  elif [[ "${RISK_TIER}" == "critical" && "${CONFIRM_CRITICAL}" != "true" ]]; then
    EXEC_RC=9
    ERROR_MSG="blocked by risk_tier=critical: pass --confirm-critical true"
  elif ! python3 - <<'PY' "${ESTIMATED_COST_USD}" "${COST_CEILING_USD}"
import sys
estimated = float(sys.argv[1])
ceiling = float(sys.argv[2])
raise SystemExit(0 if estimated <= ceiling else 1)
PY
  then
    if [[ "${CONFIRM_BUDGET}" != "true" ]]; then
      EXEC_RC=10
      ERROR_MSG="blocked by budget gate: estimated_cost_usd=${ESTIMATED_COST_USD} exceeds ceiling=${COST_CEILING_USD} for risk_tier=${RISK_TIER}; pass --confirm-budget true to override"
    fi
  elif [[ "${RISK_TIER}" == "review" && "${ROUTE}" != "trusted_local" ]]; then
    APPROVAL_JSON="$(approval_state_json)"
    APPROVAL_VALID="$(printf '%s' "${APPROVAL_JSON}" | jq -r '.valid // false')"
    if [[ "${APPROVAL_VALID}" != "true" ]]; then
      EXEC_RC=8
      ERROR_MSG="blocked by review approval TTL: $(printf '%s' "${APPROVAL_JSON}" | jq -r '.reason // "missing approval"'). renew with: bin/lacp-mode remote-enabled --ttl-min ${LACP_REMOTE_APPROVAL_TTL_MIN}"
    fi
  fi
fi

run_direct() {
  local -a cmd=("$@")
  "${cmd[@]}"
}

run_with_runner() {
  local runner="$1"
  shift
  local -a cmd=("$@")
  "${runner}" -- "${cmd[@]}"
}

if [[ "${DRY_RUN}" -eq 1 ]]; then
  EXECUTED=0
elif [[ "${EXEC_RC}" -ne 0 ]]; then
  EXECUTED=0
else
  case "${ROUTE}" in
    trusted_local)
      RUNNER_TYPE="direct"
      run_direct "${CMD[@]}" || EXEC_RC=$?
      EXECUTED=1
      ;;
    local_sandbox)
      RUNNER_TYPE="local_sandbox_runner"
      RUNNER_PATH="${LACP_LOCAL_SANDBOX_RUNNER:-}"
      if [[ -n "${RUNNER_PATH}" ]]; then
        run_with_runner "${RUNNER_PATH}" "${CMD[@]}" || EXEC_RC=$?
        EXECUTED=1
      else
        RUNNER_TYPE="direct_fallback"
        log "WARN: LACP_LOCAL_SANDBOX_RUNNER is unset; falling back to direct execution"
        run_direct "${CMD[@]}" || EXEC_RC=$?
        EXECUTED=1
      fi
      ;;
    remote_sandbox)
      if [[ "${LACP_ALLOW_EXTERNAL_REMOTE}" != "true" ]]; then
        EXEC_RC=7
        ERROR_MSG="route=remote_sandbox blocked by policy: set LACP_ALLOW_EXTERNAL_REMOTE=true to enable external remote execution"
        EXECUTED=0
      else
        RUNNER_TYPE="remote_sandbox_runner"
        RUNNER_PATH="${LACP_REMOTE_SANDBOX_RUNNER:-}"
        if [[ -z "${RUNNER_PATH}" ]]; then
          case "${REMOTE_PROVIDER}" in
            daytona) RUNNER_PATH="${ROOT}/scripts/runners/daytona-runner.sh" ;;
            e2b) RUNNER_PATH="${ROOT}/scripts/runners/e2b-runner.sh" ;;
            *) RUNNER_PATH="" ;;
          esac
        fi
        if [[ -n "${RUNNER_PATH}" ]]; then
          run_with_runner "${RUNNER_PATH}" "${CMD[@]}" || EXEC_RC=$?
          EXECUTED=1
        else
          EXEC_RC=3
          ERROR_MSG="route=remote_sandbox but no runner resolved (provider=${REMOTE_PROVIDER:-unknown})"
        fi
      fi
      ;;
    *)
      EXEC_RC=4
      ERROR_MSG="Unknown route: ${ROUTE}"
      ;;
  esac
fi

RUNS_DIR="${LACP_KNOWLEDGE_ROOT}/data/sandbox-runs"
mkdir -p "${RUNS_DIR}"
RUN_TAG="$(date -u +%Y%m%dT%H%M%SZ)-$$-${RANDOM}"
RUN_FILE="${RUNS_DIR}/run-${RUN_TAG}.json"
END_MS="$(now_ms)"
COMPLETED_AT_UTC="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
DURATION_MS="$((END_MS - START_MS))"

PROVIDER_META_JSON="null"
if [[ "${ROUTE}" == "remote_sandbox" && -n "${REMOTE_PROVIDER}" ]]; then
  case "${REMOTE_PROVIDER}" in
    daytona)
      if command -v daytona >/dev/null 2>&1; then
        DAYTONA_BIN="$(command -v daytona)"
        DAYTONA_VER="$(daytona version 2>/dev/null | head -n 1 || true)"
        PROVIDER_META_JSON="$(jq -n --arg provider "daytona" --arg cli_path "${DAYTONA_BIN}" --arg cli_version "${DAYTONA_VER}" '{provider:$provider, cli_path:$cli_path, cli_version:$cli_version}')"
      fi
      ;;
    e2b)
      if command -v e2b >/dev/null 2>&1; then
        E2B_BIN="$(command -v e2b)"
        E2B_VER="$(e2b --version 2>/dev/null | head -n 1 || true)"
        PROVIDER_META_JSON="$(jq -n --arg provider "e2b" --arg cli_path "${E2B_BIN}" --arg cli_version "${E2B_VER}" '{provider:$provider, cli_path:$cli_path, cli_version:$cli_version}')"
      fi
      ;;
  esac
fi

CMD_JSON="[]"
if [[ ${#CMD[@]} -gt 0 ]]; then
  CMD_JSON="$(json_escape_cmd "${CMD[@]}")"
fi

jq -n \
  --arg schema_version "1.1.0" \
  --arg timestamp "${RUN_TAG}" \
  --arg started_at "${STARTED_AT_UTC}" \
  --arg completed_at "${COMPLETED_AT_UTC}" \
  --argjson duration_ms "${DURATION_MS}" \
  --arg task "${TASK}" \
  --arg route "${ROUTE}" \
  --arg risk_tier "${RISK_TIER}" \
  --argjson cost_ceiling_usd "${COST_CEILING_USD}" \
  --argjson estimated_cost_usd "${ESTIMATED_COST_USD}" \
  --argjson budget_confirmed "$([[ "${CONFIRM_BUDGET}" == "true" ]] && echo true || echo false)" \
  --argjson input_contract_required "$([[ "${INPUT_CONTRACT_REQUIRED}" == "true" ]] && echo true || echo false)" \
  --argjson input_contract_valid "$([[ "${INPUT_CONTRACT_VALID}" == "true" ]] && echo true || echo false)" \
  --arg input_contract_error "${INPUT_CONTRACT_ERROR}" \
  --argjson reasons "${REASONS_JSON}" \
  --arg remote_provider "${REMOTE_PROVIDER}" \
  --argjson route_decision "${ROUTE_JSON}" \
  --argjson provider_metadata "${PROVIDER_META_JSON}" \
  --argjson remote_approval "${APPROVAL_JSON}" \
  --argjson dry_run "$([[ "${DRY_RUN}" -eq 1 ]] && echo true || echo false)" \
  --argjson executed "$([[ "${EXECUTED}" -eq 1 ]] && echo true || echo false)" \
  --arg runner_type "${RUNNER_TYPE}" \
  --arg runner_path "${RUNNER_PATH}" \
  --arg error "${ERROR_MSG}" \
  --argjson exit_code "${EXEC_RC}" \
  --argjson command "${CMD_JSON}" \
  '{
    schema_version: $schema_version,
    timestamp: $timestamp,
    started_at_utc: $started_at,
    completed_at_utc: $completed_at,
    duration_ms: $duration_ms,
    task: $task,
    route: $route,
    risk_tier: $risk_tier,
    cost_ceiling_usd: $cost_ceiling_usd,
    estimated_cost_usd: $estimated_cost_usd,
    budget_confirmed: $budget_confirmed,
    input_contract: {
      required: $input_contract_required,
      valid: $input_contract_valid,
      error: (if $input_contract_error == "" then null else $input_contract_error end)
    },
    remote_provider: (if $remote_provider == "" then null else $remote_provider end),
    reasons: $reasons,
    route_decision: $route_decision,
    provider_metadata: $provider_metadata,
    remote_approval: $remote_approval,
    dry_run: $dry_run,
    executed: $executed,
    runner: {
      type: $runner_type,
      path: $runner_path
    },
    command: $command,
    exit_code: $exit_code,
    error: (if $error == "" then null else $error end)
  }' > "${RUN_FILE}"

if [[ "${AS_JSON}" -eq 1 ]]; then
  jq -n \
    --arg schema_version "1.1.0" \
    --arg run_file "${RUN_FILE}" \
    --arg route "${ROUTE}" \
    --arg risk_tier "${RISK_TIER}" \
    --argjson cost_ceiling_usd "${COST_CEILING_USD}" \
    --argjson estimated_cost_usd "${ESTIMATED_COST_USD}" \
    --argjson budget_confirmed "$([[ "${CONFIRM_BUDGET}" == "true" ]] && echo true || echo false)" \
    --argjson input_contract_required "$([[ "${INPUT_CONTRACT_REQUIRED}" == "true" ]] && echo true || echo false)" \
    --argjson input_contract_valid "$([[ "${INPUT_CONTRACT_VALID}" == "true" ]] && echo true || echo false)" \
    --arg input_contract_error "${INPUT_CONTRACT_ERROR}" \
    --argjson exit_code "${EXEC_RC}" \
    --argjson executed "$([[ "${EXECUTED}" -eq 1 ]] && echo true || echo false)" \
    --argjson dry_run "$([[ "${DRY_RUN}" -eq 1 ]] && echo true || echo false)" \
    --argjson reasons "${REASONS_JSON}" \
    --arg remote_provider "${REMOTE_PROVIDER}" \
    --argjson duration_ms "${DURATION_MS}" \
    --arg started_at "${STARTED_AT_UTC}" \
    --arg completed_at "${COMPLETED_AT_UTC}" \
    --argjson provider_metadata "${PROVIDER_META_JSON}" \
    --argjson remote_approval "${APPROVAL_JSON}" \
    --arg error "${ERROR_MSG}" \
    '{
      schema_version: $schema_version,
      run_file: $run_file,
      route: $route,
      risk_tier: $risk_tier,
      cost_ceiling_usd: $cost_ceiling_usd,
      estimated_cost_usd: $estimated_cost_usd,
      budget_confirmed: $budget_confirmed,
      input_contract: {
        required: $input_contract_required,
        valid: $input_contract_valid,
        error: (if $input_contract_error == "" then null else $input_contract_error end)
      },
      remote_provider: (if $remote_provider == "" then null else $remote_provider end),
      reasons: $reasons,
      started_at_utc: $started_at,
      completed_at_utc: $completed_at,
      duration_ms: $duration_ms,
      provider_metadata: $provider_metadata,
      remote_approval: $remote_approval,
      dry_run: $dry_run,
      executed: $executed,
      exit_code: $exit_code,
      error: (if $error == "" then null else $error end)
    }'
else
  log "route=${ROUTE} executed=${EXECUTED} exit_code=${EXEC_RC}"
  log "run_file=${RUN_FILE}"
  if [[ -n "${ERROR_MSG}" ]]; then
    log "error=${ERROR_MSG}"
  fi
fi

exit "${EXEC_RC}"
