#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'USAGE'
Usage: lacp-brain-expand [--days N] [--apply] [--strict] [--json] [--skip-qmd]

Runs the local Obsidian brain expansion loop:
  0) Guard Obsidian graph/app config + stable symlinks
  0.5) Obsidian config drift guard
  1) Sync Claude/Codex sessions into vault notes
  2) Materialize captured web research into inbox notes
  3) Sync research signals into knowledge graph nodes
  4) Sync local repo/codebase knowledge into graph notes
  5) Mirror repo docs/research notes into Obsidian graph nodes
  6) Extract Obsidian Agent Daily progress into graph notes
  7) Weekly consolidation gate (canonical synthesis notes from promoted research)
  7.5) Gap detection (cross-category bridges + under-researched areas)
  7.6) FSRS review queue (decaying nodes by retrievability score)
  8) Route + archive inbox notes
  9) Refresh QMD index (optional)
 10) Run brain + knowledge doctors

Options:
  --days N        Lookback window for research sync (default: 7)
  --apply         Apply writes for scripts supporting dry-run/apply modes
  --strict        Return non-zero if any step fails
  --json          Emit machine-readable JSON summary
  --skip-qmd      Skip `qmd update`
  --activate      Enable spreading activation for new research signals
  --consolidate   Use enhanced memory consolidation (prune/merge)
USAGE
}

DAYS=7
APPLY=0
STRICT=0
AS_JSON=0
SKIP_QMD=0
ACTIVATE=0
CONSOLIDATE=0
SANDBOX=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --days)
      DAYS="$2"
      shift 2
      ;;
    --apply)
      APPLY=1
      shift
      ;;
    --strict)
      STRICT=1
      shift
      ;;
    --json)
      AS_JSON=1
      shift
      ;;
    --skip-qmd)
      SKIP_QMD=1
      shift
      ;;
    --activate)
      ACTIVATE=1
      shift
      ;;
    --consolidate)
      CONSOLIDATE=1
      shift
      ;;
    --sandbox)
      SANDBOX=1
      shift
      ;;
    --progress)
      PROGRESS=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

if ! [[ "${DAYS}" =~ ^[0-9]+$ ]]; then
  die "--days must be a non-negative integer"
fi

REAL_AUTOMATION_ROOT="${LACP_AUTOMATION_ROOT}"
REAL_KNOWLEDGE_ROOT="${LACP_KNOWLEDGE_ROOT}"

SCRIPTS_DIR="${LACP_AUTOMATION_ROOT}/scripts"
if [[ ! -d "${SCRIPTS_DIR}" ]]; then
  SCRIPTS_DIR="${REAL_AUTOMATION_ROOT}/scripts"
fi

WORKFLOW_BASE="${LACP_KNOWLEDGE_ROOT}"
if [[ ! -d "${WORKFLOW_BASE}" ]]; then
  WORKFLOW_BASE="${REAL_KNOWLEDGE_ROOT}"
fi
WORKFLOW_DIR="${WORKFLOW_BASE}/data/workflows/brain-expand"
mkdir -p "${WORKFLOW_DIR}"

KNOWLEDGE_DOCTOR_ROOT="${LACP_KNOWLEDGE_GRAPH_ROOT}"
if [[ ! -d "${KNOWLEDGE_DOCTOR_ROOT}" || "${KNOWLEDGE_DOCTOR_ROOT}" == /tmp/lacp-sentinel/* ]]; then
  KNOWLEDGE_DOCTOR_ROOT="${REAL_KNOWLEDGE_ROOT}"
fi

RUN_TS="$(date -u +%Y%m%dT%H%M%SZ)"
LOG_FILE="${WORKFLOW_DIR}/brain-expand-${RUN_TS}.log"
STEPS_FILE="$(mktemp)"
trap 'rm -f "${STEPS_FILE}"' EXIT

PASS_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0

log_step() {
  local status="$1"
  local name="$2"
  local detail="$3"
  printf '%s\t%s\t%s\n' "${status}" "${name}" "${detail}" >> "${STEPS_FILE}"

  case "${status}" in
    PASS) PASS_COUNT=$((PASS_COUNT + 1)) ;;
    WARN) WARN_COUNT=$((WARN_COUNT + 1)) ;;
    FAIL) FAIL_COUNT=$((FAIL_COUNT + 1)) ;;
  esac

  # Progress mode: emit structured JSON event to stderr for TUI consumption
  if [[ "${PROGRESS:-0}" -eq 1 ]]; then
    printf '{"event":"step","status":"%s","name":"%s","detail":"%s","ts":"%s"}\n' \
      "${status}" "${name}" "${detail}" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >&2
  fi
}

# Sandboxed execution wrapper: drops network access on macOS via sandbox-exec
# Falls back to normal execution on Linux or when --sandbox not set
run_sandboxed() {
  if [[ "${SANDBOX}" -eq 1 ]] && command -v sandbox-exec >/dev/null 2>&1; then
    sandbox-exec -p '(version 1)(allow default)(deny network*)' "$@"
  else
    "$@"
  fi
}

run_step() {
  local name="$1"
  shift

  if {
    echo "[$(date -u +%H:%M:%S)] STEP ${name}"
    "$@"
  } >> "${LOG_FILE}" 2>&1; then
    log_step "PASS" "${name}" "ok"
  else
    log_step "FAIL" "${name}" "see ${LOG_FILE}"
  fi
}

run_step_soft() {
  local name="$1"
  shift

  {
    echo "[$(date -u +%H:%M:%S)] STEP ${name}"
    "$@"
  } >> "${LOG_FILE}" 2>&1 || {
    log_step "WARN" "${name}" "non-zero exit (see ${LOG_FILE})"
    return 0
  }
  log_step "PASS" "${name}" "ok"
}

# 1) Session sync
GRAPH_GUARD_SCRIPT="${SCRIPTS_DIR}/ensure_obsidian_graph_health.py"
if [[ ! -f "${GRAPH_GUARD_SCRIPT}" && -f "${REAL_AUTOMATION_ROOT}/scripts/ensure_obsidian_graph_health.py" ]]; then
  GRAPH_GUARD_SCRIPT="${REAL_AUTOMATION_ROOT}/scripts/ensure_obsidian_graph_health.py"
fi
if [[ -f "${GRAPH_GUARD_SCRIPT}" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step_soft "obsidian_graph_guard" python3 "${GRAPH_GUARD_SCRIPT}" --apply
  else
    run_step_soft "obsidian_graph_guard" python3 "${GRAPH_GUARD_SCRIPT}"
  fi
else
  log_step "WARN" "obsidian_graph_guard" "missing ensure_obsidian_graph_health.py"
fi

# 0.5) Obsidian config drift guard
if [[ -x "${ROOT}/bin/lacp-obsidian" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step_soft "obsidian_config_guard" "${ROOT}/bin/lacp-obsidian" apply --json
  else
    run_step_soft "obsidian_config_guard" "${ROOT}/bin/lacp-obsidian" audit --json
  fi
else
  log_step "WARN" "obsidian_config_guard" "missing ${ROOT}/bin/lacp-obsidian"
fi

# 0.8) Promote per-turn memory extractions from staging
STAGING_FILE="${HOME}/.lacp/memory-staging/pending.jsonl"
if [[ -f "${STAGING_FILE}" ]]; then
  STAGING_COUNT="$(wc -l < "${STAGING_FILE}" 2>/dev/null | tr -d ' ')"
  if [[ "${STAGING_COUNT}" -gt 0 ]]; then
    log_step "PASS" "staging_promote" "${STAGING_COUNT} pending signals from per-turn extraction"
    # Staging signals will be consumed by sync_research_knowledge.py in step 3
    # (it reads from inbox + registry; we move staging to inbox format)
    if [[ "${APPLY}" -eq 1 ]]; then
      run_step_soft "staging_promote" python3 -c "
import json
from pathlib import Path
from datetime import datetime, timezone

staging = Path('${STAGING_FILE}')
inbox = Path('${LACP_OBSIDIAN_VAULT:-$HOME/obsidian/vault}/inbox')
inbox.mkdir(parents=True, exist_ok=True)

promoted = 0
for line in staging.read_text().splitlines():
    if not line.strip():
        continue
    try:
        sig = json.loads(line)
    except json.JSONDecodeError:
        continue
    # Write as inbox note for sync_research_knowledge to pick up
    ts = sig.get('timestamp', datetime.now(timezone.utc).isoformat())
    day = sig.get('day', datetime.now(timezone.utc).strftime('%Y-%m-%d'))
    text = sig.get('text', '')
    if len(text) < 20:
        continue
    note_id = f'staged-{day}-{promoted:03d}'
    note_path = inbox / f'{note_id}.md'
    note_path.write_text(f'''---
type: research
source: per-turn-extraction
created: {day}
agent_id: {sig.get('session_id', 'local')[:20]}
confidence: 0.6
---

# {text[:80]}

{text}
''')
    promoted += 1

# Clear staging after promotion
staging.write_text('')
print(f'Promoted {promoted} signals from staging to inbox')
"
    fi
  else
    log_step "PASS" "staging_promote" "no pending signals"
  fi
else
  log_step "PASS" "staging_promote" "no staging file"
fi

# 1) Session sync
if [[ -x "${SCRIPTS_DIR}/run_session_sync.sh" ]]; then
  run_step "session_sync" /bin/bash "${SCRIPTS_DIR}/run_session_sync.sh"
else
  log_step "WARN" "session_sync" "missing ${SCRIPTS_DIR}/run_session_sync.sh"
fi

# 2) Materialize web research capture
if [[ -f "${SCRIPTS_DIR}/materialize_research_inbox.py" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step "materialize_research_inbox" python3 "${SCRIPTS_DIR}/materialize_research_inbox.py" --apply
  else
    run_step "materialize_research_inbox" python3 "${SCRIPTS_DIR}/materialize_research_inbox.py"
  fi
else
  log_step "WARN" "materialize_research_inbox" "missing ${SCRIPTS_DIR}/materialize_research_inbox.py"
fi

# 3) Sync research graph nodes
if [[ -f "${SCRIPTS_DIR}/sync_research_knowledge.py" ]]; then
  SYNC_ARGS=(--days "${DAYS}")
  if [[ "${APPLY}" -eq 1 ]]; then
    SYNC_ARGS+=(--apply)
  fi
  if [[ "${ACTIVATE}" -eq 1 ]]; then
    SYNC_ARGS+=(--activate)
  fi
  run_step "sync_research_knowledge" python3 "${SCRIPTS_DIR}/sync_research_knowledge.py" "${SYNC_ARGS[@]}"
else
  log_step "WARN" "sync_research_knowledge" "missing ${SCRIPTS_DIR}/sync_research_knowledge.py"
fi

# 4) Sync repo/codebase graph nodes
if [[ -f "${SCRIPTS_DIR}/sync_repo_knowledge.py" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step "sync_repo_knowledge" python3 "${SCRIPTS_DIR}/sync_repo_knowledge.py" --apply --json
  else
    run_step "sync_repo_knowledge" python3 "${SCRIPTS_DIR}/sync_repo_knowledge.py" --json
  fi
else
  log_step "WARN" "sync_repo_knowledge" "missing ${SCRIPTS_DIR}/sync_repo_knowledge.py"
fi

# 5) Mirror repo docs/research notes into graph nodes
if [[ -x "${ROOT}/bin/lacp-repo-research-sync" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step "sync_repo_research" "${ROOT}/bin/lacp-repo-research-sync" --apply --json
  else
    run_step "sync_repo_research" "${ROOT}/bin/lacp-repo-research-sync" --json
  fi
else
  log_step "WARN" "sync_repo_research" "missing ${ROOT}/bin/lacp-repo-research-sync"
fi

# 6) Extract Obsidian Agent Daily into graph notes
if [[ -f "${SCRIPTS_DIR}/sync_agent_daily_knowledge.py" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step "sync_agent_daily_knowledge" python3 "${SCRIPTS_DIR}/sync_agent_daily_knowledge.py" --days "${DAYS}" --apply --json
  else
    run_step "sync_agent_daily_knowledge" python3 "${SCRIPTS_DIR}/sync_agent_daily_knowledge.py" --days "${DAYS}" --json
  fi
else
  log_step "WARN" "sync_agent_daily_knowledge" "missing ${SCRIPTS_DIR}/sync_agent_daily_knowledge.py"
fi

# 7) Weekly consolidation gate
if [[ "${CONSOLIDATE}" -eq 1 && -f "${SCRIPTS_DIR}/memory_consolidation.py" ]]; then
  # Enhanced consolidation with prune/merge logic
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step_soft "consolidate_research" run_sandboxed python3 "${SCRIPTS_DIR}/memory_consolidation.py" --apply
  else
    run_step_soft "consolidate_research" run_sandboxed python3 "${SCRIPTS_DIR}/memory_consolidation.py" --dry-run
  fi
elif [[ -f "${SCRIPTS_DIR}/consolidate_research.py" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step_soft "consolidate_research" python3 "${SCRIPTS_DIR}/consolidate_research.py" --apply --weekly-gate --min-days-between-runs 6
  else
    run_step_soft "consolidate_research" python3 "${SCRIPTS_DIR}/consolidate_research.py" --dry-run
  fi
else
  log_step "WARN" "consolidate_research" "missing ${SCRIPTS_DIR}/consolidate_research.py"
fi

# 7.5) Gap detection
if [[ -f "${SCRIPTS_DIR}/detect_knowledge_gaps.py" ]]; then
  run_step_soft "detect_knowledge_gaps" python3 "${SCRIPTS_DIR}/detect_knowledge_gaps.py" --write-note
else
  log_step "WARN" "detect_knowledge_gaps" "missing ${SCRIPTS_DIR}/detect_knowledge_gaps.py"
fi

# 7.6) Active Recall Probes (test actual retrievability before review queue)
if [[ -f "${SCRIPTS_DIR}/active_recall_probes.py" ]]; then
  PROBE_ARGS=(--threshold 0.3 --max-items 100)
  if [[ "${APPLY}" -eq 1 ]]; then
    PROBE_ARGS+=(--apply)
  fi
  run_step_soft "active_recall_probes" python3 "${SCRIPTS_DIR}/active_recall_probes.py" "${PROBE_ARGS[@]}"
else
  log_step "WARN" "active_recall_probes" "missing ${SCRIPTS_DIR}/active_recall_probes.py"
fi

# 7.7) FSRS review queue (now informed by probe results)
if [[ -f "${SCRIPTS_DIR}/generate_review_queue.py" ]]; then
  run_step_soft "review_queue" python3 "${SCRIPTS_DIR}/generate_review_queue.py"
else
  log_step "WARN" "review_queue" "missing ${SCRIPTS_DIR}/generate_review_queue.py"
fi

# 8) Route/archive inbox
if [[ -f "${SCRIPTS_DIR}/route_inbox.py" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step_soft "route_inbox" python3 "${SCRIPTS_DIR}/route_inbox.py" --apply
  else
    run_step_soft "route_inbox" python3 "${SCRIPTS_DIR}/route_inbox.py"
  fi
else
  log_step "WARN" "route_inbox" "missing ${SCRIPTS_DIR}/route_inbox.py"
fi

if [[ -f "${SCRIPTS_DIR}/archive_inbox.py" ]]; then
  if [[ "${APPLY}" -eq 1 ]]; then
    run_step_soft "archive_inbox" python3 "${SCRIPTS_DIR}/archive_inbox.py" --days 30 --apply
  else
    run_step_soft "archive_inbox" python3 "${SCRIPTS_DIR}/archive_inbox.py" --days 30
  fi
else
  log_step "WARN" "archive_inbox" "missing ${SCRIPTS_DIR}/archive_inbox.py"
fi

# 9) Update QMD collection index
if [[ "${SKIP_QMD}" -eq 1 ]]; then
  log_step "WARN" "qmd_update" "skipped by --skip-qmd"
else
  run_step_soft "qmd_update" npx -y @tobilu/qmd update
fi

# 10) Doctors (soft by default, strict only when requested)
run_step_soft "brain_doctor" "${ROOT}/bin/lacp-brain-doctor" --json
run_step_soft "knowledge_doctor" "${ROOT}/bin/lacp-knowledge-doctor" --root "${KNOWLEDGE_DOCTOR_ROOT}" --json

# 10.5) Memory index guard — enforce MEMORY.md size caps
if [[ -f "${SCRIPTS_DIR}/memory_index_guard.py" ]]; then
  # Find all MEMORY.md files in Claude project memory dirs
  for memfile in "${HOME}/.claude/projects/"*/memory/MEMORY.md; do
    if [[ -f "${memfile}" ]]; then
      if [[ "${APPLY}" -eq 1 ]]; then
        run_step_soft "memory_index_guard" python3 "${SCRIPTS_DIR}/memory_index_guard.py" --enforce "${memfile}"
      else
        run_step_soft "memory_index_guard" python3 "${SCRIPTS_DIR}/memory_index_guard.py" --check "${memfile}"
      fi
    fi
  done
else
  log_step "WARN" "memory_index_guard" "missing ${SCRIPTS_DIR}/memory_index_guard.py"
fi

# 10.6) SMS epoch synthesis (psychology-informed memory consolidation)
if python3 -c "
import sys; sys.path.insert(0, '${ROOT}/hooks')
from self_memory_system import read_episodes, synthesize_epoch, write_epoch
episodes = read_episodes(days=${DAYS}, min_significance=0.3)
if len(episodes) >= 3:
    epoch = synthesize_epoch('Weekly synthesis (brain-expand)', days=${DAYS})
    write_epoch(epoch)
    print(f'SMS epoch synthesized: {epoch.episode_count} episodes, {len(epoch.key_decisions)} decisions')
else:
    print(f'SMS: {len(episodes)} episodes (need 3+ for synthesis)')
" >> "${LOG_FILE}" 2>&1; then
  log_step "PASS" "sms_epoch_synthesis" "SMS epoch synthesis complete"
else
  log_step "WARN" "sms_epoch_synthesis" "SMS epoch synthesis skipped or failed"
fi

if [[ "${AS_JSON}" -eq 1 ]]; then
  python3 - <<'PY' "${STEPS_FILE}" "${LOG_FILE}" "${RUN_TS}" "${PASS_COUNT}" "${WARN_COUNT}" "${FAIL_COUNT}" "${DAYS}" "${APPLY}" "${STRICT}" "${ACTIVATE}" "${CONSOLIDATE}"
import json
import sys
from pathlib import Path

steps_file = Path(sys.argv[1])
log_file = sys.argv[2]
run_ts = sys.argv[3]
pass_count = int(sys.argv[4])
warn_count = int(sys.argv[5])
fail_count = int(sys.argv[6])
days = int(sys.argv[7])
apply = sys.argv[8] == "1"
strict = sys.argv[9] == "1"
activate = sys.argv[10] == "1" if len(sys.argv) > 10 else False
consolidate = sys.argv[11] == "1" if len(sys.argv) > 11 else False

steps = []
for line in steps_file.read_text().splitlines():
    if not line.strip():
        continue
    status, name, detail = line.split("\t", 2)
    steps.append({"status": status, "name": name, "detail": detail})

payload = {
    "schema_version": "1",
    "kind": "brain_expand",
    "run_ts_utc": run_ts,
    "ok": fail_count == 0,
    "strict": strict,
    "apply": apply,
    "activate": activate,
    "consolidate": consolidate,
    "days": days,
    "summary": {"pass": pass_count, "warn": warn_count, "fail": fail_count},
    "log_file": log_file,
    "steps": steps,
}
print(json.dumps(payload, indent=2))
PY
else
  log "brain-expand summary: pass=${PASS_COUNT} warn=${WARN_COUNT} fail=${FAIL_COUNT} log=${LOG_FILE}"
  while IFS=$'\t' read -r status name detail; do
    printf '%-5s %-28s %s\n' "${status}" "${name}" "${detail}"
  done < "${STEPS_FILE}"
fi

if [[ "${STRICT}" -eq 1 && "${FAIL_COUNT}" -gt 0 ]]; then
  exit 1
fi

exit 0
