#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-onboard [--with-verify] [--hours N] [--no-auto-deps] [--auto-deps-dry-run] [--auto-deps-force] [--no-auto-adopt] [--no-auto-hook-optimize] [--with-ollama]

Initial setup helper:
- creates .env from config/lacp.env.example when missing
- auto-detects and installs missing core dependencies on macOS/Homebrew by default
- runs bootstrap checks
- adopts local claude/codex/hermes wrappers when binaries are present (default-on)
- repairs/applies Claude hook profile when local Claude config exists (default-on)
- optionally installs Ollama + recommended models for quality gate
- optionally runs a full verify cycle
EOF
}

WITH_VERIFY=0
HOURS="${LACP_VERIFY_HOURS}"
AUTO_DEPS=1
AUTO_DEPS_DRY_RUN=0
AUTO_DEPS_FORCE=0
case "${LACP_AUTO_ADOPT_LOCAL:-true}" in
  false|0|no) AUTO_ADOPT=0 ;;
  *) AUTO_ADOPT=1 ;;
esac
case "${LACP_AUTO_HOOK_OPTIMIZE:-true}" in
  false|0|no) AUTO_HOOK_OPTIMIZE=0 ;;
  *) AUTO_HOOK_OPTIMIZE=1 ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --with-verify)
      WITH_VERIFY=1
      shift
      ;;
    --hours)
      HOURS="$2"
      shift 2
      ;;
    --no-auto-deps)
      AUTO_DEPS=0
      shift
      ;;
    --auto-deps-dry-run)
      AUTO_DEPS=1
      AUTO_DEPS_DRY_RUN=1
      shift
      ;;
    --auto-deps-force)
      AUTO_DEPS_FORCE=1
      shift
      ;;
    --no-auto-adopt)
      AUTO_ADOPT=0
      shift
      ;;
    --no-auto-hook-optimize)
      AUTO_HOOK_OPTIMIZE=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

if [[ "${AUTO_DEPS}" -eq 1 ]]; then
  lacp_auto_install_deps "$([[ "${AUTO_DEPS_DRY_RUN}" -eq 1 ]] && echo true || echo false)" "$([[ "${AUTO_DEPS_FORCE}" -eq 1 ]] && echo true || echo false)"
fi

if [[ ! -f "${ROOT}/.env" ]]; then
  if [[ "${LACP_SKIP_DOTENV:-0}" == "1" ]]; then
    log "Skipped .env creation because LACP_SKIP_DOTENV=1"
  else
    cp "${ROOT}/config/lacp.env.example" "${ROOT}/.env"
    log "Created ${ROOT}/.env from template"
  fi
else
  log "Using existing ${ROOT}/.env"
fi

log "Running bootstrap checks"
"${ROOT}/bin/lacp-bootstrap"

if [[ "${AUTO_ADOPT}" -eq 1 ]]; then
  if "${ROOT}/bin/lacp-adopt-local" --json >/dev/null 2>&1; then
    log "Auto-adopted available local claude/codex/hermes wrappers"
  else
    log "Auto-adopt skipped: wrapper install failed (run bin/lacp-adopt-local manually)"
  fi
fi

if [[ "${AUTO_HOOK_OPTIMIZE}" -eq 1 ]]; then
  if command -v claude >/dev/null 2>&1 && [[ -d "${HOME}/.claude" ]]; then
    if "${ROOT}/bin/lacp-claude-hooks" optimize --profile minimal-stop >/dev/null 2>&1; then
      log "Auto-optimized Claude hooks/profile (minimal-stop)"
    else
      log "Auto-hook optimize skipped: run bin/lacp claude-hooks optimize --profile minimal-stop manually"
    fi
  else
    log "Auto-hook optimize skipped: local Claude config not found"
  fi
fi

if [[ "${WITH_VERIFY}" -eq 1 ]]; then
  log "Running verify cycle"
  "${ROOT}/bin/lacp-verify" --hours "${HOURS}"
else
  log "Skipped full verify. Run: bin/lacp-verify --hours ${HOURS}"
fi

log "Onboarding complete"
