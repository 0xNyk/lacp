#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-doctor [--json] [--fix] [--fix-deps] [--auto-deps-dry-run] [--auto-deps-force]

Runs path and health diagnostics for LACP dependencies and recent artifacts.
Exits non-zero if required checks fail.
EOF
}

AS_JSON=0
FIX=0
FIX_DEPS=0
AUTO_DEPS_DRY_RUN=0
AUTO_DEPS_FORCE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      AS_JSON=1
      shift
      ;;
    --fix)
      FIX=1
      shift
      ;;
    --fix-deps)
      FIX_DEPS=1
      shift
      ;;
    --auto-deps-dry-run)
      FIX_DEPS=1
      AUTO_DEPS_DRY_RUN=1
      shift
      ;;
    --auto-deps-force)
      AUTO_DEPS_FORCE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

if [[ "${FIX_DEPS}" -eq 1 ]]; then
  lacp_auto_install_deps "$([[ "${AUTO_DEPS_DRY_RUN}" -eq 1 ]] && echo true || echo false)" "$([[ "${AUTO_DEPS_FORCE}" -eq 1 ]] && echo true || echo false)"
fi

if [[ "${FIX}" -eq 1 ]]; then
  mkdir -p "${LACP_AUTOMATION_ROOT}" "${LACP_KNOWLEDGE_ROOT}" "${LACP_DRAFTS_ROOT}"
  mkdir -p "${LACP_AUTOMATION_ROOT}/data/snapshots"
  mkdir -p "${LACP_KNOWLEDGE_ROOT}/data/benchmarks"
  mkdir -p "${LACP_KNOWLEDGE_ROOT}/data/approvals"

  if [[ "${LACP_SKIP_DOTENV:-0}" != "1" && ! -f "${LACP_ROOT}/.env" && -f "${LACP_ROOT}/config/lacp.env.example" ]]; then
    cp "${LACP_ROOT}/config/lacp.env.example" "${LACP_ROOT}/.env"
  fi
fi

checks_tmp="$(mktemp)"
trap 'rm -f "${checks_tmp}"' EXIT

add_check() {
  local name="$1"
  local status="$2"
  local detail="$3"
  printf '%s\t%s\t%s\n' "${status}" "${name}" "${detail}" >> "${checks_tmp}"
}

check_cmd() {
  local cmd="$1"
  if command -v "${cmd}" >/dev/null 2>&1; then
    add_check "cmd:${cmd}" "PASS" "$(command -v "${cmd}")"
  else
    add_check "cmd:${cmd}" "FAIL" "missing"
  fi
}

check_file() {
  local path="$1"
  local label="$2"
  if [[ -f "${path}" ]]; then
    add_check "${label}" "PASS" "${path}"
  else
    add_check "${label}" "FAIL" "${path}"
  fi
}

check_dir() {
  local path="$1"
  local label="$2"
  if [[ -d "${path}" ]]; then
    add_check "${label}" "PASS" "${path}"
  else
    add_check "${label}" "FAIL" "${path}"
  fi
}

check_canonical_dir() {
  local path="$1"
  local label="$2"
  if [[ -d "${path}" ]]; then
    local canonical
    canonical="$(cd "${path}" && pwd -P)"
    add_check "${label}" "PASS" "${path} -> ${canonical}"
  else
    add_check "${label}" "FAIL" "${path}"
  fi
}

check_latest_file_age_hours() {
  local glob_path="$1"
  local label="$2"
  local max_hours="$3"
  local latest_file latest_epoch now_epoch age_hours
  latest_file="$(latest_file "${glob_path}" || true)"
  if [[ -z "${latest_file}" ]]; then
    add_check "${label}" "WARN" "missing"
    return 0
  fi
  latest_epoch="$(stat -f %m "${latest_file}" 2>/dev/null || echo 0)"
  now_epoch="$(date -u +%s)"
  if [[ "${latest_epoch}" -le 0 ]]; then
    add_check "${label}" "WARN" "${latest_file} (unable to read mtime)"
    return 0
  fi
  age_hours="$(((now_epoch - latest_epoch) / 3600))"
  if [[ "${age_hours}" -le "${max_hours}" ]]; then
    add_check "${label}" "PASS" "${latest_file} age_hours=${age_hours}"
  else
    add_check "${label}" "WARN" "${latest_file} age_hours=${age_hours} (>${max_hours})"
  fi
}

check_cmd bash
check_cmd python3
check_cmd rg
check_cmd jq
check_cmd curl
check_cmd git

check_canonical_dir "${LACP_AUTOMATION_ROOT}" "root:automation"
check_canonical_dir "${LACP_KNOWLEDGE_ROOT}" "root:knowledge"
check_canonical_dir "${LACP_DRAFTS_ROOT}" "root:drafts"

if [[ -f "${LACP_ROOT}/.env" ]]; then
  add_check "config:env_file" "PASS" "${LACP_ROOT}/.env"
else
  add_check "config:env_file" "WARN" "missing (copy from config/lacp.env.example)"
fi

if [[ -n "${LACP_DRAFTS_ROOT}" ]]; then
  LEGACY_DRAFTS_ROOT="${HOME}/docs/ai-dev-optimization/articles"
  if [[ -d "${LEGACY_DRAFTS_ROOT}" ]]; then
    canonical_latest="$(python3 - <<'PY' "${LACP_DRAFTS_ROOT}"
import pathlib
import sys

root = pathlib.Path(sys.argv[1])
files = [p for p in root.rglob("*.md") if p.is_file()]
if files:
    newest = max(files, key=lambda p: p.stat().st_mtime)
    print(str(newest))
PY
)"
    legacy_latest="$(python3 - <<'PY' "${LEGACY_DRAFTS_ROOT}"
import pathlib
import sys

root = pathlib.Path(sys.argv[1])
files = [p for p in root.rglob("*.md") if p.is_file()]
if files:
    newest = max(files, key=lambda p: p.stat().st_mtime)
    print(str(newest))
PY
)"
    if [[ -n "${canonical_latest}" && -n "${legacy_latest}" ]]; then
      canonical_epoch="$(stat -f %m "${canonical_latest}" 2>/dev/null || echo 0)"
      legacy_epoch="$(stat -f %m "${legacy_latest}" 2>/dev/null || echo 0)"
      if [[ "${legacy_epoch}" -gt "${canonical_epoch}" ]]; then
        add_check "drift:drafts_root" "WARN" "legacy path newer than canonical; review sync source (${LEGACY_DRAFTS_ROOT})"
      else
        add_check "drift:drafts_root" "PASS" "canonical path is freshest"
      fi
    else
      add_check "drift:drafts_root" "PASS" "no conflicting legacy drafts detected"
    fi
  else
    add_check "drift:drafts_root" "PASS" "legacy drafts path absent"
  fi
fi

check_file "$(automation_script run_shared_memory.sh)" "script:run_shared_memory.sh"
check_file "$(automation_script run_memory_pipeline.sh)" "script:run_memory_pipeline.sh"
check_file "$(automation_script run_memory_benchmark_suite.sh)" "script:run_memory_benchmark_suite.sh"
check_file "$(automation_script capture_snapshot.py)" "script:capture_snapshot.py"
check_file "${LACP_SANDBOX_POLICY_FILE}" "config:sandbox_policy"
check_file "${LACP_MCP_AUTH_POLICY_FILE}" "config:mcp_auth_policy"
check_file "${LACP_ROOT}/config/harness/tasks.schema.json" "config:harness_tasks_schema"
check_file "${LACP_ROOT}/config/harness/sandbox-profiles.yaml" "config:harness_sandbox_profiles"
check_file "${LACP_ROOT}/config/harness/verification-policy.yaml" "config:harness_verification_policy"
check_file "${LACP_ROOT}/config/harness/browser-evidence.schema.json" "config:harness_browser_evidence_schema"
check_file "${LACP_ROOT}/config/risk-policy-contract.json" "config:risk_policy_contract"
check_file "${LACP_ROOT}/config/risk-policy-contract.schema.json" "config:risk_policy_contract_schema"
check_file "${LACP_ROOT}/config/context-profiles.json" "config:context_profiles"

if [[ -f "${LACP_SANDBOX_POLICY_FILE}" ]] && jq empty "${LACP_SANDBOX_POLICY_FILE}" >/dev/null 2>&1; then
  add_check "config:sandbox_policy_json" "PASS" "valid json"
elif [[ -f "${LACP_SANDBOX_POLICY_FILE}" ]]; then
  add_check "config:sandbox_policy_json" "FAIL" "invalid json"
fi

if [[ -f "${LACP_ROOT}/config/risk-policy-contract.json" ]] && jq empty "${LACP_ROOT}/config/risk-policy-contract.json" >/dev/null 2>&1; then
  add_check "config:risk_policy_contract_json" "PASS" "valid json"
elif [[ -f "${LACP_ROOT}/config/risk-policy-contract.json" ]]; then
  add_check "config:risk_policy_contract_json" "FAIL" "invalid json"
fi

if [[ -f "${LACP_ROOT}/config/risk-policy-contract.schema.json" ]] && jq empty "${LACP_ROOT}/config/risk-policy-contract.schema.json" >/dev/null 2>&1; then
  add_check "config:risk_policy_contract_schema_json" "PASS" "valid json"
elif [[ -f "${LACP_ROOT}/config/risk-policy-contract.schema.json" ]]; then
  add_check "config:risk_policy_contract_schema_json" "FAIL" "invalid json"
fi

if [[ -f "${LACP_ROOT}/config/context-profiles.json" ]] && jq empty "${LACP_ROOT}/config/context-profiles.json" >/dev/null 2>&1; then
  add_check "config:context_profiles_json" "PASS" "valid json"
elif [[ -f "${LACP_ROOT}/config/context-profiles.json" ]]; then
  add_check "config:context_profiles_json" "FAIL" "invalid json"
fi

if [[ -f "${LACP_ROOT}/config/harness/browser-evidence.schema.json" ]] && jq empty "${LACP_ROOT}/config/harness/browser-evidence.schema.json" >/dev/null 2>&1; then
  add_check "config:harness_browser_evidence_schema_json" "PASS" "valid json"
elif [[ -f "${LACP_ROOT}/config/harness/browser-evidence.schema.json" ]]; then
  add_check "config:harness_browser_evidence_schema_json" "FAIL" "invalid json"
fi

if [[ -f "${LACP_MCP_AUTH_POLICY_FILE}" ]] && jq empty "${LACP_MCP_AUTH_POLICY_FILE}" >/dev/null 2>&1; then
  add_check "config:mcp_auth_policy_json" "PASS" "valid json"
else
  add_check "config:mcp_auth_policy_json" "FAIL" "invalid or missing json"
fi

if [[ -f "${LACP_MCP_AUTH_POLICY_FILE}" ]] && jq -e '.auth.require_pkce == true' "${LACP_MCP_AUTH_POLICY_FILE}" >/dev/null 2>&1; then
  add_check "policy:mcp_pkce" "PASS" "require_pkce=true"
else
  add_check "policy:mcp_pkce" "FAIL" "require_pkce must be true"
fi

if [[ -f "${LACP_MCP_AUTH_POLICY_FILE}" ]]; then
  mcp_token_ttl="$(jq -r '.auth.token_ttl_max_minutes // 0' "${LACP_MCP_AUTH_POLICY_FILE}" 2>/dev/null || echo 0)"
  if [[ "${mcp_token_ttl}" =~ ^[0-9]+$ ]] && [[ "${mcp_token_ttl}" -gt 0 ]] && [[ "${mcp_token_ttl}" -le 60 ]]; then
    add_check "policy:mcp_token_ttl" "PASS" "token_ttl_max_minutes=${mcp_token_ttl}"
  else
    add_check "policy:mcp_token_ttl" "FAIL" "token_ttl_max_minutes must be 1..60 (got ${mcp_token_ttl})"
  fi

  mcp_refresh_ttl_days="$(jq -r '.auth.refresh_token_ttl_max_days // 0' "${LACP_MCP_AUTH_POLICY_FILE}" 2>/dev/null || echo 0)"
  if [[ "${mcp_refresh_ttl_days}" =~ ^[0-9]+$ ]] && [[ "${mcp_refresh_ttl_days}" -gt 0 ]] && [[ "${mcp_refresh_ttl_days}" -le 30 ]]; then
    add_check "policy:mcp_refresh_ttl" "PASS" "refresh_token_ttl_max_days=${mcp_refresh_ttl_days}"
  else
    add_check "policy:mcp_refresh_ttl" "FAIL" "refresh_token_ttl_max_days must be 1..30 (got ${mcp_refresh_ttl_days})"
  fi

  mcp_rotation_days="$(jq -r '.auth.rotation_interval_days // 0' "${LACP_MCP_AUTH_POLICY_FILE}" 2>/dev/null || echo 0)"
  if [[ "${mcp_rotation_days}" =~ ^[0-9]+$ ]] && [[ "${mcp_rotation_days}" -gt 0 ]] && [[ "${mcp_rotation_days}" -le 30 ]]; then
    add_check "policy:mcp_rotation" "PASS" "rotation_interval_days=${mcp_rotation_days}"
  else
    add_check "policy:mcp_rotation" "FAIL" "rotation_interval_days must be 1..30 (got ${mcp_rotation_days})"
  fi

  if jq -e '.auth.allow_implicit_flow == false' "${LACP_MCP_AUTH_POLICY_FILE}" >/dev/null 2>&1; then
    add_check "policy:mcp_implicit_flow" "PASS" "allow_implicit_flow=false"
  else
    add_check "policy:mcp_implicit_flow" "FAIL" "allow_implicit_flow must be false"
  fi
fi

if [[ -f "${LACP_ROOT}/.env" ]]; then
  mcp_token_lines="$(rg -n '^[A-Za-z0-9_]*MCP[A-Za-z0-9_]*TOKEN[A-Za-z0-9_]*=' "${LACP_ROOT}/.env" || true)"
  allow_static_tokens="$(jq -r '.auth.allow_static_tokens_in_env // false' "${LACP_MCP_AUTH_POLICY_FILE}" 2>/dev/null || echo false)"
  if [[ -n "${mcp_token_lines}" ]]; then
    if [[ "${allow_static_tokens}" == "true" ]]; then
      add_check "policy:mcp_static_tokens_env" "WARN" "MCP token variables found in .env and policy allows it"
    else
      add_check "policy:mcp_static_tokens_env" "FAIL" "MCP token variables found in .env; move to keychain/secret manager"
    fi
  else
    add_check "policy:mcp_static_tokens_env" "PASS" "no MCP token vars in .env"
  fi
fi

if [[ -f "${LACP_SANDBOX_POLICY_FILE}" ]] && jq -e '.routing.risk_tiers' "${LACP_SANDBOX_POLICY_FILE}" >/dev/null 2>&1; then
  invalid_tiers="$(jq -r '.routing.risk_tiers | to_entries[] | select(.value != "safe" and .value != "review" and .value != "critical") | "\(.key)=\(.value)"' "${LACP_SANDBOX_POLICY_FILE}" | tr '\n' ',' | sed 's/,$//')"
  if [[ -z "${invalid_tiers}" ]]; then
    add_check "config:risk_tiers" "PASS" "safe/review/critical"
  else
    add_check "config:risk_tiers" "FAIL" "invalid tiers: ${invalid_tiers}"
  fi
else
  add_check "config:risk_tiers" "WARN" "missing routing.risk_tiers (defaults will be used)"
fi

if [[ -f "${LACP_SANDBOX_POLICY_FILE}" ]] && jq -e '.routing.cost_ceiling_usd_by_risk_tier' "${LACP_SANDBOX_POLICY_FILE}" >/dev/null 2>&1; then
  invalid_costs="$(jq -r '.routing.cost_ceiling_usd_by_risk_tier | to_entries[] | select((.value|type) != "number" or .value < 0) | "\(.key)=\(.value)"' "${LACP_SANDBOX_POLICY_FILE}" | tr '\n' ',' | sed 's/,$//')"
  if [[ -z "${invalid_costs}" ]]; then
    add_check "config:cost_ceilings" "PASS" "numeric non-negative per tier"
  else
    add_check "config:cost_ceilings" "FAIL" "invalid values: ${invalid_costs}"
  fi
else
  add_check "config:cost_ceilings" "WARN" "missing routing.cost_ceiling_usd_by_risk_tier (defaults to 0)"
fi

REMOTE_PROVIDER="$(jq -r '.routing.remote_provider // "daytona"' "${LACP_SANDBOX_POLICY_FILE}" 2>/dev/null || echo "daytona")"
add_check "config:remote_provider" "PASS" "${REMOTE_PROVIDER}"

DAYTONA_RUNNER="${LACP_ROOT}/scripts/runners/daytona-runner.sh"
E2B_RUNNER="${LACP_ROOT}/scripts/runners/e2b-runner.sh"
TMUX_RUNNER="${LACP_ROOT}/scripts/runners/tmux-runner.sh"
DMUX_RUNNER="${LACP_ROOT}/scripts/runners/dmux-runner.sh"
CLAUDE_WORKTREE_RUNNER="${LACP_ROOT}/scripts/runners/claude-worktree-runner.sh"
check_file "${DAYTONA_RUNNER}" "runner_file:daytona"
check_file "${E2B_RUNNER}" "runner_file:e2b"
check_file "${TMUX_RUNNER}" "runner_file:tmux"
check_file "${DMUX_RUNNER}" "runner_file:dmux"
check_file "${CLAUDE_WORKTREE_RUNNER}" "runner_file:claude_worktree"
check_file "${LACP_ROOT}/bin/lacp-remote-setup" "bin:lacp-remote-setup"
check_file "${LACP_ROOT}/bin/lacp-remote-smoke" "bin:lacp-remote-smoke"
check_file "${LACP_ROOT}/bin/lacp-orchestrate" "bin:lacp-orchestrate"
check_file "${LACP_ROOT}/bin/lacp-worktree" "bin:lacp-worktree"
check_file "${LACP_ROOT}/bin/lacp-swarm" "bin:lacp-swarm"
check_file "${LACP_ROOT}/bin/lacp-harness-validate" "bin:lacp-harness-validate"
check_file "${LACP_ROOT}/bin/lacp-harness-run" "bin:lacp-harness-run"
check_file "${LACP_ROOT}/bin/lacp-pr-preflight" "bin:lacp-pr-preflight"
check_file "${LACP_ROOT}/bin/lacp-browser-evidence-validate" "bin:lacp-browser-evidence-validate"
check_file "${LACP_ROOT}/bin/lacp-mode" "bin:lacp-mode"
check_file "${LACP_ROOT}/bin/lacp-knowledge-doctor" "bin:lacp-knowledge-doctor"
check_file "${LACP_ROOT}/bin/lacp-status-report" "bin:lacp-status-report"
add_check "policy:allow_external_remote" "PASS" "${LACP_ALLOW_EXTERNAL_REMOTE}"

if [[ "${LACP_ALLOW_EXTERNAL_REMOTE}" == "true" ]]; then
  if [[ -f "${LACP_REMOTE_APPROVAL_FILE}" ]] && jq -e . "${LACP_REMOTE_APPROVAL_FILE}" >/dev/null 2>&1; then
    expires_at_utc="$(jq -r '.expires_at_utc // ""' "${LACP_REMOTE_APPROVAL_FILE}")"
    if [[ -n "${expires_at_utc}" ]]; then
      if python3 - <<'PY' "${expires_at_utc}"
import datetime as dt
import sys

try:
    expires = dt.datetime.strptime(sys.argv[1], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=dt.timezone.utc)
except Exception:
    raise SystemExit(1)
now = dt.datetime.now(dt.timezone.utc)
raise SystemExit(0 if expires > now else 1)
PY
      then
        add_check "policy:remote_approval" "PASS" "${LACP_REMOTE_APPROVAL_FILE} expires_at_utc=${expires_at_utc}"
      else
        add_check "policy:remote_approval" "FAIL" "${LACP_REMOTE_APPROVAL_FILE} expired_at_utc=${expires_at_utc}; renew via bin/lacp-mode remote-enabled --ttl-min ${LACP_REMOTE_APPROVAL_TTL_MIN}"
      fi
    else
      add_check "policy:remote_approval" "FAIL" "${LACP_REMOTE_APPROVAL_FILE} missing expires_at_utc"
    fi
  else
    add_check "policy:remote_approval" "FAIL" "missing/invalid ${LACP_REMOTE_APPROVAL_FILE}; grant via bin/lacp-mode remote-enabled --ttl-min ${LACP_REMOTE_APPROVAL_TTL_MIN}"
  fi
else
  add_check "policy:remote_approval" "PASS" "not required in local-only mode"
fi

if [[ -n "${LACP_LOCAL_SANDBOX_RUNNER:-}" ]]; then
  if command -v "${LACP_LOCAL_SANDBOX_RUNNER}" >/dev/null 2>&1; then
    add_check "runner:local_sandbox" "PASS" "${LACP_LOCAL_SANDBOX_RUNNER}"
  else
    add_check "runner:local_sandbox" "WARN" "configured but not found: ${LACP_LOCAL_SANDBOX_RUNNER}"
  fi
else
  add_check "runner:local_sandbox" "WARN" "unset (local_sandbox uses direct fallback)"
fi

if [[ -n "${LACP_REMOTE_SANDBOX_RUNNER:-}" ]]; then
  if command -v "${LACP_REMOTE_SANDBOX_RUNNER}" >/dev/null 2>&1; then
    add_check "runner:remote_sandbox" "PASS" "${LACP_REMOTE_SANDBOX_RUNNER}"
  else
    add_check "runner:remote_sandbox" "WARN" "configured but not found: ${LACP_REMOTE_SANDBOX_RUNNER}"
  fi
else
  add_check "runner:remote_sandbox" "WARN" "unset (uses provider default: ${REMOTE_PROVIDER})"
fi

if command -v daytona >/dev/null 2>&1; then
  add_check "cli:daytona" "PASS" "$(command -v daytona)"
else
  add_check "cli:daytona" "WARN" "missing"
fi

if command -v tmux >/dev/null 2>&1; then
  add_check "cli:tmux" "PASS" "$(command -v tmux)"
else
  add_check "cli:tmux" "WARN" "missing (optional unless using tmux orchestration)"
fi

if command -v claude >/dev/null 2>&1; then
  add_check "cli:claude" "PASS" "$(command -v claude)"
else
  add_check "cli:claude" "WARN" "missing (optional unless using claude_worktree orchestration)"
fi

if command -v dmux >/dev/null 2>&1; then
  add_check "cli:dmux" "PASS" "$(command -v dmux)"
else
  add_check "cli:dmux" "WARN" "missing (optional unless using dmux orchestration)"
fi

if command -v e2b >/dev/null 2>&1; then
  add_check "cli:e2b" "PASS" "$(command -v e2b)"
else
  add_check "cli:e2b" "WARN" "missing (optional unless using E2B_SANDBOX_ID mode)"
fi

if command -v node >/dev/null 2>&1 || command -v npx >/dev/null 2>&1; then
  add_check "runtime:e2b_lifecycle" "PASS" "node/npx available"
else
  add_check "runtime:e2b_lifecycle" "WARN" "node/npx missing for E2B lifecycle mode"
fi

if curl -fsS http://127.0.0.1:11434/api/version >/dev/null 2>&1; then
  add_check "health:ollama" "PASS" "http://127.0.0.1:11434/api/version"
else
  add_check "health:ollama" "WARN" "unreachable"
fi

latest_bench="$(latest_file "${LACP_KNOWLEDGE_ROOT}/data/benchmarks/benchmark-*.json" || true)"
if [[ -n "${latest_bench}" ]]; then
  gate_ok="$(jq -r '.gate_ok // false' "${latest_bench}" 2>/dev/null || echo "false")"
  if [[ "${gate_ok}" == "true" ]]; then
    add_check "artifact:latest_benchmark" "PASS" "${latest_bench}"
  else
    add_check "artifact:latest_benchmark" "WARN" "${latest_bench} gate_ok=${gate_ok}"
  fi
else
  add_check "artifact:latest_benchmark" "WARN" "missing"
fi

latest_snapshot="$(latest_file "${LACP_AUTOMATION_ROOT}/data/snapshots/snapshot-*.json" || true)"
if [[ -n "${latest_snapshot}" ]]; then
  add_check "artifact:latest_snapshot" "PASS" "${latest_snapshot}"
else
  add_check "artifact:latest_snapshot" "WARN" "missing"
fi

check_latest_file_age_hours "${LACP_KNOWLEDGE_ROOT}/data/sandbox-runs/run-*.json" "artifact:latest_sandbox_run_age" 72
check_latest_file_age_hours "${LACP_KNOWLEDGE_ROOT}/data/remote-smoke/remote-smoke-*.json" "artifact:latest_remote_smoke_age" 168

claude_wrapper_state="$(lacp_wrapper_managed_state claude)"
codex_wrapper_state="$(lacp_wrapper_managed_state codex)"
case "${claude_wrapper_state}" in
  managed) add_check "wrapper:claude_managed" "PASS" "${LACP_WRAPPER_BIN_DIR}/claude" ;;
  missing) add_check "wrapper:claude_managed" "WARN" "${LACP_WRAPPER_BIN_DIR}/claude missing (run bin/lacp-adopt-local)" ;;
  *) add_check "wrapper:claude_managed" "WARN" "${LACP_WRAPPER_BIN_DIR}/claude unmanaged (run bin/lacp-adopt-local --force)" ;;
esac
case "${codex_wrapper_state}" in
  managed) add_check "wrapper:codex_managed" "PASS" "${LACP_WRAPPER_BIN_DIR}/codex" ;;
  missing) add_check "wrapper:codex_managed" "WARN" "${LACP_WRAPPER_BIN_DIR}/codex missing (run bin/lacp-adopt-local)" ;;
  *) add_check "wrapper:codex_managed" "WARN" "${LACP_WRAPPER_BIN_DIR}/codex unmanaged (run bin/lacp-adopt-local --force)" ;;
esac

fail_count="$(awk -F'\t' '$1=="FAIL"{c++} END{print c+0}' "${checks_tmp}")"
warn_count="$(awk -F'\t' '$1=="WARN"{c++} END{print c+0}' "${checks_tmp}")"
pass_count="$(awk -F'\t' '$1=="PASS"{c++} END{print c+0}' "${checks_tmp}")"

if [[ "${AS_JSON}" -eq 1 ]]; then
  python3 - <<'PY' "${checks_tmp}" "${fail_count}" "${warn_count}" "${pass_count}"
import json
import sys
from pathlib import Path

checks_path = Path(sys.argv[1])
fail_count = int(sys.argv[2])
warn_count = int(sys.argv[3])
pass_count = int(sys.argv[4])

checks = []
for line in checks_path.read_text().splitlines():
    status, name, detail = line.split("\t", 2)
    checks.append({"status": status, "name": name, "detail": detail})

payload = {
    "ok": fail_count == 0,
    "summary": {
        "pass": pass_count,
        "warn": warn_count,
        "fail": fail_count,
    },
    "checks": checks,
}
print(json.dumps(payload, indent=2))
PY
else
  log "Doctor summary: pass=${pass_count} warn=${warn_count} fail=${fail_count}"
  while IFS=$'\t' read -r status name detail; do
    printf '%-5s %-34s %s\n' "${status}" "${name}" "${detail}"
  done < "${checks_tmp}"
fi

if [[ "${fail_count}" -gt 0 ]]; then
  exit 1
fi
