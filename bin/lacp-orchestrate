#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage:
  lacp-orchestrate doctor [--json]
  lacp-orchestrate run --task <text> --backend tmux|dmux|claude_worktree --session <name> --command <cmd> [options]
  lacp-orchestrate run --batch <jobs.json> [options]

Options (run):
  --repo-trust trusted|unknown    Default: unknown
  --internet true|false           Default: false
  --external-code true|false      Default: false
  --cpu-heavy true|false          Default: false
  --long-run true|false           Default: false
  --estimated-cost-usd <n>        Optional budget estimate
  --confirm-budget true           Optional budget override
  --confirm-critical true         Required for critical-risk tasks
  --input-contract <json>         Structured contract for risky runs
  --dry-run                       Plan-only execution
  --claude-tmux true|false        Enable Claude native --tmux when backend=claude_worktree
  --batch <path>                  Run multiple orchestration jobs from JSON manifest
  --continue-on-error true|false  Continue batch after a failed job (default false)
  --json                          Output structured JSON
EOF
}

bool_arg() {
  case "$1" in
    true|false) printf '%s' "$1" ;;
    *) die "Expected true|false, got: $1" ;;
  esac
}

cmd_doctor() {
  local as_json="$1"
  local tmux_path dmux_path claude_path git_path default_backend

  tmux_path="$(command -v tmux || true)"
  dmux_path="$(command -v dmux || true)"
  claude_path="$(command -v claude || true)"
  git_path="$(command -v git || true)"
  default_backend="${LACP_ORCHESTRATOR_BACKEND:-dmux}"

  if [[ "${as_json}" == "true" ]]; then
    jq -n \
      --arg default_backend "${default_backend}" \
      --arg tmux_path "${tmux_path}" \
      --arg dmux_path "${dmux_path}" \
      --arg claude_path "${claude_path}" \
      --arg git_path "${git_path}" \
      '{
        ok: true,
        default_backend: $default_backend,
        backends: {
          tmux: {
            available: ($tmux_path != ""),
            command: (if $tmux_path == "" then null else $tmux_path end)
          },
          dmux: {
            available: ($dmux_path != ""),
            command: (if $dmux_path == "" then null else $dmux_path end)
          },
          claude_worktree: {
            available: ($claude_path != "" and $git_path != ""),
            command: (if $claude_path == "" then null else $claude_path end),
            git: (if $git_path == "" then null else $git_path end)
          }
        }
      }'
    return 0
  fi

  log "default_backend=${default_backend}"
  if [[ -n "${tmux_path}" ]]; then
    log "tmux=available (${tmux_path})"
  else
    log "tmux=missing"
  fi
  if [[ -n "${dmux_path}" ]]; then
    log "dmux=available (${dmux_path})"
  else
    log "dmux=missing"
  fi
  if [[ -n "${claude_path}" && -n "${git_path}" ]]; then
    log "claude_worktree=available (claude=${claude_path}, git=${git_path})"
  else
    log "claude_worktree=missing (claude=${claude_path:-none}, git=${git_path:-none})"
  fi
}

cmd_run() {
  local task="" backend="${LACP_ORCHESTRATOR_BACKEND:-dmux}" session="" command_text=""
  local repo_trust="unknown" internet="false" external_code="false" cpu_heavy="false" long_run="false"
  local estimated_cost_usd="" confirm_budget="false" confirm_critical="false" input_contract=""
  local claude_tmux="false"
  local batch_file="" continue_on_error="false"
  local dry_run="false" as_json="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --task) task="$2"; shift 2 ;;
      --backend) backend="$2"; shift 2 ;;
      --session) session="$2"; shift 2 ;;
      --command) command_text="$2"; shift 2 ;;
      --repo-trust) repo_trust="$2"; shift 2 ;;
      --internet) internet="$(bool_arg "$2")"; shift 2 ;;
      --external-code) external_code="$(bool_arg "$2")"; shift 2 ;;
      --cpu-heavy) cpu_heavy="$(bool_arg "$2")"; shift 2 ;;
      --long-run) long_run="$(bool_arg "$2")"; shift 2 ;;
      --estimated-cost-usd) estimated_cost_usd="$2"; shift 2 ;;
      --confirm-budget) confirm_budget="$(bool_arg "$2")"; shift 2 ;;
      --confirm-critical) confirm_critical="$(bool_arg "$2")"; shift 2 ;;
      --input-contract) input_contract="$2"; shift 2 ;;
      --claude-tmux) claude_tmux="$(bool_arg "$2")"; shift 2 ;;
      --batch) batch_file="$2"; shift 2 ;;
      --continue-on-error) continue_on_error="$(bool_arg "$2")"; shift 2 ;;
      --dry-run) dry_run="true"; shift ;;
      --json) as_json="true"; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "Unknown argument: $1" ;;
    esac
  done

  if [[ -n "${batch_file}" ]]; then
    require_file "${batch_file}"
    local -a job_lines=()
    mapfile -t job_lines < <(
      python3 - <<'PY' "${batch_file}" "${continue_on_error}"
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
payload = json.loads(path.read_text())
cli_continue = sys.argv[2] == "true"

if isinstance(payload, list):
    jobs = payload
    batch_continue = cli_continue
elif isinstance(payload, dict):
    jobs = payload.get("jobs", [])
    batch_continue = bool(payload.get("continue_on_error", cli_continue))
else:
    raise SystemExit("batch manifest must be array or object")

if not isinstance(jobs, list) or not jobs:
    raise SystemExit("batch manifest has no jobs")

print(json.dumps({"batch_continue_on_error": batch_continue}))
for job in jobs:
    if not isinstance(job, dict):
        raise SystemExit("all jobs must be objects")
    print(json.dumps(job, separators=(",", ":")))
PY
    )

    [[ "${#job_lines[@]}" -ge 2 ]] || die "batch manifest has no valid jobs"

    local batch_meta="${job_lines[0]}"
    local effective_continue_on_error
    effective_continue_on_error="$(jq -r '.batch_continue_on_error' <<<"${batch_meta}")"

    local total=0 succeeded=0 failed=0
    local jobs_json='[]'
    local idx=0
    local any_failed="false"

    for job_json in "${job_lines[@]:1}"; do
      idx=$((idx + 1))
      total=$((total + 1))

      local j_task j_backend j_session j_command
      local j_repo_trust j_internet j_external_code j_cpu_heavy j_long_run
      local j_estimated_cost j_confirm_budget j_confirm_critical j_input_contract
      local j_claude_tmux j_dry_run

      j_task="$(jq -r --arg d "${task}" '.task // $d' <<<"${job_json}")"
      j_backend="$(jq -r --arg d "${backend}" '.backend // $d' <<<"${job_json}")"
      j_session="$(jq -r --arg d "${session}" '.session // $d' <<<"${job_json}")"
      j_command="$(jq -r --arg d "${command_text}" '.command // $d' <<<"${job_json}")"
      j_repo_trust="$(jq -r --arg d "${repo_trust}" '.repo_trust // $d' <<<"${job_json}")"
      j_internet="$(jq -r --arg d "${internet}" '.internet // $d' <<<"${job_json}")"
      j_external_code="$(jq -r --arg d "${external_code}" '.external_code // $d' <<<"${job_json}")"
      j_cpu_heavy="$(jq -r --arg d "${cpu_heavy}" '.cpu_heavy // $d' <<<"${job_json}")"
      j_long_run="$(jq -r --arg d "${long_run}" '.long_run // $d' <<<"${job_json}")"
      j_estimated_cost="$(jq -r '.estimated_cost_usd // empty' <<<"${job_json}")"
      j_confirm_budget="$(jq -r '.confirm_budget // false' <<<"${job_json}")"
      j_confirm_critical="$(jq -r '.confirm_critical // false' <<<"${job_json}")"
      j_input_contract="$(jq -c '.input_contract // empty' <<<"${job_json}")"
      j_claude_tmux="$(jq -r --arg d "${claude_tmux}" '.claude_tmux // $d' <<<"${job_json}")"
      j_dry_run="$(jq -r --arg d "${dry_run}" '.dry_run // $d' <<<"${job_json}")"

      local missing_reason=""
      if [[ "${j_task}" == "null" || -z "${j_task}" ]]; then
        missing_reason="missing task"
      elif [[ "${j_session}" == "null" || -z "${j_session}" ]]; then
        missing_reason="missing session"
      elif [[ "${j_command}" == "null" || -z "${j_command}" ]]; then
        missing_reason="missing command"
      fi
      if [[ -n "${missing_reason}" ]]; then
        local invalid_result
        invalid_result="$(jq -n \
          --argjson index "${idx}" \
          --arg task "${j_task}" \
          --arg backend "${j_backend}" \
          --arg session "${j_session}" \
          --arg command "${j_command}" \
          --arg reason "${missing_reason}" \
          '{
            index:$index,
            task:(if $task == "null" then "" else $task end),
            backend:(if $backend == "null" then "" else $backend end),
            session:(if $session == "null" then "" else $session end),
            command:(if $command == "null" then "" else $command end),
            ok:false,
            exit_code:2,
            output:("invalid batch job: " + $reason)
          }')"
        jobs_json="$(jq -c --argjson item "${invalid_result}" '. + [$item]' <<<"${jobs_json}")"
        failed=$((failed + 1))
        any_failed="true"
        if [[ "${effective_continue_on_error}" != "true" ]]; then
          break
        fi
        continue
      fi

      local -a one_args=(
        run
        --task "${j_task}"
        --backend "${j_backend}"
        --session "${j_session}"
        --command "${j_command}"
        --repo-trust "${j_repo_trust}"
        --internet "${j_internet}"
        --external-code "${j_external_code}"
        --cpu-heavy "${j_cpu_heavy}"
        --long-run "${j_long_run}"
        --claude-tmux "${j_claude_tmux}"
        --json
      )

      if [[ -n "${j_estimated_cost}" ]]; then
        one_args+=(--estimated-cost-usd "${j_estimated_cost}")
      fi
      if [[ "${j_confirm_budget}" == "true" ]]; then
        one_args+=(--confirm-budget true)
      fi
      if [[ "${j_confirm_critical}" == "true" ]]; then
        one_args+=(--confirm-critical true)
      fi
      if [[ -n "${j_input_contract}" && "${j_input_contract}" != "null" ]]; then
        one_args+=(--input-contract "${j_input_contract}")
      fi
      if [[ "${j_dry_run}" == "true" ]]; then
        one_args+=(--dry-run)
      fi

      set +e
      local run_out
      run_out="$("${ROOT}/bin/lacp-orchestrate" "${one_args[@]}" 2>&1)"
      local run_rc=$?
      set -e

      local job_result
      job_result="$(jq -n \
        --argjson index "${idx}" \
        --arg task "${j_task}" \
        --arg backend "${j_backend}" \
        --arg session "${j_session}" \
        --arg command "${j_command}" \
        --argjson exit_code "${run_rc}" \
        --arg output "${run_out}" \
        '{
          index:$index,
          task:$task,
          backend:$backend,
          session:$session,
          command:$command,
          ok:($exit_code==0),
          exit_code:$exit_code,
          output:$output
        }')"
      jobs_json="$(jq -c --argjson item "${job_result}" '. + [$item]' <<<"${jobs_json}")"

      if [[ "${run_rc}" -eq 0 ]]; then
        succeeded=$((succeeded + 1))
      else
        failed=$((failed + 1))
        any_failed="true"
        if [[ "${effective_continue_on_error}" != "true" ]]; then
          break
        fi
      fi
    done

    local batch_ok="true"
    if [[ "${any_failed}" == "true" ]]; then
      batch_ok="false"
    fi

    if [[ "${as_json}" == "true" ]]; then
      jq -n \
        --argjson ok "$( [[ "${batch_ok}" == "true" ]] && echo true || echo false )" \
        --argjson continue_on_error "$( [[ "${effective_continue_on_error}" == "true" ]] && echo true || echo false )" \
        --argjson total "${total}" \
        --argjson succeeded "${succeeded}" \
        --argjson failed "${failed}" \
        --argjson jobs "${jobs_json}" \
        '{
          ok:$ok,
          summary:{
            total:$total,
            succeeded:$succeeded,
            failed:$failed,
            continue_on_error:$continue_on_error
          },
          jobs:$jobs
        }'
    else
      log "batch complete total=${total} succeeded=${succeeded} failed=${failed} continue_on_error=${effective_continue_on_error}"
    fi
    [[ "${batch_ok}" == "true" ]]
    return $?
  fi

  [[ -n "${task}" ]] || die "--task is required"
  [[ -n "${session}" ]] || die "--session is required"
  [[ -n "${command_text}" ]] || die "--command is required"
  [[ "${repo_trust}" == "trusted" || "${repo_trust}" == "unknown" ]] || die "--repo-trust must be trusted|unknown"
  [[ "${backend}" == "tmux" || "${backend}" == "dmux" || "${backend}" == "claude_worktree" ]] || die "--backend must be tmux|dmux|claude_worktree"

  local runner=""
  case "${backend}" in
    tmux|dmux)
      runner="${ROOT}/scripts/runners/${backend}-runner.sh"
      ;;
    claude_worktree)
      runner="${ROOT}/scripts/runners/claude-worktree-runner.sh"
      ;;
  esac
  require_file "${runner}"

  export LACP_ORCH_BACKEND="${backend}"
  export LACP_ORCH_SESSION_NAME="${session}"
  export LACP_ORCH_COMMAND="${command_text}"
  export LACP_ORCH_DRY_RUN="${dry_run}"
  export LACP_CLAUDE_WORKTREE_USE_TMUX="${claude_tmux}"

  local -a run_args=(
    --task "${task}"
    --repo-trust "${repo_trust}"
    --internet "${internet}"
    --external-code "${external_code}"
    --cpu-heavy "${cpu_heavy}"
    --long-run "${long_run}"
  )

  if [[ -n "${estimated_cost_usd}" ]]; then
    run_args+=(--estimated-cost-usd "${estimated_cost_usd}")
  fi
  if [[ "${confirm_budget}" == "true" ]]; then
    run_args+=(--confirm-budget true)
  fi
  if [[ "${confirm_critical}" == "true" ]]; then
    run_args+=(--confirm-critical true)
  fi
  if [[ -n "${input_contract}" ]]; then
    run_args+=(--input-contract "${input_contract}")
  fi
  if [[ "${dry_run}" == "true" ]]; then
    run_args+=(--dry-run)
  fi
  if [[ "${as_json}" == "true" ]]; then
    run_args+=(--json)
  fi

  "${ROOT}/bin/lacp-sandbox-run" "${run_args[@]}" -- "${runner}"
}

main() {
  [[ $# -ge 1 ]] || { usage; exit 0; }
  local sub="$1"
  shift || true

  case "${sub}" in
    doctor)
      local as_json="false"
      if [[ "${1:-}" == "--json" ]]; then
        as_json="true"
        shift
      fi
      [[ $# -eq 0 ]] || die "Unknown doctor argument: $1"
      cmd_doctor "${as_json}"
      ;;
    run)
      cmd_run "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "Unknown subcommand: ${sub}"
      ;;
  esac
}

main "$@"
