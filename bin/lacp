#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: lacp <command> [args...]

Core:
  start         Run onboarding flow (alias: onboard)
  install       Run installer profile workflow
  bootstrap-system Run full install/onboard/doctor bootstrap flow
  verify        Run verification cycle
  doctor        Run diagnostics
  status        Render status report
  test          Run test suites
  mode          Show/set operating mode

Ops:
  loop          Intent -> execute -> observe -> adapt control loop
  trace-triage  Cluster recent failed runs into root-cause groups
  context-profile List/render reusable context-contract profiles
  session-fingerprint Emit deterministic runtime session fingerprint
  report        Summarize recent run/artifact health
  canary        Evaluate 7-day promotion readiness gate
  canary-optimize Run bounded verify/canary optimization loop
  auto-rollback Run canary and fail-safe rollback actions on failure
  schedule-health Manage scheduled local health checks (launchd)
  policy-pack   Apply named policy baseline packs (starter/strict/enterprise)
  release-prepare Run full pre-live go/no-go discipline checks
  release-publish Build + publish release artifacts from local machine (no Actions)
  release-verify Verify release artifacts + checksums + tap install dry-run
  vendor-watch  Track Claude/Codex versions + docs/changelog drift
  automations-tui Unified dashboard for local automation health/status
  cache-audit   Analyze prompt cache effectiveness from local histories
  cache-guard   Enforce cache effectiveness thresholds
  skill-audit   Audit local skills for supply-chain risk patterns
  skill-factory Manage auto-skill-factory capture/record/lifecycle workflows
  release-gate  Run strict pre-live go/no-go gates
  pr-preflight  Evaluate PR policy gates (risk tier/checks/review/evidence)
  harness-validate Validate tasks.json against harness contracts
  harness-run  Execute tasks.json with dependency-aware loop retries
  e2e          Run local browser e2e workflows and auth pattern checks
  api-e2e      Run API/backend e2e workflows with manifest evidence
  contract-e2e Run contract/smart-contract e2e workflows with manifest evidence
  browser-evidence-validate Validate browser evidence manifest contract
  orchestrate   Run optional tmux/dmux orchestration through LACP gates
  worktree      Manage git worktree lifecycle for isolated agent runs
  swarm         Manage dmux-first multi-session swarm workflows
  migrate       Migrate roots into .env
  incident-drill Run incident readiness checklist/drill
  workflow-run  Deterministic multi-role workflow runner
  adopt-local   Install local claude/codex wrappers that route through LACP
  unadopt-local Remove LACP-managed local claude/codex wrappers
  route         Show routing decision
  run           Execute routed sandbox run
  bootstrap     Run bootstrap checks

Knowledge:
  knowledge-doctor   Validate knowledge graph/docs hygiene

Remote:
  remote-setup  Configure remote provider prerequisites
  remote-smoke  Run remote provider smoke test

Examples:
  lacp start --with-verify
  lacp test --isolated
  lacp doctor --json | jq
EOF
}

if [[ $# -lt 1 ]]; then
  usage
  exit 0
fi

cmd="$1"
shift || true

case "${cmd}" in
  start|onboard)
    exec "${ROOT}/bin/lacp-onboard" "$@"
    ;;
  install)
    exec "${ROOT}/bin/lacp-install" "$@"
    ;;
  bootstrap-system)
    exec "${ROOT}/bin/lacp-bootstrap-system" "$@"
    ;;
  verify)
    exec "${ROOT}/bin/lacp-verify" "$@"
    ;;
  doctor)
    exec "${ROOT}/bin/lacp-doctor" "$@"
    ;;
  knowledge-doctor)
    exec "${ROOT}/bin/lacp-knowledge-doctor" "$@"
    ;;
  status)
    exec "${ROOT}/bin/lacp-status-report" "$@"
    ;;
  test)
    exec "${ROOT}/bin/lacp-test" "$@"
    ;;
  mode)
    exec "${ROOT}/bin/lacp-mode" "$@"
    ;;
  report)
    exec "${ROOT}/bin/lacp-report" "$@"
    ;;
  loop)
    exec "${ROOT}/bin/lacp-loop" "$@"
    ;;
  trace-triage)
    exec "${ROOT}/bin/lacp-trace-triage" "$@"
    ;;
  context-profile)
    exec "${ROOT}/bin/lacp-context-profile" "$@"
    ;;
  session-fingerprint)
    exec "${ROOT}/bin/lacp-session-fingerprint" "$@"
    ;;
  canary)
    exec "${ROOT}/bin/lacp-canary" "$@"
    ;;
  canary-optimize)
    exec "${ROOT}/bin/lacp-canary-optimize" "$@"
    ;;
  auto-rollback)
    exec "${ROOT}/bin/lacp-auto-rollback" "$@"
    ;;
  schedule-health)
    exec "${ROOT}/bin/lacp-schedule-health" "$@"
    ;;
  policy-pack)
    exec "${ROOT}/bin/lacp-policy-pack" "$@"
    ;;
  release-prepare)
    exec "${ROOT}/bin/lacp-release-prepare" "$@"
    ;;
  release-publish)
    exec "${ROOT}/bin/lacp-release-publish" "$@"
    ;;
  release-verify)
    exec "${ROOT}/bin/lacp-release-verify" "$@"
    ;;
  vendor-watch)
    exec "${ROOT}/bin/lacp-vendor-watch" "$@"
    ;;
  automations-tui)
    exec "${ROOT}/bin/lacp-automations-tui" "$@"
    ;;
  cache-audit)
    exec "${ROOT}/bin/lacp-cache-audit" "$@"
    ;;
  cache-guard)
    exec "${ROOT}/bin/lacp-cache-guard" "$@"
    ;;
  skill-audit)
    exec "${ROOT}/bin/lacp-skill-audit" "$@"
    ;;
  skill-factory)
    exec "${ROOT}/bin/lacp-skill-factory" "$@"
    ;;
  release-gate)
    exec "${ROOT}/bin/lacp-release-gate" "$@"
    ;;
  pr-preflight)
    exec "${ROOT}/bin/lacp-pr-preflight" "$@"
    ;;
  harness-validate)
    exec "${ROOT}/bin/lacp-harness-validate" "$@"
    ;;
  harness-run)
    exec "${ROOT}/bin/lacp-harness-run" "$@"
    ;;
  e2e)
    exec "${ROOT}/bin/lacp-e2e" "$@"
    ;;
  api-e2e)
    exec "${ROOT}/bin/lacp-api-e2e" "$@"
    ;;
  contract-e2e)
    exec "${ROOT}/bin/lacp-contract-e2e" "$@"
    ;;
  browser-evidence-validate)
    exec "${ROOT}/bin/lacp-browser-evidence-validate" "$@"
    ;;
  orchestrate)
    exec "${ROOT}/bin/lacp-orchestrate" "$@"
    ;;
  worktree)
    exec "${ROOT}/bin/lacp-worktree" "$@"
    ;;
  swarm)
    exec "${ROOT}/bin/lacp-swarm" "$@"
    ;;
  migrate)
    exec "${ROOT}/bin/lacp-migrate" "$@"
    ;;
  incident-drill)
    exec "${ROOT}/bin/lacp-incident-drill" "$@"
    ;;
  workflow-run)
    exec "${ROOT}/bin/lacp-workflow-run" "$@"
    ;;
  adopt-local)
    exec "${ROOT}/bin/lacp-adopt-local" "$@"
    ;;
  unadopt-local)
    exec "${ROOT}/bin/lacp-unadopt-local" "$@"
    ;;
  route)
    exec "${ROOT}/bin/lacp-route" "$@"
    ;;
  run)
    exec "${ROOT}/bin/lacp-sandbox-run" "$@"
    ;;
  bootstrap)
    exec "${ROOT}/bin/lacp-bootstrap" "$@"
    ;;
  remote-setup)
    exec "${ROOT}/bin/lacp-remote-setup" "$@"
    ;;
  remote-smoke)
    exec "${ROOT}/bin/lacp-remote-smoke" "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "[lacp] ERROR: unknown command: ${cmd}" >&2
    usage >&2
    exit 1
    ;;
esac
