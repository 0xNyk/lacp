#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'USAGE'
Usage: lacp-loop --task "<summary>" [routing options] [loop options] -- <command> [args...]

Run one deterministic control loop:
  1) intent: capture task + command + routing contract
  2) execute: run through lacp-sandbox-run
  3) observe: collect status/report (+ optional verify/canary)
  4) adapt: optionally run auto-rollback on failed loop

Routing options:
  --repo-trust trusted|unknown|untrusted   (default: unknown)
  --internet true|false                    (default: false)
  --external-code true|false               (default: false)
  --sensitive-data true|false              (default: false)
  --cpu-heavy true|false                   (default: false)
  --long-run true|false                    (default: false)
  --remote-provider auto|daytona|e2b       (default: auto)
  --estimated-cost-usd <number>
  --confirm-critical true|false
  --confirm-budget true|false
  --input-contract '<json>'
  --context-contract '<json>'
  --context-profile <name>
  --context-profile-var KEY=VALUE   (repeatable; used with --context-profile)
  --loop-profile <name>
  --credential-profile <name>
  --session-fingerprint <value|auto>

Loop options:
  --dry-run                 Do not execute command
  --with-verify             Include lacp-verify stage
  --verify-hours <n>        Verify hours (default: LACP_VERIFY_HOURS)
  --with-canary             Include lacp-canary stage
  --canary-days <n>         Canary lookback days (default: LACP_CANARY_DAYS)
  --since-clean-baseline    Canary baseline-aware mode
  --baseline-file <path>    Canary baseline file override
  --report-hours <n>        Report hours (default: verify-hours)
  --auto-rollback-on-fail   Run lacp-auto-rollback if loop fails
  --json                    Emit JSON summary
  -h, --help                Show help
USAGE
}

as_bool() {
  case "$1" in
    true|false) printf '%s' "$1" ;;
    *) die "Expected true|false, got: $1" ;;
  esac
}

run_capture() {
  local out_var="$1"
  shift
  local captured_out
  set +e
  captured_out="$("$@" 2>&1)"
  local rc=$?
  set -e
  captured_out="$(printf '%s' "${captured_out}" | tr -d '\000-\010\013\014\016-\037')"
  printf -v "${out_var}" '%s' "${captured_out}"
  return "${rc}"
}

TASK=""
REPO_TRUST="unknown"
INTERNET="false"
EXTERNAL_CODE="false"
SENSITIVE_DATA="false"
CPU_HEAVY="false"
LONG_RUN="false"
REMOTE_PROVIDER_OVERRIDE="auto"
ESTIMATED_COST_USD="0"
CONFIRM_CRITICAL="false"
CONFIRM_BUDGET="false"
INPUT_CONTRACT=""
CONTEXT_CONTRACT=""
CONTEXT_PROFILE=""
declare -a CONTEXT_PROFILE_VARS=()
SESSION_FINGERPRINT=""
LOOP_PROFILE=""
CREDENTIAL_PROFILE=""

SET_REPO_TRUST=0
SET_INTERNET=0
SET_EXTERNAL_CODE=0
SET_SENSITIVE_DATA=0
SET_CPU_HEAVY=0
SET_LONG_RUN=0
SET_REMOTE_PROVIDER=0
SET_CONFIRM_CRITICAL=0
SET_CONFIRM_BUDGET=0
SET_INPUT_CONTRACT=0
SET_WITH_VERIFY=0
SET_VERIFY_HOURS=0
SET_WITH_CANARY=0
SET_CANARY_DAYS=0
SET_REPORT_HOURS=0
SET_SINCE_CLEAN_BASELINE=0
SET_AUTO_ROLLBACK=0

DRY_RUN=0
WITH_VERIFY=0
WITH_CANARY=0
VERIFY_HOURS="${LACP_VERIFY_HOURS}"
CANARY_DAYS="${LACP_CANARY_DAYS}"
REPORT_HOURS="${LACP_VERIFY_HOURS}"
SINCE_CLEAN_BASELINE=0
BASELINE_FILE=""
AUTO_ROLLBACK=0
AS_JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --task) TASK="$2"; shift 2 ;;
    --repo-trust) REPO_TRUST="$2"; SET_REPO_TRUST=1; shift 2 ;;
    --internet) INTERNET="$(as_bool "$2")"; SET_INTERNET=1; shift 2 ;;
    --external-code) EXTERNAL_CODE="$(as_bool "$2")"; SET_EXTERNAL_CODE=1; shift 2 ;;
    --sensitive-data) SENSITIVE_DATA="$(as_bool "$2")"; SET_SENSITIVE_DATA=1; shift 2 ;;
    --cpu-heavy) CPU_HEAVY="$(as_bool "$2")"; SET_CPU_HEAVY=1; shift 2 ;;
    --long-run) LONG_RUN="$(as_bool "$2")"; SET_LONG_RUN=1; shift 2 ;;
    --remote-provider) REMOTE_PROVIDER_OVERRIDE="$2"; SET_REMOTE_PROVIDER=1; shift 2 ;;
    --estimated-cost-usd) ESTIMATED_COST_USD="$2"; shift 2 ;;
    --confirm-critical) CONFIRM_CRITICAL="$(as_bool "$2")"; SET_CONFIRM_CRITICAL=1; shift 2 ;;
    --confirm-budget) CONFIRM_BUDGET="$(as_bool "$2")"; SET_CONFIRM_BUDGET=1; shift 2 ;;
    --input-contract) INPUT_CONTRACT="$2"; SET_INPUT_CONTRACT=1; shift 2 ;;
    --context-contract) CONTEXT_CONTRACT="$2"; shift 2 ;;
    --context-profile) CONTEXT_PROFILE="$2"; shift 2 ;;
    --context-profile-var) CONTEXT_PROFILE_VARS+=("$2"); shift 2 ;;
    --loop-profile) LOOP_PROFILE="$2"; shift 2 ;;
    --credential-profile) CREDENTIAL_PROFILE="$2"; shift 2 ;;
    --session-fingerprint) SESSION_FINGERPRINT="$2"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --with-verify) WITH_VERIFY=1; SET_WITH_VERIFY=1; shift ;;
    --verify-hours) VERIFY_HOURS="$2"; REPORT_HOURS="$2"; SET_VERIFY_HOURS=1; SET_REPORT_HOURS=1; shift 2 ;;
    --with-canary) WITH_CANARY=1; SET_WITH_CANARY=1; shift ;;
    --canary-days) CANARY_DAYS="$2"; SET_CANARY_DAYS=1; shift 2 ;;
    --since-clean-baseline) SINCE_CLEAN_BASELINE=1; SET_SINCE_CLEAN_BASELINE=1; shift ;;
    --baseline-file) BASELINE_FILE="$2"; shift 2 ;;
    --report-hours) REPORT_HOURS="$2"; SET_REPORT_HOURS=1; shift 2 ;;
    --auto-rollback-on-fail) AUTO_ROLLBACK=1; SET_AUTO_ROLLBACK=1; shift ;;
    --json) AS_JSON=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    *) die "Unknown argument: $1" ;;
  esac
done

[[ -n "${TASK}" ]] || die "--task is required"
[[ $# -gt 0 ]] || die "Missing command after --"
if [[ -n "${CONTEXT_CONTRACT}" && -n "${CONTEXT_PROFILE}" ]]; then
  die "--context-contract and --context-profile are mutually exclusive"
fi
if [[ -n "${LOOP_PROFILE}" ]]; then
  loop_profile_raw="$("${ROOT}/bin/lacp-loop-profile" render --profile "${LOOP_PROFILE}" --json 2>&1 || true)"
  loop_profile_ok="$(jq -r '.ok // false' 2>/dev/null <<<"${loop_profile_raw}" || echo false)"
  if [[ "${loop_profile_ok}" != "true" ]]; then
    loop_profile_error="$(jq -r '.error // "failed to render loop profile"' 2>/dev/null <<<"${loop_profile_raw}" || echo "failed to render loop profile")"
    die "loop profile render failed: ${loop_profile_error}"
  fi
  if [[ "${SET_REPO_TRUST}" -eq 0 ]]; then
    v="$(jq -r '.routing_defaults.repo_trust // empty' <<<"${loop_profile_raw}")"
    [[ -n "${v}" ]] && REPO_TRUST="${v}"
  fi
  if [[ "${SET_INTERNET}" -eq 0 ]]; then INTERNET="$(jq -r '.routing_defaults.internet // false' <<<"${loop_profile_raw}")"; fi
  if [[ "${SET_EXTERNAL_CODE}" -eq 0 ]]; then EXTERNAL_CODE="$(jq -r '.routing_defaults.external_code // false' <<<"${loop_profile_raw}")"; fi
  if [[ "${SET_SENSITIVE_DATA}" -eq 0 ]]; then SENSITIVE_DATA="$(jq -r '.routing_defaults.sensitive_data // false' <<<"${loop_profile_raw}")"; fi
  if [[ "${SET_CPU_HEAVY}" -eq 0 ]]; then CPU_HEAVY="$(jq -r '.routing_defaults.cpu_heavy // false' <<<"${loop_profile_raw}")"; fi
  if [[ "${SET_LONG_RUN}" -eq 0 ]]; then LONG_RUN="$(jq -r '.routing_defaults.long_run // false' <<<"${loop_profile_raw}")"; fi
  if [[ "${SET_REMOTE_PROVIDER}" -eq 0 ]]; then
    v="$(jq -r '.routing_defaults.remote_provider // empty' <<<"${loop_profile_raw}")"
    [[ -n "${v}" ]] && REMOTE_PROVIDER_OVERRIDE="${v}"
  fi
  if [[ "${SET_CONFIRM_CRITICAL}" -eq 0 ]]; then CONFIRM_CRITICAL="$(jq -r '.routing_defaults.confirm_critical // false' <<<"${loop_profile_raw}")"; fi
  if [[ "${SET_CONFIRM_BUDGET}" -eq 0 ]]; then CONFIRM_BUDGET="$(jq -r '.routing_defaults.confirm_budget // false' <<<"${loop_profile_raw}")"; fi
  if [[ "${SET_WITH_VERIFY}" -eq 0 ]]; then WITH_VERIFY="$(jq -r '.loop_defaults.with_verify // false' <<<"${loop_profile_raw}" | sed 's/true/1/;s/false/0/')"; fi
  if [[ "${SET_VERIFY_HOURS}" -eq 0 ]]; then
    v="$(jq -r '.loop_defaults.verify_hours // empty' <<<"${loop_profile_raw}")"
    [[ -n "${v}" ]] && VERIFY_HOURS="${v}"
  fi
  if [[ "${SET_WITH_CANARY}" -eq 0 ]]; then WITH_CANARY="$(jq -r '.loop_defaults.with_canary // false' <<<"${loop_profile_raw}" | sed 's/true/1/;s/false/0/')"; fi
  if [[ "${SET_CANARY_DAYS}" -eq 0 ]]; then
    v="$(jq -r '.loop_defaults.canary_days // empty' <<<"${loop_profile_raw}")"
    [[ -n "${v}" ]] && CANARY_DAYS="${v}"
  fi
  if [[ "${SET_REPORT_HOURS}" -eq 0 ]]; then
    v="$(jq -r '.loop_defaults.report_hours // empty' <<<"${loop_profile_raw}")"
    [[ -n "${v}" ]] && REPORT_HOURS="${v}"
  fi
  if [[ "${SET_SINCE_CLEAN_BASELINE}" -eq 0 ]]; then SINCE_CLEAN_BASELINE="$(jq -r '.loop_defaults.since_clean_baseline // false' <<<"${loop_profile_raw}" | sed 's/true/1/;s/false/0/')"; fi
  if [[ "${SET_AUTO_ROLLBACK}" -eq 0 ]]; then AUTO_ROLLBACK="$(jq -r '.loop_defaults.auto_rollback_on_fail // false' <<<"${loop_profile_raw}" | sed 's/true/1/;s/false/0/')"; fi
fi
if [[ -n "${CREDENTIAL_PROFILE}" ]]; then
  cred_profile_raw="$("${ROOT}/bin/lacp-credential-profile" render --profile "${CREDENTIAL_PROFILE}" --json 2>&1 || true)"
  cred_profile_ok="$(jq -r '.ok // false' 2>/dev/null <<<"${cred_profile_raw}" || echo false)"
  if [[ "${cred_profile_ok}" != "true" ]]; then
    cred_profile_error="$(jq -r '.error // "failed to render credential profile"' 2>/dev/null <<<"${cred_profile_raw}" || echo "failed to render credential profile")"
    die "credential profile render failed: ${cred_profile_error}"
  fi
  if [[ "${SET_REPO_TRUST}" -eq 0 ]]; then
    v="$(jq -r '.defaults.repo_trust // empty' <<<"${cred_profile_raw}")"
    [[ -n "${v}" ]] && REPO_TRUST="${v}"
  fi
  if [[ "${SET_INTERNET}" -eq 0 ]]; then INTERNET="$(jq -r '.defaults.internet // false' <<<"${cred_profile_raw}")"; fi
  if [[ "${SET_EXTERNAL_CODE}" -eq 0 ]]; then EXTERNAL_CODE="$(jq -r '.defaults.external_code // false' <<<"${cred_profile_raw}")"; fi
  if [[ "${SET_SENSITIVE_DATA}" -eq 0 ]]; then SENSITIVE_DATA="$(jq -r '.defaults.sensitive_data // false' <<<"${cred_profile_raw}")"; fi
  if [[ "${SET_CONFIRM_CRITICAL}" -eq 0 ]]; then CONFIRM_CRITICAL="$(jq -r '.defaults.confirm_critical // false' <<<"${cred_profile_raw}")"; fi
  if [[ "${SET_CONFIRM_BUDGET}" -eq 0 ]]; then CONFIRM_BUDGET="$(jq -r '.defaults.confirm_budget // false' <<<"${cred_profile_raw}")"; fi
  if [[ "${SET_INPUT_CONTRACT}" -eq 0 ]]; then INPUT_CONTRACT="$(jq -c '.input_contract // {}' <<<"${cred_profile_raw}")"; fi
fi
if [[ -n "${CONTEXT_PROFILE}" ]]; then
  profile_cmd=("${ROOT}/bin/lacp-context-profile" render --profile "${CONTEXT_PROFILE}")
  for kv in ${CONTEXT_PROFILE_VARS+"${CONTEXT_PROFILE_VARS[@]}"}; do
    profile_cmd+=(--var "${kv}")
  done
  profile_cmd+=(--json)
  profile_raw="$("${profile_cmd[@]}" 2>&1 || true)"
  profile_ok="$(jq -r '.ok // false' 2>/dev/null <<<"${profile_raw}" || echo false)"
  if [[ "${profile_ok}" != "true" ]]; then
    profile_error="$(jq -r '.error // "failed to render context profile"' 2>/dev/null <<<"${profile_raw}" || echo "failed to render context profile")"
    die "context profile render failed: ${profile_error}"
  fi
  CONTEXT_CONTRACT="$(jq -c '.context_contract' <<<"${profile_raw}")"
fi
if [[ "${SESSION_FINGERPRINT}" == "auto" ]]; then
  SESSION_FINGERPRINT="$("${ROOT}/bin/lacp-session-fingerprint")"
fi

execute_cmd=(
  "${ROOT}/bin/lacp-sandbox-run"
  --task "${TASK}"
  --repo-trust "${REPO_TRUST}"
  --internet "${INTERNET}"
  --external-code "${EXTERNAL_CODE}"
  --sensitive-data "${SENSITIVE_DATA}"
  --cpu-heavy "${CPU_HEAVY}"
  --long-run "${LONG_RUN}"
  --remote-provider "${REMOTE_PROVIDER_OVERRIDE}"
  --estimated-cost-usd "${ESTIMATED_COST_USD}"
  --confirm-critical "${CONFIRM_CRITICAL}"
  --confirm-budget "${CONFIRM_BUDGET}"
)

if [[ -n "${INPUT_CONTRACT}" ]]; then
  execute_cmd+=(--input-contract "${INPUT_CONTRACT}")
fi
if [[ -n "${CONTEXT_CONTRACT}" ]]; then
  execute_cmd+=(--context-contract "${CONTEXT_CONTRACT}")
fi
if [[ -n "${SESSION_FINGERPRINT}" ]]; then
  execute_cmd+=(--session-fingerprint "${SESSION_FINGERPRINT}")
fi
if [[ "${DRY_RUN}" -eq 1 ]]; then
  execute_cmd+=(--dry-run)
fi
execute_cmd+=(--json -- "$@")

execute_json="{}"
verify_json="null"
canary_json="null"
status_json="{}"
report_json="{}"
rollback_json="null"

execute_rc=0
verify_rc=0
canary_rc=0
status_rc=0
report_rc=0
rollback_rc=0

run_capture execute_json "${execute_cmd[@]}" || execute_rc=$?

if [[ "${WITH_VERIFY}" -eq 1 ]]; then
  run_capture verify_json "${ROOT}/bin/lacp-verify" --hours "${VERIFY_HOURS}" || verify_rc=$?
fi

canary_args=("${ROOT}/bin/lacp-canary" --days "${CANARY_DAYS}" --json)
if [[ "${SINCE_CLEAN_BASELINE}" -eq 1 ]]; then
  canary_args+=(--since-clean-baseline)
fi
if [[ -n "${BASELINE_FILE}" ]]; then
  canary_args+=(--baseline-file "${BASELINE_FILE}")
fi
if [[ "${WITH_CANARY}" -eq 1 ]]; then
  run_capture canary_json "${canary_args[@]}" || canary_rc=$?
fi

run_capture status_json "${ROOT}/bin/lacp-status-report" --json || status_rc=$?
run_capture report_json "${ROOT}/bin/lacp-report" --hours "${REPORT_HOURS}" --json || report_rc=$?

loop_ok="true"
if [[ "${execute_rc}" -ne 0 || "${verify_rc}" -ne 0 || "${canary_rc}" -ne 0 || "${status_rc}" -ne 0 || "${report_rc}" -ne 0 ]]; then
  loop_ok="false"
fi
if [[ "${status_rc}" -eq 0 ]] && [[ "$(echo "${status_json}" | jq -r '.ok // false')" != "true" ]]; then
  loop_ok="false"
fi
if [[ "${report_rc}" -eq 0 ]] && [[ "$(echo "${report_json}" | jq -r '.ok // false')" != "true" ]]; then
  loop_ok="false"
fi
if [[ "${WITH_CANARY}" -eq 1 ]] && [[ "${canary_rc}" -eq 0 ]] && [[ "$(echo "${canary_json}" | jq -r '.ok // false')" != "true" ]]; then
  loop_ok="false"
fi

if [[ "${loop_ok}" != "true" && "${AUTO_ROLLBACK}" -eq 1 ]]; then
  run_capture rollback_json "${ROOT}/bin/lacp-auto-rollback" --days "${CANARY_DAYS}" --json || rollback_rc=$?
fi

classifier_json="$(python3 - <<'PY' "${loop_ok}" "${execute_rc}" "${verify_rc}" "${canary_rc}" "${status_rc}" "${report_rc}" "${execute_json}" "${verify_json}" "${canary_json}" "${status_json}" "${report_json}"
import json
import sys

loop_ok = sys.argv[1] == "true"
execute_rc = int(sys.argv[2])
verify_rc = int(sys.argv[3])
canary_rc = int(sys.argv[4])
status_rc = int(sys.argv[5])
report_rc = int(sys.argv[6])
execute_raw = sys.argv[7]
verify_raw = sys.argv[8]
canary_raw = sys.argv[9]
status_raw = sys.argv[10]
report_raw = sys.argv[11]

def parse(raw):
    try:
        return json.loads(raw)
    except Exception:
        return {}

execute = parse(execute_raw)
verify = parse(verify_raw)
canary = parse(canary_raw)
status = parse(status_raw)
report = parse(report_raw)

signals = []
hints = []
primary = None
secondary = []

execute_error = str(execute.get("error") or "")
execute_exit_code = int(execute.get("exit_code", execute_rc) or execute_rc)
executed = bool(execute.get("executed", False))
ctx_required = bool(((execute.get("context_contract") or {}).get("required")) if isinstance(execute, dict) else False)
ctx_valid = bool(((execute.get("context_contract") or {}).get("valid")) if isinstance(execute, dict) else False)

policy_block_codes = {8, 9, 10, 11, 12}

if not loop_ok:
    if execute_exit_code in policy_block_codes or "blocked by" in execute_error.lower():
        primary = "policy_block"
        signals.append(f"execute.exit_code={execute_exit_code}")
        if execute_error:
            signals.append(f"execute.error={execute_error}")
        hints.append("Review route/risk gates and required confirmations (`--confirm-critical`, `--confirm-budget`).")
        hints.append("Provide required contracts (`--input-contract`, `--context-contract`) for risky or mutating/remote-target runs.")

    if (ctx_required and not ctx_valid) or "context contract gate" in execute_error.lower() or "context mismatch" in execute_error.lower():
        if primary is None:
            primary = "context_drift"
        elif primary != "context_drift":
            secondary.append("context_drift")
        signals.append("context_contract.invalid=true")
        hints.append("Pin execution context with `--context-contract` (`expected_host`, `expected_cwd_prefix`, `expected_git_branch`, `expected_git_worktree`, `expected_remote_host`).")
        hints.append("Run in dedicated worktree/session per task to avoid cross-window drift.")

    if canary_rc != 0:
        if primary is None:
            primary = "regression"
        elif primary != "regression":
            secondary.append("regression")
        signals.append("canary.rc!=0")
        hints.append("Inspect canary failures and run `lacp canary --json` + `lacp report --json` to confirm regression source.")

    canary_ok = canary.get("ok") if isinstance(canary, dict) else None
    if canary_ok is False:
        if primary is None:
            primary = "regression"
        elif primary != "regression":
            secondary.append("regression")
        signals.append("canary.ok=false")

    benchmark_gate_ok = None
    if isinstance(status, dict):
        benchmark_gate_ok = ((status.get("summary") or {}).get("benchmark_gate_ok"))
    if benchmark_gate_ok is False:
        if primary is None:
            primary = "regression"
        elif primary != "regression":
            secondary.append("regression")
        signals.append("status.summary.benchmark_gate_ok=false")

    if execute_rc != 0 and primary is None:
        if execute_exit_code in (126, 127) or "not found" in execute_error.lower() or "missing" in execute_error.lower():
            primary = "env_missing"
            signals.append(f"execute.exit_code={execute_exit_code}")
            hints.append("Verify local dependencies and configured runners (`lacp doctor --json`, `lacp bootstrap`).")
        else:
            primary = "test_fail"
            signals.append(f"execute.exit_code={execute_exit_code}")
            hints.append("Investigate failing command output and re-run with deterministic inputs/contracts.")

    for stage_name, rc, payload in (
        ("verify", verify_rc, verify),
        ("status", status_rc, status),
        ("report", report_rc, report),
    ):
        if rc != 0:
            if primary is None:
                primary = "env_missing"
            elif primary != "env_missing":
                secondary.append("env_missing")
            signals.append(f"{stage_name}.rc={rc}")
            hints.append(f"Check `{stage_name}` stage dependencies and artifact roots (`LACP_AUTOMATION_ROOT`, `LACP_KNOWLEDGE_ROOT`).")
        elif isinstance(payload, dict) and payload.get("ok") is False and stage_name in {"status", "report"}:
            if primary is None:
                primary = "regression"
            elif primary != "regression":
                secondary.append("regression")
            signals.append(f"{stage_name}.ok=false")

if primary is None:
    confidence = 1.0 if loop_ok else 0.4
else:
    confidence = 0.95 if primary in {"policy_block", "context_drift"} else 0.8

# de-duplicate while preserving order
def dedupe(items):
    seen = set()
    out = []
    for item in items:
        if item in seen:
            continue
        seen.add(item)
        out.append(item)
    return out

payload = {
    "primary_cause": primary,
    "secondary_causes": dedupe(secondary),
    "signals": dedupe(signals),
    "remediation_hints": dedupe(hints),
    "confidence": confidence,
}
print(json.dumps(payload))
PY
)"

cmd_json="$(printf '%s\0' "$@" | xargs -0 -n1 printf '%s\n' | jq -R . | jq -s .)"
result_json="$(jq -n \
  --arg schema_version "1" \
  --arg kind "control_loop" \
  --arg generated_at_utc "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  --argjson ok "$([[ "${loop_ok}" == "true" ]] && echo true || echo false)" \
  --argjson dry_run "$([[ "${DRY_RUN}" -eq 1 ]] && echo true || echo false)" \
  --argjson with_verify "$([[ "${WITH_VERIFY}" -eq 1 ]] && echo true || echo false)" \
  --argjson with_canary "$([[ "${WITH_CANARY}" -eq 1 ]] && echo true || echo false)" \
  --argjson auto_rollback "$([[ "${AUTO_ROLLBACK}" -eq 1 ]] && echo true || echo false)" \
  --arg loop_profile "${LOOP_PROFILE}" \
  --arg credential_profile "${CREDENTIAL_PROFILE}" \
  --arg task "${TASK}" \
  --arg repo_trust "${REPO_TRUST}" \
  --arg internet "${INTERNET}" \
  --arg external_code "${EXTERNAL_CODE}" \
  --arg sensitive_data "${SENSITIVE_DATA}" \
  --arg cpu_heavy "${CPU_HEAVY}" \
  --arg long_run "${LONG_RUN}" \
  --arg remote_provider "${REMOTE_PROVIDER_OVERRIDE}" \
  --arg estimated_cost_usd "${ESTIMATED_COST_USD}" \
  --argjson command "${cmd_json}" \
  --argjson execute_rc "${execute_rc}" \
  --argjson verify_rc "${verify_rc}" \
  --argjson canary_rc "${canary_rc}" \
  --argjson status_rc "${status_rc}" \
  --argjson report_rc "${report_rc}" \
  --argjson rollback_rc "${rollback_rc}" \
  --arg execute_raw "${execute_json}" \
  --arg verify_raw "${verify_json}" \
  --arg canary_raw "${canary_json}" \
  --arg status_raw "${status_json}" \
  --arg report_raw "${report_json}" \
  --arg rollback_raw "${rollback_json}" \
  --arg classifier_raw "${classifier_json}" \
  '{
    schema_version: $schema_version,
    kind: $kind,
    generated_at_utc: $generated_at_utc,
    ok: $ok,
    intent: {
      task: $task,
      routing: {
        repo_trust: $repo_trust,
        internet: ($internet == "true"),
        external_code: ($external_code == "true"),
        sensitive_data: ($sensitive_data == "true"),
        cpu_heavy: ($cpu_heavy == "true"),
        long_run: ($long_run == "true"),
        remote_provider: $remote_provider,
        estimated_cost_usd: (try ($estimated_cost_usd | tonumber) catch null)
      },
      command: $command
    },
    options: {
      dry_run: $dry_run,
      with_verify: $with_verify,
      with_canary: $with_canary,
      auto_rollback_on_fail: $auto_rollback,
      loop_profile: (if $loop_profile == "" then null else $loop_profile end),
      credential_profile: (if $credential_profile == "" then null else $credential_profile end)
    },
    stages: {
      execute: {
        rc: $execute_rc,
        result: (try ($execute_raw | fromjson) catch {ok:false, raw:$execute_raw})
      },
      verify: {
        rc: $verify_rc,
        result: (if $with_verify then (try ($verify_raw | fromjson) catch {ok:false, raw:$verify_raw}) else null end)
      },
      canary: {
        rc: $canary_rc,
        result: (if $with_canary then (try ($canary_raw | fromjson) catch {ok:false, raw:$canary_raw}) else null end)
      },
      status: {
        rc: $status_rc,
        result: (try ($status_raw | fromjson) catch {ok:false, raw:$status_raw})
      },
      report: {
        rc: $report_rc,
        result: (try ($report_raw | fromjson) catch {ok:false, raw:$report_raw})
      },
      adapt: {
        rollback_rc: $rollback_rc,
        result: (if $rollback_raw == "null" then null else {raw: $rollback_raw} end)
      }
    },
    analysis: (try ($classifier_raw | fromjson) catch {
      primary_cause: null,
      secondary_causes: [],
      signals: ["classifier_parse_error"],
      remediation_hints: ["re-run with --json and inspect stage outputs directly"],
      confidence: 0.0
    })
  }')"

if [[ "${AS_JSON}" -eq 1 ]]; then
  printf '%s\n' "${result_json}"
else
  echo "${result_json}" | jq -r '
    "LACP Loop",
    "  ok=\(.ok) dry_run=\(.options.dry_run)",
    "  task=\(.intent.task)",
    "  execute.rc=\(.stages.execute.rc) verify.rc=\(.stages.verify.rc) canary.rc=\(.stages.canary.rc)",
    "  status.ok=\(.stages.status.result.ok // false) report.ok=\(.stages.report.result.ok // false)",
    "  auto_rollback=\(.options.auto_rollback_on_fail) rollback_rc=\(.stages.adapt.rollback_rc)"
  '
fi

if [[ "${loop_ok}" != "true" ]]; then
  exit 1
fi
