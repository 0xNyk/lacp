#!/usr/bin/env bash
set -euo pipefail

LACP_SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export LACP_SCRIPT_ROOT

python3 - "$@" <<'PY'
from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import subprocess
import sys
from pathlib import Path

def utc_stamp() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def run_cmd(cmd: list[str], env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, capture_output=True, text=True, env=env)


def canonical_sha256(payload: dict) -> str:
    raw = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(raw).hexdigest()


def attach_receipt(record: dict, prev_hash: str, receipt_index: int) -> tuple[dict, str]:
    ts = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    preimage = dict(record)
    preimage["receipt"] = {
        "receipt_version": "1.0",
        "receipt_index": receipt_index,
        "prev_receipt_hash": prev_hash,
        "generated_at_utc": ts,
    }
    digest = canonical_sha256(preimage)
    preimage["receipt"]["receipt_hash"] = digest
    return preimage, digest


def topological_order(tasks: list[dict]) -> list[dict]:
    by_id = {t["id"]: t for t in tasks}
    indegree = {t["id"]: 0 for t in tasks}
    edges: dict[str, list[str]] = {t["id"]: [] for t in tasks}
    for t in tasks:
        for dep in t.get("depends_on", []):
            edges.setdefault(dep, []).append(t["id"])
            indegree[t["id"]] += 1
    queue = [tid for tid, d in indegree.items() if d == 0]
    ordered: list[str] = []
    while queue:
        cur = queue.pop(0)
        ordered.append(cur)
        for nxt in edges.get(cur, []):
            indegree[nxt] -= 1
            if indegree[nxt] == 0:
                queue.append(nxt)
    if len(ordered) != len(tasks):
        raise ValueError("dependency graph has a cycle")
    return [by_id[tid] for tid in ordered]


def map_profile_to_sandbox_args(profile: dict, task_title: str, dry_run: bool) -> list[str]:
    route = str(profile.get("route", "trusted_local"))
    args = ["--task", task_title]
    if route == "trusted_local":
        args += ["--repo-trust", "trusted"]
    elif route == "local_sandbox":
        args += ["--repo-trust", "unknown", "--external-code", "true"]
    elif route == "remote_sandbox":
        args += ["--repo-trust", "unknown", "--cpu-heavy", "true", "--long-run", "true"]
    else:
        args += ["--repo-trust", "unknown"]
    if dry_run:
        args.append("--dry-run")
    return args


def run_verification_checks(policy: dict, workdir: Path) -> tuple[bool, list[dict]]:
    checks = policy.get("required", {}).get("checks", [])
    min_passed = int(policy.get("thresholds", {}).get("min_passed_checks", len(checks)))
    results: list[dict] = []
    passed = 0
    for check in checks:
        cid = str(check.get("id", "check"))
        command = str(check.get("command", "")).strip()
        if not command:
            results.append({"id": cid, "command": command, "exit_code": 2, "ok": False, "error": "missing command"})
            continue
        cp = run_cmd(["/usr/bin/env", "bash", "-lc", f"cd {json.dumps(str(workdir))} && {command}"])
        ok = cp.returncode == 0
        if ok:
            passed += 1
        results.append(
            {
                "id": cid,
                "command": command,
                "exit_code": cp.returncode,
                "ok": ok,
                "stdout": cp.stdout[-2000:],
                "stderr": cp.stderr[-2000:],
            }
        )
    return passed >= min_passed, results


def validate_json_schema(value, schema: dict, path: str = "$") -> list[str]:
    errors: list[str] = []
    if not isinstance(schema, dict):
        return [f"{path}: schema must be an object"]

    stype = schema.get("type")
    if stype == "object":
        if not isinstance(value, dict):
            return [f"{path}: expected object"]
        required = schema.get("required", [])
        if isinstance(required, list):
            for key in required:
                if isinstance(key, str) and key not in value:
                    errors.append(f"{path}: missing required property '{key}'")
        props = schema.get("properties", {})
        if isinstance(props, dict):
            for key, sub in props.items():
                if key in value:
                    errors.extend(validate_json_schema(value[key], sub, f"{path}.{key}"))
    elif stype == "array":
        if not isinstance(value, list):
            return [f"{path}: expected array"]
        item_schema = schema.get("items")
        if isinstance(item_schema, dict):
            for idx, item in enumerate(value):
                errors.extend(validate_json_schema(item, item_schema, f"{path}[{idx}]"))
    elif stype == "string":
        if not isinstance(value, str):
            return [f"{path}: expected string"]
    elif stype == "number":
        if not isinstance(value, (int, float)) or isinstance(value, bool):
            return [f"{path}: expected number"]
    elif stype == "integer":
        if not isinstance(value, int) or isinstance(value, bool):
            return [f"{path}: expected integer"]
    elif stype == "boolean":
        if not isinstance(value, bool):
            return [f"{path}: expected boolean"]

    enum_vals = schema.get("enum")
    if isinstance(enum_vals, list) and enum_vals and value not in enum_vals:
        errors.append(f"{path}: value not in enum")
    return errors


def validate_expected_inputs(task: dict, deps: list[str], output_registry: dict[str, dict]) -> tuple[bool, list[dict], list[str]]:
    contracts = task.get("expected_inputs") or []
    if not isinstance(contracts, list):
        return False, [], ["expected_inputs must be an array"]

    deps_set = set(str(d) for d in deps)
    resolved: list[dict] = []
    errors: list[str] = []
    for item in contracts:
        if not isinstance(item, dict):
            errors.append("expected_inputs entry must be an object")
            continue
        cid = str(item.get("id") or "").strip()
        from_task = str(item.get("from_task") or "").strip()
        output_id = str(item.get("output_id") or "").strip()
        required = bool(item.get("required", True))
        if not cid or not from_task or not output_id:
            errors.append("expected_inputs entry missing id/from_task/output_id")
            continue
        if from_task not in deps_set:
            errors.append(f"input contract {cid} references from_task={from_task} not present in depends_on")
            continue

        output_map = output_registry.get(from_task) or {}
        output_ref = output_map.get(output_id)
        exists = bool(output_ref and output_ref.get("exists"))
        if required and not exists:
            errors.append(f"input contract {cid} missing required upstream output {from_task}:{output_id}")
            continue

        resolved.append(
            {
                "id": cid,
                "from_task": from_task,
                "output_id": output_id,
                "required": required,
                "resolved": exists,
                "path": (output_ref or {}).get("path"),
            }
        )
    return len(errors) == 0, resolved, errors


def collect_expected_outputs(task: dict, workdir: Path, tasks_dir: Path, root: Path) -> tuple[bool, dict[str, dict], list[str]]:
    contracts = task.get("expected_outputs") or []
    if not isinstance(contracts, list):
        return False, {}, ["expected_outputs must be an array"]

    outputs: dict[str, dict] = {}
    errors: list[str] = []
    for item in contracts:
        if not isinstance(item, dict):
            errors.append("expected_outputs entry must be an object")
            continue
        oid = str(item.get("id") or "").strip()
        path_raw = str(item.get("path") or "").strip()
        kind = str(item.get("kind") or "").strip() or None
        schema_path_raw = str(item.get("schema_path") or "").strip() or None
        required = bool(item.get("required", True))
        if not oid or not path_raw:
            errors.append("expected_outputs entry missing id/path")
            continue
        p = Path(path_raw)
        p_abs = p if p.is_absolute() else (workdir / p).resolve()
        exists = p_abs.exists()
        if required and not exists:
            errors.append(f"output contract {oid} missing required path: {p_abs}")

        schema_errors: list[str] = []
        schema_path_resolved: str | None = None
        if exists and schema_path_raw:
            candidate_paths: list[Path] = []
            sp = Path(schema_path_raw)
            if sp.is_absolute():
                candidate_paths.append(sp)
            else:
                candidate_paths.append((tasks_dir / sp).resolve())
                candidate_paths.append((root / sp).resolve())
                candidate_paths.append((workdir / sp).resolve())
            schema_file = next((c for c in candidate_paths if c.exists()), None)
            if schema_file is None:
                schema_errors.append(f"schema_path not found: {schema_path_raw}")
            else:
                schema_path_resolved = str(schema_file)
                try:
                    schema_doc = json.loads(schema_file.read_text())
                except Exception as exc:
                    schema_errors.append(f"invalid schema json ({schema_file}): {exc}")
                    schema_doc = None

                if schema_doc is not None:
                    try:
                        data_doc = json.loads(p_abs.read_text())
                    except Exception as exc:
                        schema_errors.append(f"output is not valid json for schema validation ({p_abs}): {exc}")
                        data_doc = None

                    if data_doc is not None:
                        schema_errors.extend(validate_json_schema(data_doc, schema_doc))

        if schema_errors:
            errors.extend([f"output contract {oid} schema validation failed: {e}" for e in schema_errors])

        outputs[oid] = {
            "id": oid,
            "path": str(p_abs),
            "path_raw": path_raw,
            "kind": kind,
            "schema_path": schema_path_resolved,
            "schema_path_raw": schema_path_raw,
            "schema_errors": schema_errors,
            "required": required,
            "exists": exists,
        }
    return len(errors) == 0, outputs, errors


def run_task_attempt(
    root: Path,
    workdir: Path,
    task: dict,
    profile: dict,
    policy: dict,
    run_dir: Path,
    stage: str,
    attempt_no: int,
    dry_run: bool,
    prev_hash: str,
    receipt_index: int,
) -> tuple[bool, dict, str, int]:
    runner = task.get("runner") or {}
    runner_cmd = str(runner.get("command", "")).strip()
    if not runner_cmd:
        record = {
            "stage": stage,
            "attempt": attempt_no,
            "ok": False,
            "error": "task missing runner.command",
            "task_id": task.get("id"),
        }
        record, new_hash = attach_receipt(record, prev_hash, receipt_index)
        return False, record, new_hash, receipt_index + 1

    env = os.environ.copy()
    env["LACP_HARNESS_TASK_ID"] = str(task.get("id"))
    env["LACP_HARNESS_STAGE"] = stage
    for k, v in (runner.get("env") or {}).items():
        env[str(k)] = str(v)

    runner_shell_cmd = f"cd {json.dumps(str(workdir))} && {runner_cmd}"
    sandbox_args = map_profile_to_sandbox_args(profile, str(task.get("title", task.get("id"))), dry_run)
    cmd = [str(root / "bin/lacp-sandbox-run"), *sandbox_args, "--", "/usr/bin/env", "bash", "-lc", runner_shell_cmd]
    run_cp = run_cmd(cmd, env=env)

    verify_ok = False
    verify_results: list[dict] = []
    if run_cp.returncode == 0:
        verify_ok, verify_results = run_verification_checks(policy, workdir)

    ok = run_cp.returncode == 0 and verify_ok
    record = {
        "task_id": task.get("id"),
        "stage": stage,
        "attempt": attempt_no,
        "ok": ok,
        "runner": {
            "command": runner_cmd,
            "exit_code": run_cp.returncode,
            "stdout": run_cp.stdout[-4000:],
            "stderr": run_cp.stderr[-4000:],
        },
        "verification": {
            "ok": verify_ok,
            "results": verify_results,
        },
    }
    record, new_hash = attach_receipt(record, prev_hash, receipt_index)
    out_file = run_dir / str(task["id"]) / f"{stage}-attempt-{attempt_no:02d}.json"
    out_file.parent.mkdir(parents=True, exist_ok=True)
    out_file.write_text(json.dumps(record, indent=2) + "\n")
    return ok, record, new_hash, receipt_index + 1


def classify_failure(
    *,
    status: str,
    reason: str | None,
    records: list[dict],
    output_errors: list[str],
    input_errors: list[str],
) -> tuple[str | None, str | None]:
    if status == "succeeded":
        return None, None

    if status == "blocked":
        if reason == "input_contract_invalid":
            return "input_contract_invalid", "fix_input_contracts"
        if isinstance(reason, str) and reason.startswith("dependency_failed:"):
            return "dependency_failed", "fix_upstream_dependency"
        return "blocked_unknown", "manual_triage"

    if output_errors:
        schema_related = any("schema validation failed" in str(e).lower() for e in output_errors)
        if schema_related:
            return "schema_mismatch", "fix_artifact_schema_or_payload"
        return "output_contract_invalid", "fix_output_contract"

    if input_errors:
        return "input_contract_invalid", "fix_input_contracts"

    latest_runner: dict | None = None
    for rec in reversed(records):
        runner = rec.get("runner") if isinstance(rec, dict) else None
        if isinstance(runner, dict):
            latest_runner = runner
            break

    if latest_runner is not None:
        exit_code = int(latest_runner.get("exit_code") or 0)
        text = f"{latest_runner.get('stdout') or ''}\n{latest_runner.get('stderr') or ''}".lower()
        if exit_code != 0:
            if "blocked by" in text or exit_code in {8, 9, 10, 11, 12, 13, 14}:
                return "runner_blocked_gate", "review_policy_and_confirmations"
            return "runner_nonzero", "fix_runner_command"

    verify_failed = any(
        isinstance(rec, dict)
        and isinstance(rec.get("verification"), dict)
        and rec.get("verification", {}).get("ok") is False
        for rec in records
    )
    if verify_failed:
        return "verification_fail", "fix_impl_or_verification_checks"

    return "unknown_failure", "manual_triage"


def main() -> int:
    parser = argparse.ArgumentParser(description="Execute harness tasks in dependency order with loop retries.")
    parser.add_argument("--tasks", required=True, help="Path to tasks.json")
    parser.add_argument("--profiles", default="config/harness/sandbox-profiles.yaml", help="Path to sandbox profiles YAML")
    parser.add_argument(
        "--verification",
        default="config/harness/verification-policy.yaml",
        help="Path to verification policy YAML",
    )
    parser.add_argument("--workdir", default=".", help="Working directory for task commands")
    parser.add_argument("--run-id", default="", help="Optional run id")
    parser.add_argument("--continue-on-fail", action="store_true", help="Continue later tasks after failures")
    parser.add_argument("--dry-run", action="store_true", help="Dry run for sandboxed command execution")
    parser.add_argument(
        "--remediation-plan",
        default="",
        help="Optional remediation plan output path (default: <run_dir>/remediation-plan.json)",
    )
    parser.add_argument("--json", action="store_true", help="Emit JSON summary")
    args = parser.parse_args()

    try:
        import yaml  # type: ignore
    except Exception as exc:
        print(f"[lacp] ERROR: missing yaml support: {exc}", file=sys.stderr)
        return 2

    root_env = os.environ.get("LACP_SCRIPT_ROOT", "")
    if not root_env:
        print("[lacp] ERROR: missing LACP_SCRIPT_ROOT", file=sys.stderr)
        return 2
    root = Path(root_env).resolve()
    tasks_file = Path(args.tasks).resolve()
    profiles_file = (root / args.profiles).resolve() if not Path(args.profiles).is_absolute() else Path(args.profiles)
    verification_file = (
        (root / args.verification).resolve() if not Path(args.verification).is_absolute() else Path(args.verification)
    )
    workdir = Path(args.workdir).resolve()
    tasks_dir = tasks_file.parent.resolve()
    run_id = args.run_id.strip() or f"run-{utc_stamp()}-{os.getpid()}"

    validate_cp = run_cmd(
        [
            str(root / "bin/lacp-harness-validate"),
            "--tasks",
            str(tasks_file),
            "--profiles",
            str(profiles_file),
            "--verification",
            str(verification_file),
            "--json",
        ]
    )
    if validate_cp.returncode != 0:
        if args.json:
            payload = {
                "ok": False,
                "error": "harness validation failed",
                "validator_output": validate_cp.stdout,
            }
            print(json.dumps(payload, indent=2))
        else:
            print("[lacp] ERROR: harness validation failed", file=sys.stderr)
            print(validate_cp.stdout, file=sys.stderr)
        return 1

    tasks_payload = json.loads(tasks_file.read_text())
    profiles_payload = yaml.safe_load(profiles_file.read_text())
    verification_payload = yaml.safe_load(verification_file.read_text())
    tasks = topological_order(tasks_payload["tasks"])
    profiles_map = profiles_payload.get("profiles", {})
    verification_map = verification_payload.get("policies", {})

    knowledge_root = Path(os.environ.get("LACP_KNOWLEDGE_ROOT", str(Path.home() / ".lacp/knowledge")))
    run_dir = knowledge_root / "data" / "harness-runs" / run_id
    run_dir.mkdir(parents=True, exist_ok=True)

    summary: list[dict] = []
    remediation_items: list[dict] = []
    succeeded = 0
    failed = 0
    blocked = 0
    receipt_chain_head = ""
    receipt_index = 0

    failed_ids: set[str] = set()
    output_registry: dict[str, dict[str, dict]] = {}
    for task in tasks:
        task_id = str(task["id"])
        deps = task.get("depends_on", [])
        dep_failed = [d for d in deps if d in failed_ids]
        if dep_failed:
            blocked += 1
            failed_ids.add(task_id)
            failure_class, remediation_action = classify_failure(
                status="blocked",
                reason=f"dependency_failed:{','.join(dep_failed)}",
                records=[],
                output_errors=[],
                input_errors=[],
            )
            item = (
                {
                    "task_id": task_id,
                    "status": "blocked",
                    "reason": f"dependency_failed:{','.join(dep_failed)}",
                    "failure_class": failure_class,
                    "remediation_action": remediation_action,
                }
            )
            summary.append(item)
            remediation_items.append(item)
            if not args.continue_on_fail:
                break
            continue

        input_ok, input_resolved, input_errors = validate_expected_inputs(task, deps, output_registry)
        if not input_ok:
            blocked += 1
            failed_ids.add(task_id)
            failure_class, remediation_action = classify_failure(
                status="blocked",
                reason="input_contract_invalid",
                records=[],
                output_errors=[],
                input_errors=input_errors,
            )
            item = (
                {
                    "task_id": task_id,
                    "status": "blocked",
                    "reason": "input_contract_invalid",
                    "input_errors": input_errors,
                    "failure_class": failure_class,
                    "remediation_action": remediation_action,
                }
            )
            summary.append(item)
            remediation_items.append(item)
            if not args.continue_on_fail:
                break
            continue

        profile = profiles_map[task["sandbox_profile"]]
        policy = verification_map[task["verification_policy"]]
        loops = task["iterations"]
        failure_action = str(policy.get("failure_action", "require_human_review"))
        allow_retry = failure_action in {"retry_same_model", "retry_stronger_model"}
        loop2_max = int(loops.get("loop_2_max", 0))
        if failure_action == "retry_stronger_model":
            loop2_max = max(loop2_max, 1)

        task_ok = False
        records: list[dict] = []
        for i in range(1, int(loops["loop_1_max"]) + 1):
            ok, rec, receipt_chain_head, receipt_index = run_task_attempt(
                root,
                workdir,
                task,
                profile,
                policy,
                run_dir,
                "loop1",
                i,
                args.dry_run,
                receipt_chain_head,
                receipt_index,
            )
            records.append(rec)
            if ok:
                task_ok = True
                break
            if not allow_retry:
                break

        if not task_ok and allow_retry:
            for i in range(1, loop2_max + 1):
                ok, rec, receipt_chain_head, receipt_index = run_task_attempt(
                    root,
                    workdir,
                    task,
                    profile,
                    policy,
                    run_dir,
                    "loop2_stronger" if failure_action == "retry_stronger_model" else "loop2",
                    i,
                    args.dry_run,
                    receipt_chain_head,
                    receipt_index,
                )
                records.append(rec)
                if ok:
                    task_ok = True
                    break
                if not allow_retry:
                    break

        if task_ok and int(loops.get("quality_loop_max", 0)) > 0:
            quality_ok = False
            for i in range(1, int(loops["quality_loop_max"]) + 1):
                ok, verify_results = run_verification_checks(policy, workdir)
                rec = {
                    "task_id": task_id,
                    "stage": "quality",
                    "attempt": i,
                    "ok": ok,
                    "verification": {"ok": ok, "results": verify_results},
                }
                rec, receipt_chain_head = attach_receipt(rec, receipt_chain_head, receipt_index)
                receipt_index += 1
                out_file = run_dir / task_id / f"quality-attempt-{i:02d}.json"
                out_file.parent.mkdir(parents=True, exist_ok=True)
                out_file.write_text(json.dumps(rec, indent=2) + "\n")
                records.append(rec)
                if ok:
                    quality_ok = True
                    break
                if not allow_retry:
                    break
            task_ok = quality_ok

        output_errors: list[str] = []
        if task_ok:
            out_ok, out_map, out_errors = collect_expected_outputs(task, workdir, tasks_dir, root)
            output_errors = out_errors
            if out_ok:
                output_registry[task_id] = out_map
            else:
                task_ok = False
                rec = {
                    "task_id": task_id,
                    "stage": "output_contract",
                    "attempt": 1,
                    "ok": False,
                    "error": "output_contract_invalid",
                    "errors": out_errors,
                }
                rec, receipt_chain_head = attach_receipt(rec, receipt_chain_head, receipt_index)
                receipt_index += 1
                out_file = run_dir / task_id / "output-contract.json"
                out_file.parent.mkdir(parents=True, exist_ok=True)
                out_file.write_text(json.dumps(rec, indent=2) + "\n")
                records.append(rec)

        if task_ok:
            succeeded += 1
            status = "succeeded"
            failure_class, remediation_action = None, None
        else:
            failed += 1
            failed_ids.add(task_id)
            status = "failed"
            failure_class, remediation_action = classify_failure(
                status=status,
                reason=None,
                records=records,
                output_errors=output_errors,
                input_errors=[],
            )
            if not args.continue_on_fail:
                item = (
                    {
                        "task_id": task_id,
                        "status": status,
                        "attempts": len(records),
                        "failure_action": failure_action,
                        "failure_class": failure_class,
                        "remediation_action": remediation_action,
                        "input_contracts": input_resolved,
                        "output_errors": output_errors,
                    }
                )
                summary.append(item)
                remediation_items.append(item)
                break

        item = (
            {
                "task_id": task_id,
                "status": status,
                "attempts": len(records),
                "failure_action": failure_action,
                "failure_class": failure_class,
                "remediation_action": remediation_action,
                "input_contracts": input_resolved,
                "output_errors": output_errors,
            }
        )
        summary.append(item)
        if status != "succeeded":
            remediation_items.append(item)

    ok = failed == 0 and blocked == 0
    payload = {
        "ok": ok,
        "run_id": run_id,
        "run_dir": str(run_dir),
        "summary": {
            "total": len(tasks),
            "succeeded": succeeded,
            "failed": failed,
            "blocked": blocked,
            "receipts_total": receipt_index,
            "receipt_chain_head": receipt_chain_head,
        },
        "tasks": summary,
    }
    (run_dir / "summary.json").write_text(json.dumps(payload, indent=2) + "\n")

    class_counts: dict[str, int] = {}
    for item in remediation_items:
        key = str(item.get("failure_class") or "unknown")
        class_counts[key] = class_counts.get(key, 0) + 1
    remediation_plan = {
        "ok": ok,
        "run_id": run_id,
        "run_dir": str(run_dir),
        "generated_at_utc": dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "summary": {
            "items": len(remediation_items),
            "class_counts": class_counts,
        },
        "tasks": remediation_items,
    }
    remediation_path = Path(args.remediation_plan).resolve() if args.remediation_plan else (run_dir / "remediation-plan.json")
    remediation_path.parent.mkdir(parents=True, exist_ok=True)
    remediation_path.write_text(json.dumps(remediation_plan, indent=2) + "\n")

    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"[lacp] harness run {run_id} complete: ok={str(ok).lower()} succeeded={succeeded} failed={failed} blocked={blocked}")
        print(f"[lacp] artifacts={run_dir}")

    return 0 if ok else 1


if __name__ == "__main__":
    raise SystemExit(main())
