#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-tui

Interactive control panel with Dashboard, Brain, Doctor, Hooks, and Runs tabs.

Keybindings:
  d  Dashboard   b  Brain   o  Doctor   h  Hooks   u  Runs   r  Refresh   q  Quit
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
  usage
  exit 0
fi

require_cmd python3

if command -v uv >/dev/null 2>&1; then
  exec uv run --with textual python3 "${ROOT}/scripts/tui/app.py" "$@"
else
  if ! python3 -c "import textual" 2>/dev/null; then
    die "textual not installed. Install with: pip install textual  (or install uv for zero-setup)"
  fi
  exec python3 "${ROOT}/scripts/tui/app.py" "$@"
fi
