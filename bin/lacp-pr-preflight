#!/usr/bin/env bash
set -euo pipefail

LACP_SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export LACP_SCRIPT_ROOT

python3 - "$@" <<'PY'
from __future__ import annotations

import argparse
import fnmatch
import json
import os
import subprocess
import sys
from pathlib import Path


def run_cmd(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, capture_output=True, text=True)


def load_json(path: Path):
    return json.loads(path.read_text())


def normalize_changed_files(repo_root: Path, changed_files: list[str]) -> list[str]:
    out: list[str] = []
    for value in changed_files:
        v = value.strip()
        if not v:
            continue
        p = Path(v)
        if p.is_absolute():
            try:
                v = str(p.resolve().relative_to(repo_root))
            except Exception:
                v = str(p.resolve())
        out.append(v)
    return sorted(set(out))


def tier_rank(tier: str) -> int:
    return {"low": 1, "medium": 2, "high": 3}.get(tier, 0)


def pick_risk_tier(changed_files: list[str], tier_rules: dict[str, list[str]]) -> str:
    best = "low"
    for file_path in changed_files:
        for tier, globs in tier_rules.items():
            if any(fnmatch.fnmatch(file_path, pattern) for pattern in globs):
                if tier_rank(tier) > tier_rank(best):
                    best = tier
    return best


def parse_check_runs(payload) -> list[dict]:
    if isinstance(payload, dict) and isinstance(payload.get("check_runs"), list):
        return [x for x in payload["check_runs"] if isinstance(x, dict)]
    if isinstance(payload, list):
        return [x for x in payload if isinstance(x, dict)]
    return []


def check_run_ok(check: dict) -> bool:
    status = str(check.get("status", "")).lower()
    conclusion = str(check.get("conclusion", "")).lower()
    if status in {"completed", "success"} and conclusion in {"success", "neutral", "skipped", ""}:
        return True
    if conclusion == "success":
        return True
    return False


def canonical_sha(value: str) -> str:
    return value.strip().lower()


def evidence_required(cfg: dict, risk_tier: str, changed_files: list[str]) -> bool:
    tiers = set(cfg.get("requiredTiers") or [])
    if risk_tier not in tiers:
        return False
    globs = [x for x in (cfg.get("requiredMatchGlobs") or []) if isinstance(x, str) and x]
    if not globs:
        return True
    return any(any(fnmatch.fnmatch(f, g) for g in globs) for f in changed_files)


def validate_manifest(
    *,
    root_env: Path,
    cfg: dict,
    manifest_path: Path,
) -> tuple[bool, dict]:
    schema_rel = str(cfg.get("manifestSchema", "config/harness/browser-evidence.schema.json"))
    schema_path = Path(schema_rel)
    if not schema_path.is_absolute():
        schema_path = (root_env / schema_path).resolve()

    cmd = [
        str(root_env / "bin/lacp-browser-evidence-validate"),
        "--manifest",
        str(manifest_path),
        "--schema",
        str(schema_path),
        "--max-age-hours",
        str(int(cfg.get("maxArtifactAgeHours", 24))),
        "--json",
    ]
    for kind in cfg.get("requiredEntrypointKinds", []):
        cmd.extend(["--required-entrypoint-kind", str(kind)])
    cp = run_cmd(cmd)
    try:
        details = json.loads(cp.stdout) if cp.stdout.strip() else {}
    except Exception:
        details = {"raw_output": cp.stdout, "stderr": cp.stderr}

    ok = cp.returncode == 0

    # Additional semantic gates beyond schema validator.
    try:
        payload = load_json(manifest_path)
    except Exception as exc:
        ok = False
        details.setdefault("extra_errors", []).append(f"failed to parse manifest for extra checks: {exc}")
        return ok, details

    flows = payload.get("flows") if isinstance(payload, dict) else []
    if not isinstance(flows, list):
        flows = []

    prefixes = [x for x in (cfg.get("requiredEntrypointPrefixes") or []) if isinstance(x, str) and x]
    if prefixes:
        has_prefix = False
        for flow in flows:
            if not isinstance(flow, dict):
                continue
            entry = flow.get("entrypoint")
            if isinstance(entry, str) and any(entry.startswith(p) for p in prefixes):
                has_prefix = True
                break
        if not has_prefix:
            ok = False
            details.setdefault("extra_errors", []).append(
                f"missing required entrypoint prefix; expected one of: {prefixes}"
            )

    substrings_any = [x.lower() for x in (cfg.get("requiredAssertionSubstringsAny") or []) if isinstance(x, str) and x]
    if substrings_any:
        names: list[str] = []
        for flow in flows:
            if not isinstance(flow, dict):
                continue
            assertions = flow.get("assertions")
            if isinstance(assertions, list):
                for a in assertions:
                    if isinstance(a, dict) and isinstance(a.get("name"), str):
                        names.append(a["name"].lower())
        if not any(any(token in name for token in substrings_any) for name in names):
            ok = False
            details.setdefault("extra_errors", []).append(
                f"missing assertion containing any of: {substrings_any}"
            )

    return ok, details


def main() -> int:
    parser = argparse.ArgumentParser(description="LACP PR preflight gate planner/validator")
    parser.add_argument("--contract", default="config/risk-policy-contract.json", help="Risk policy contract path")
    parser.add_argument("--schema", default="config/risk-policy-contract.schema.json", help="Contract schema path")
    parser.add_argument("--changed-files", default="", help="Newline file with changed paths")
    parser.add_argument("--from-ref", default="", help="Git from ref for changed files")
    parser.add_argument("--to-ref", default="HEAD", help="Git to ref for changed files")
    parser.add_argument("--head-sha", default="", help="PR head sha; defaults to current HEAD")
    parser.add_argument("--checks-json", default="", help="Optional checks payload JSON")
    parser.add_argument("--review-json", default="", help="Optional review-agent state JSON")
    parser.add_argument("--browser-evidence", default="", help="Optional browser evidence manifest JSON")
    parser.add_argument("--api-evidence", default="", help="Optional API evidence manifest JSON")
    parser.add_argument("--contract-evidence", default="", help="Optional contract evidence manifest JSON")
    parser.add_argument("--auto-e2e-run", action="store_true", help="Auto-run local e2e to generate browser evidence when missing")
    parser.add_argument("--auto-e2e-command", default="", help="Command used by lacp e2e run (example: npx playwright test)")
    parser.add_argument("--auto-e2e-flows-file", default="", help="Flow metadata JSON used by lacp e2e run")
    parser.add_argument("--auto-e2e-manifest", default=".lacp/browser-evidence.auto.json", help="Output manifest path for auto e2e")
    parser.add_argument("--auto-e2e-skip-command", action="store_true", help="Skip execution and only materialize manifest")
    parser.add_argument("--auto-e2e-auth-check", action="store_true", help="Run lacp e2e auth-check after auto e2e run")
    parser.add_argument(
        "--auto-e2e-auth-require-assertion-substring",
        action="append",
        default=[],
        help="Auth-check required assertion substring (repeatable)",
    )
    parser.add_argument("--repo-root", default=".", help="Repo root path")
    parser.add_argument("--json", action="store_true", help="Emit JSON")
    args = parser.parse_args()

    root_env = Path(os.environ.get("LACP_SCRIPT_ROOT", ".")).resolve()
    repo_root = Path(args.repo_root).resolve()

    contract_path = Path(args.contract)
    if not contract_path.is_absolute():
        contract_path = (root_env / contract_path).resolve()
    schema_path = Path(args.schema)
    if not schema_path.is_absolute():
        schema_path = (root_env / schema_path).resolve()

    errors: list[str] = []
    warnings: list[str] = []

    if not contract_path.is_file():
        errors.append(f"missing contract: {contract_path}")
    if not schema_path.is_file():
        errors.append(f"missing schema: {schema_path}")

    contract = {}
    if not errors:
        try:
            contract = load_json(contract_path)
            _ = load_json(schema_path)
        except Exception as exc:
            errors.append(f"invalid contract/schema json: {exc}")

    changed_files: list[str] = []
    if args.changed_files:
        changed_path = Path(args.changed_files).resolve()
        if not changed_path.is_file():
            errors.append(f"missing changed-files input: {changed_path}")
        else:
            changed_files = changed_path.read_text().splitlines()
    elif args.from_ref:
        cp = run_cmd(["git", "-C", str(repo_root), "diff", "--name-only", args.from_ref, args.to_ref])
        if cp.returncode != 0:
            errors.append(f"git diff failed: {cp.stderr.strip()}")
        else:
            changed_files = cp.stdout.splitlines()
    else:
        cp = run_cmd(["git", "-C", str(repo_root), "diff", "--name-only", "HEAD~1", args.to_ref])
        if cp.returncode == 0:
            changed_files = cp.stdout.splitlines()
        else:
            warnings.append("could not infer changed files from HEAD~1; provide --changed-files or --from-ref")

    changed_files = normalize_changed_files(repo_root, changed_files)
    if not changed_files:
        warnings.append("changed file set is empty")

    if args.head_sha:
        head_sha = canonical_sha(args.head_sha)
    else:
        cp = run_cmd(["git", "-C", str(repo_root), "rev-parse", "HEAD"])
        if cp.returncode != 0:
            errors.append("unable to determine head sha")
            head_sha = ""
        else:
            head_sha = canonical_sha(cp.stdout)

    risk_tier = "low"
    required_checks: list[str] = []
    docs_drift_ok = True
    docs_drift_hits: list[dict] = []
    checks_ok = True
    missing_checks: list[str] = []
    failed_checks: list[str] = []
    stale_checks: list[str] = []
    review_required = False
    review_ok = True

    browser_required = False
    browser_ok = True
    browser_details: dict = {}
    auto_e2e_details: dict = {}

    api_required = False
    api_ok = True
    api_details: dict = {}

    contract_required = False
    contract_ok = True
    contract_details: dict = {}

    if isinstance(contract, dict):
        tier_rules = contract.get("riskTierRules") or {}
        merge_policy = contract.get("mergePolicy") or {}
        docs_rules = contract.get("docsDriftRules") or []
        review_cfg = contract.get("reviewAgent") or {}
        browser_cfg = contract.get("browserEvidence") or {}
        api_cfg = contract.get("apiEvidence") or {}
        contract_cfg = contract.get("contractEvidence") or {}

        if not isinstance(tier_rules, dict):
            errors.append("contract.riskTierRules must be object")
            tier_rules = {}
        if not isinstance(merge_policy, dict):
            errors.append("contract.mergePolicy must be object")
            merge_policy = {}
        if not isinstance(docs_rules, list):
            errors.append("contract.docsDriftRules must be array")
            docs_rules = []

        safe_rules = {
            "high": list(tier_rules.get("high") or []),
            "medium": list(tier_rules.get("medium") or []),
            "low": list(tier_rules.get("low") or ["**"]),
        }

        risk_tier = pick_risk_tier(changed_files, safe_rules)
        required_checks = list((merge_policy.get(risk_tier) or {}).get("requiredChecks") or [])

        for idx, rule in enumerate(docs_rules):
            if not isinstance(rule, dict):
                continue
            match_globs = [x for x in (rule.get("match") or []) if isinstance(x, str) and x]
            requires_any = [x for x in (rule.get("requiresAny") or []) if isinstance(x, str) and x]
            if not match_globs or not requires_any:
                continue
            triggered = [f for f in changed_files if any(fnmatch.fnmatch(f, pat) for pat in match_globs)]
            if not triggered:
                continue
            satisfied = any(req in changed_files for req in requires_any)
            docs_drift_hits.append(
                {
                    "rule_index": idx,
                    "triggered_by": triggered,
                    "requires_any": requires_any,
                    "satisfied": satisfied,
                }
            )
            if not satisfied:
                docs_drift_ok = False

        review_required = risk_tier in set(review_cfg.get("requiredTiers") or [])
        browser_required = evidence_required(browser_cfg if isinstance(browser_cfg, dict) else {}, risk_tier, changed_files)
        api_required = evidence_required(api_cfg if isinstance(api_cfg, dict) else {}, risk_tier, changed_files)
        contract_required = evidence_required(contract_cfg if isinstance(contract_cfg, dict) else {}, risk_tier, changed_files)

        if args.checks_json:
            checks_path = Path(args.checks_json).resolve()
            if not checks_path.is_file():
                errors.append(f"missing checks json: {checks_path}")
            else:
                checks_payload = load_json(checks_path)
                check_runs = parse_check_runs(checks_payload)
                check_by_name: dict[str, list[dict]] = {}
                for run in check_runs:
                    name = str(run.get("name", "")).strip()
                    if not name:
                        continue
                    check_by_name.setdefault(name, []).append(run)

                for req in required_checks:
                    candidates = check_by_name.get(req, [])
                    if not candidates:
                        checks_ok = False
                        missing_checks.append(req)
                        continue

                    fresh: list[dict] = []
                    stale: list[dict] = []
                    for c in candidates:
                        run_sha = canonical_sha(str(c.get("head_sha", "") or c.get("sha", "")))
                        if head_sha and run_sha and run_sha != head_sha:
                            stale.append(c)
                        else:
                            fresh.append(c)

                    if stale:
                        stale_checks.append(req)

                    target = fresh[-1] if fresh else None
                    if target is None:
                        checks_ok = False
                        failed_checks.append(f"{req}:stale-only")
                    elif not check_run_ok(target):
                        checks_ok = False
                        failed_checks.append(f"{req}:{target.get('conclusion', target.get('status', 'unknown'))}")

        if review_required:
            if not args.review_json:
                review_ok = False
                errors.append("review required for this tier but --review-json not provided")
            else:
                review_path = Path(args.review_json).resolve()
                if not review_path.is_file():
                    review_ok = False
                    errors.append(f"missing review json: {review_path}")
                else:
                    review_state = load_json(review_path)
                    review_sha = canonical_sha(str(review_state.get("head_sha", "")))
                    review_status = str(review_state.get("status", "")).lower()
                    actionable = int(review_state.get("actionable_findings", 0) or 0)

                    if bool(review_cfg.get("mustMatchHeadSha", True)) and head_sha and review_sha and review_sha != head_sha:
                        review_ok = False
                        errors.append("review state is stale for current head sha")
                    if review_status not in {"success", "completed", "clean"}:
                        review_ok = False
                        errors.append(f"review status not clean: {review_status or 'missing'}")
                    if actionable > 0:
                        review_ok = False
                        errors.append(f"review actionable findings: {actionable}")

        # Browser evidence with optional auto-run
        if browser_required:
            evidence_input = args.browser_evidence.strip()
            if not evidence_input and args.auto_e2e_run:
                auto_cmd = args.auto_e2e_command.strip() or "npx playwright test"
                if not args.auto_e2e_flows_file.strip():
                    browser_ok = False
                    errors.append("auto e2e enabled but --auto-e2e-flows-file not provided")
                else:
                    flows_path = Path(args.auto_e2e_flows_file).resolve()
                    manifest_path = Path(args.auto_e2e_manifest)
                    if not manifest_path.is_absolute():
                        manifest_path = (repo_root / manifest_path).resolve()
                    auto_cmd_args = [
                        str(root_env / "bin/lacp-e2e"),
                        "run",
                        "--command",
                        auto_cmd,
                        "--workdir",
                        str(repo_root),
                        "--flows-file",
                        str(flows_path),
                        "--manifest",
                        str(manifest_path),
                        "--json",
                    ]
                    if args.auto_e2e_skip_command:
                        auto_cmd_args.append("--skip-command")
                    cp = run_cmd(auto_cmd_args)
                    try:
                        auto_e2e_details = json.loads(cp.stdout) if cp.stdout.strip() else {}
                    except Exception:
                        auto_e2e_details = {"raw_output": cp.stdout, "stderr": cp.stderr}
                    if cp.returncode != 0:
                        browser_ok = False
                        errors.append("auto e2e run failed")
                    else:
                        evidence_input = str(manifest_path)

                    if cp.returncode == 0 and args.auto_e2e_auth_check:
                        auth_cmd = [
                            str(root_env / "bin/lacp-e2e"),
                            "auth-check",
                            "--manifest",
                            str(manifest_path),
                            "--json",
                        ]
                        for token in args.auto_e2e_auth_require_assertion_substring:
                            auth_cmd.extend(["--require-assertion-substring", token])
                        auth_cp = run_cmd(auth_cmd)
                        try:
                            auto_e2e_details["auth_check"] = json.loads(auth_cp.stdout) if auth_cp.stdout.strip() else {}
                        except Exception:
                            auto_e2e_details["auth_check"] = {"raw_output": auth_cp.stdout, "stderr": auth_cp.stderr}
                        if auth_cp.returncode != 0:
                            browser_ok = False
                            errors.append("auto e2e auth-check failed")

            if not evidence_input:
                browser_ok = False
                errors.append("browser evidence required for this scope but --browser-evidence not provided")
            else:
                evidence_path = Path(evidence_input).resolve()
                if not evidence_path.is_file():
                    browser_ok = False
                    errors.append(f"missing browser evidence manifest: {evidence_path}")
                else:
                    browser_ok, browser_details = validate_manifest(root_env=root_env, cfg=browser_cfg, manifest_path=evidence_path)
                    if not browser_ok:
                        errors.append("browser evidence validation failed")

        if api_required:
            api_input = args.api_evidence.strip()
            if not api_input:
                api_ok = False
                errors.append("api evidence required for this scope but --api-evidence not provided")
            else:
                p = Path(api_input).resolve()
                if not p.is_file():
                    api_ok = False
                    errors.append(f"missing api evidence manifest: {p}")
                else:
                    api_ok, api_details = validate_manifest(root_env=root_env, cfg=api_cfg, manifest_path=p)
                    if not api_ok:
                        errors.append("api evidence validation failed")

        if contract_required:
            contract_input = args.contract_evidence.strip()
            if not contract_input:
                contract_ok = False
                errors.append("contract evidence required for this scope but --contract-evidence not provided")
            else:
                p = Path(contract_input).resolve()
                if not p.is_file():
                    contract_ok = False
                    errors.append(f"missing contract evidence manifest: {p}")
                else:
                    contract_ok, contract_details = validate_manifest(root_env=root_env, cfg=contract_cfg, manifest_path=p)
                    if not contract_ok:
                        errors.append("contract evidence validation failed")

    gate_ok = (
        len(errors) == 0
        and docs_drift_ok
        and checks_ok
        and review_ok
        and browser_ok
        and api_ok
        and contract_ok
    )

    payload = {
        "ok": gate_ok,
        "head_sha": head_sha,
        "risk_tier": risk_tier,
        "changed_files": changed_files,
        "required_checks": required_checks,
        "docs_drift": {
            "ok": docs_drift_ok,
            "rules": docs_drift_hits,
        },
        "checks": {
            "ok": checks_ok,
            "missing": missing_checks,
            "failed": failed_checks,
            "stale": stale_checks,
        },
        "review": {
            "required": review_required,
            "ok": review_ok,
        },
        "browser_evidence": {
            "required": browser_required,
            "ok": browser_ok,
            "details": browser_details,
            "auto_e2e": auto_e2e_details,
        },
        "api_evidence": {
            "required": api_required,
            "ok": api_ok,
            "details": api_details,
        },
        "contract_evidence": {
            "required": contract_required,
            "ok": contract_ok,
            "details": contract_details,
        },
        "errors": errors,
        "warnings": warnings,
    }

    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        if gate_ok:
            print(f"[lacp] preflight passed (tier={risk_tier})")
        else:
            print(f"[lacp] preflight failed (tier={risk_tier})", file=sys.stderr)
            for item in errors:
                print(f" - {item}", file=sys.stderr)

    return 0 if gate_ok else 1


if __name__ == "__main__":
    raise SystemExit(main())
PY
