#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-unadopt-local [options]

Remove LACP-managed local wrappers for `claude` and `codex`.

Options:
  --bin-dir <dir>  Wrapper directory (default: $HOME/.local/bin)
  --dry-run        Print actions only
  --json           Emit JSON summary
  -h, --help       Show help
EOF
}

BIN_DIR="${HOME}/.local/bin"
DRY_RUN=0
AS_JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --bin-dir) BIN_DIR="$2"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --json) AS_JSON=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown argument: $1" ;;
  esac
done

is_managed_wrapper() {
  local path="$1"
  [[ -f "${path}" ]] || return 1
  rg -q 'LACP_MANAGED_WRAPPER=1' "${path}"
}

declare -a EVENTS=()
log_event() {
  EVENTS+=("$1")
  if [[ "${AS_JSON}" -eq 0 ]]; then
    log "$1"
  fi
}

restore_one() {
  local cmd_name="$1"
  local wrapper_path="${BIN_DIR}/${cmd_name}"
  local native_backup="${BIN_DIR}/${cmd_name}.native"

  if [[ ! -e "${wrapper_path}" ]]; then
    log_event "skip_missing_wrapper:${wrapper_path}"
    return 0
  fi
  if ! is_managed_wrapper "${wrapper_path}"; then
    log_event "skip_non_managed_wrapper:${wrapper_path}"
    return 0
  fi

  if [[ -e "${native_backup}" ]]; then
    if [[ "${DRY_RUN}" -eq 1 ]]; then
      log_event "restore:${native_backup} -> ${wrapper_path}"
    else
      rm -f "${wrapper_path}"
      mv "${native_backup}" "${wrapper_path}"
      log_event "restored:${wrapper_path}"
    fi
  else
    if [[ "${DRY_RUN}" -eq 1 ]]; then
      log_event "remove_wrapper:${wrapper_path}"
    else
      rm -f "${wrapper_path}"
      log_event "removed:${wrapper_path}"
    fi
  fi
}

restore_one "claude"
restore_one "codex"

if [[ "${AS_JSON}" -eq 1 ]]; then
  jq -n \
    --arg bin_dir "${BIN_DIR}" \
    --argjson dry_run "$([[ "${DRY_RUN}" -eq 1 ]] && echo true || echo false)" \
    --argjson events "$(printf '%s\n' "${EVENTS[@]}" | jq -R . | jq -s .)" \
    '{
      ok: true,
      bin_dir: $bin_dir,
      dry_run: $dry_run,
      events: $events
    }'
fi
