#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage:
  lacp-mcp-profile list [--json]
  lacp-mcp-profile status [--json]
  lacp-mcp-profile apply --profile cli-first|mcp-selective|mcp-heavy [--dry-run] [--json]

Applies MCP operating profiles with CLI-first defaults and bounded MCP budgets.
EOF
}

SUB="${1:-}"
if [[ -z "${SUB}" || "${SUB}" == "-h" || "${SUB}" == "--help" || "${SUB}" == "help" ]]; then
  usage
  exit 0
fi
shift || true

PROFILES_FILE="${ROOT}/config/mcp-profiles.json"
ENV_FILE="${ROOT}/.env"
AS_JSON=0
DRY_RUN=0
PROFILE_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile) PROFILE_NAME="$2"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --json) AS_JSON=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown argument: $1" ;;
  esac
done

require_cmd jq
require_cmd python3
require_file "${PROFILES_FILE}"

list_profiles_json() {
  python3 - <<'PY' "${PROFILES_FILE}"
import json
import sys
from pathlib import Path

payload = json.loads(Path(sys.argv[1]).read_text())
items = []
for item in payload.get("profiles", []):
    items.append(
        {
            "name": item.get("name"),
            "description": item.get("description", ""),
            "env_keys": sorted((item.get("env") or {}).keys()),
        }
    )
print(json.dumps(items))
PY
}

status_json() {
  jq -n \
    --arg mode "${LACP_MCP_MODE}" \
    --argjson max_servers "${LACP_MCP_MAX_CONNECTED_SERVERS}" \
    --argjson max_tool_defs "${LACP_MCP_MAX_TOOL_DEFINITIONS}" \
    --arg require_allowlist "${LACP_MCP_REQUIRE_SERVER_ALLOWLIST}" \
    --arg use_tool_search "${LACP_MCP_USE_TOOL_SEARCH}" \
    --arg defer_tool_loading "${LACP_MCP_DEFER_TOOL_LOADING}" \
    --arg prefer_cli_first "${LACP_MCP_PREFER_CLI_FIRST}" \
    --arg auth_policy_file "${LACP_MCP_AUTH_POLICY_FILE}" \
    '{
      schema_version: "1",
      kind: "mcp_profile_status",
      ok: true,
      profile: {
        mode: $mode,
        max_connected_servers: ($max_servers|tonumber),
        max_tool_definitions: ($max_tool_defs|tonumber),
        require_server_allowlist: ($require_allowlist == "true"),
        use_tool_search: ($use_tool_search == "true"),
        defer_tool_loading: ($defer_tool_loading == "true"),
        prefer_cli_first: ($prefer_cli_first == "true")
      },
      auth_policy_file: $auth_policy_file
    }'
}

case "${SUB}" in
  list)
    profiles_json="$(list_profiles_json)"
    if [[ "${AS_JSON}" -eq 1 ]]; then
      jq -n --argjson profiles "${profiles_json}" '{schema_version:"1", kind:"mcp_profile_list", ok:true, profiles:$profiles}'
    else
      echo "${profiles_json}" | jq -r '.[] | "\(.name)\t\(.description)"'
    fi
    ;;
  status)
    out="$(status_json)"
    if [[ "${AS_JSON}" -eq 1 ]]; then
      printf '%s\n' "${out}"
    else
      echo "${out}" | jq -r '"mode=\(.profile.mode) servers=\(.profile.max_connected_servers) tool_defs=\(.profile.max_tool_definitions) allowlist=\(.profile.require_server_allowlist) defer=\(.profile.defer_tool_loading) cli_first=\(.profile.prefer_cli_first)"'
    fi
    ;;
  apply)
    [[ -n "${PROFILE_NAME}" ]] || die "--profile is required for apply"
    [[ -f "${ENV_FILE}" ]] || cp "${ROOT}/config/lacp.env.example" "${ENV_FILE}"

    result_json="$(python3 - <<'PY' "${PROFILES_FILE}" "${PROFILE_NAME}" "${ENV_FILE}" "${LACP_MCP_AUTH_POLICY_FILE}" "${DRY_RUN}"
import json
import pathlib
import re
import sys

profiles_file = pathlib.Path(sys.argv[1])
profile_name = sys.argv[2]
env_file = pathlib.Path(sys.argv[3])
auth_policy_file = pathlib.Path(sys.argv[4])
dry_run = sys.argv[5] == "1"

profiles_payload = json.loads(profiles_file.read_text())
profiles = profiles_payload.get("profiles", [])
selected = None
for item in profiles:
    if item.get("name") == profile_name:
        selected = item
        break
if not isinstance(selected, dict):
    raise SystemExit(f"unknown profile: {profile_name}")

env_updates = selected.get("env", {})
auth_patch = selected.get("mcp_auth_policy_patch", {})

def deep_merge(base, override):
    if not isinstance(base, dict) or not isinstance(override, dict):
        return override
    out = dict(base)
    for key, value in override.items():
        if key in out and isinstance(out[key], dict) and isinstance(value, dict):
            out[key] = deep_merge(out[key], value)
        else:
            out[key] = value
    return out

original_env = env_file.read_text() if env_file.exists() else ""
env_lines = original_env.splitlines()
for key, value in env_updates.items():
    pat = re.compile(rf"^{re.escape(key)}=")
    replaced = False
    for i, line in enumerate(env_lines):
        if pat.match(line):
            env_lines[i] = f'{key}="{value}"'
            replaced = True
            break
    if not replaced:
        env_lines.append(f'{key}="{value}"')
new_env = "\n".join(env_lines).strip() + "\n"

original_auth = {}
if auth_policy_file.exists():
    original_auth = json.loads(auth_policy_file.read_text())
merged_auth = deep_merge(original_auth, auth_patch)

if not dry_run:
    env_file.write_text(new_env)
    auth_policy_file.write_text(json.dumps(merged_auth, indent=2) + "\n")

result = {
    "schema_version": "1",
    "kind": "mcp_profile_apply",
    "ok": True,
    "profile": profile_name,
    "description": selected.get("description", ""),
    "dry_run": dry_run,
    "env_file": str(env_file),
    "auth_policy_file": str(auth_policy_file),
    "env_changed": original_env != new_env,
    "auth_policy_changed": original_auth != merged_auth,
    "env_updates": env_updates,
}
print(json.dumps(result))
PY
)"

    if [[ "${AS_JSON}" -eq 1 ]]; then
      printf '%s\n' "${result_json}"
    else
      echo "${result_json}" | jq -r '"mcp-profile applied: \(.profile) dry_run=\(.dry_run) env_changed=\(.env_changed) auth_policy_changed=\(.auth_policy_changed)"'
    fi
    ;;
  *)
    die "Unknown subcommand: ${SUB}"
    ;;
esac
