#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-install [--profile starter|existing] [--with-verify] [--hours N] [--force-scaffold] [--no-auto-deps] [--auto-deps-dry-run] [--auto-deps-force] [--with-obsidian-setup] [--no-obsidian-setup] [--no-auto-adopt] [--no-auto-hook-optimize]

Bootstraps LACP for first-time users.

Profiles:
  starter   Create safe local stub automation scripts when missing.
  existing  Do not scaffold automation scripts.

Notes:
  - Creates .env from config/lacp.env.example if missing.
  - Applies `starter` policy pack by default for starter profile when `.env` is managed.
  - Ensures root/data directories exist.
  - Runs lacp-onboard at the end (optionally with verify).
  - On macOS, dependency auto-detection is enabled by default and can install missing Homebrew formulas/casks plus npm global packages (including qmd).
  - Obsidian vault bootstrap is enabled by default and creates/syncs core `~/obsidian/nyk` links used by brain tooling.
EOF
}

PROFILE="starter"
WITH_VERIFY=0
HOURS="${LACP_VERIFY_HOURS}"
FORCE_SCAFFOLD=0
AUTO_DEPS=1
AUTO_DEPS_DRY_RUN=0
AUTO_DEPS_FORCE=0
OBSIDIAN_SETUP=1
AUTO_ADOPT=1
AUTO_HOOK_OPTIMIZE=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE="$2"
      shift 2
      ;;
    --with-verify)
      WITH_VERIFY=1
      shift
      ;;
    --hours)
      HOURS="$2"
      shift 2
      ;;
    --force-scaffold)
      FORCE_SCAFFOLD=1
      shift
      ;;
    --auto-deps)
      AUTO_DEPS=1
      shift
      ;;
    --no-auto-deps)
      AUTO_DEPS=0
      shift
      ;;
    --auto-deps-dry-run)
      AUTO_DEPS=1
      AUTO_DEPS_DRY_RUN=1
      shift
      ;;
    --auto-deps-force)
      AUTO_DEPS_FORCE=1
      shift
      ;;
    --with-obsidian-setup)
      OBSIDIAN_SETUP=1
      shift
      ;;
    --no-obsidian-setup)
      OBSIDIAN_SETUP=0
      shift
      ;;
    --no-auto-adopt)
      AUTO_ADOPT=0
      shift
      ;;
    --no-auto-hook-optimize)
      AUTO_HOOK_OPTIMIZE=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

case "${PROFILE}" in
  starter|existing) ;;
  *) die "--profile must be starter|existing" ;;
esac

if [[ "${AUTO_DEPS}" -eq 1 ]]; then
  lacp_auto_install_deps "$([[ "${AUTO_DEPS_DRY_RUN}" -eq 1 ]] && echo true || echo false)" "$([[ "${AUTO_DEPS_FORCE}" -eq 1 ]] && echo true || echo false)"
fi

setup_obsidian_vault() {
  local vault_root="${HOME}/obsidian/nyk"
  local docs_root="${HOME}/docs"
  local sessions_root="${HOME}/control/sessions"
  local skills_root="${HOME}/control/skills"
  local automation_scripts="${LACP_AUTOMATION_ROOT}/scripts"

  mkdir -p "${vault_root}"
  mkdir -p "${vault_root}/.obsidian"
  mkdir -p "${vault_root}/00-home/daily" "${vault_root}/atlas" "${vault_root}/inbox" "${vault_root}/voice-notes" "${vault_root}/_generated"

  mkdir -p "${docs_root}" "${sessions_root}" "${skills_root}" "${automation_scripts}"

  link_or_keep() {
    local target="$1"
    local source="$2"
    if [[ -L "${target}" ]]; then
      ln -sfn "${source}" "${target}"
      log "Updated symlink: ${target} -> ${source}"
      return 0
    fi
    if [[ -e "${target}" ]]; then
      log "Keeping existing path (not symlink): ${target}"
      return 0
    fi
    ln -s "${source}" "${target}"
    log "Created symlink: ${target} -> ${source}"
  }

  link_or_keep "${vault_root}/sessions" "${sessions_root}"
  link_or_keep "${vault_root}/skills" "${skills_root}"
  link_or_keep "${vault_root}/knowledge" "${LACP_KNOWLEDGE_ROOT}"
  link_or_keep "${vault_root}/docs" "${docs_root}"
  link_or_keep "${vault_root}/automation-scripts" "${automation_scripts}"
}

if [[ ! -f "${ROOT}/.env" ]]; then
  if [[ "${LACP_SKIP_DOTENV:-0}" == "1" ]]; then
    log "Skipped .env creation because LACP_SKIP_DOTENV=1"
  else
    cp "${ROOT}/config/lacp.env.example" "${ROOT}/.env"
    log "Created ${ROOT}/.env from template"
  fi
fi

if [[ "${PROFILE}" == "starter" && "${LACP_SKIP_DOTENV:-0}" != "1" && -f "${ROOT}/.env" ]]; then
  "${ROOT}/bin/lacp-policy-pack" apply --pack starter >/dev/null
  log "Applied policy pack: starter"
fi

mkdir -p "${LACP_AUTOMATION_ROOT}" "${LACP_KNOWLEDGE_ROOT}" "${LACP_DRAFTS_ROOT}"
mkdir -p "${LACP_AUTOMATION_ROOT}/scripts"
mkdir -p "${LACP_AUTOMATION_ROOT}/data/snapshots"
mkdir -p "${LACP_KNOWLEDGE_ROOT}/data/benchmarks"
mkdir -p "${LACP_KNOWLEDGE_ROOT}/data"

if [[ "${OBSIDIAN_SETUP}" -eq 1 ]]; then
  setup_obsidian_vault
fi

write_stub_if_needed() {
  local path="$1"
  local mode="$2"
  local content="$3"
  if [[ -f "${path}" && "${FORCE_SCAFFOLD}" -eq 0 ]]; then
    log "Keeping existing file: ${path}"
    return 0
  fi
  printf '%s\n' "${content}" > "${path}"
  chmod "${mode}" "${path}"
  log "Wrote stub: ${path}"
}

if [[ "${PROFILE}" == "starter" ]]; then
  write_stub_if_needed "$(automation_script run_shared_memory.sh)" "755" '#!/usr/bin/env bash
set -euo pipefail
echo "[lacp-stub] run_shared_memory.sh noop"
'

  # shellcheck disable=SC2016
  write_stub_if_needed "$(automation_script run_memory_pipeline.sh)" "755" '#!/usr/bin/env bash
set -euo pipefail
HOURS="${1:-24}"
K="${4:-8}"
KNOWLEDGE_ROOT="${LACP_KNOWLEDGE_ROOT:-$HOME/control/knowledge/knowledge-memory}"
mkdir -p "${KNOWLEDGE_ROOT}/data/benchmarks"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
OUT="${KNOWLEDGE_ROOT}/data/benchmarks/benchmark-${TS}.json"
cat > "${OUT}" <<JSON
{
  "gate_ok": true,
  "hours": ${HOURS},
  "summary": {
    "hit_rate_at_k": 1.0,
    "mrr_at_k": 1.0,
    "ndcg_at_k": 1.0,
    "precision_at_k": 1.0,
    "recall_at_k": 1.0
  },
  "config": {
    "top_k": ${K}
  }
}
JSON
echo "[lacp-stub] wrote benchmark: ${OUT}"
'

  # shellcheck disable=SC2016
  write_stub_if_needed "$(automation_script run_memory_benchmark_suite.sh)" "755" '#!/usr/bin/env bash
set -euo pipefail
KNOWLEDGE_ROOT="${LACP_KNOWLEDGE_ROOT:-$HOME/control/knowledge/knowledge-memory}"
mkdir -p "${KNOWLEDGE_ROOT}/data"
echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [lacp-stub] benchmark suite refresh" >> "${KNOWLEDGE_ROOT}/data/benchmark.log"
echo "[lacp-stub] benchmark log updated"
'

  write_stub_if_needed "$(automation_script capture_snapshot.py)" "755" '#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
from pathlib import Path

parser = argparse.ArgumentParser()
parser.add_argument("--hours", default="24")
parser.add_argument("--timing-runs", default="3")
args = parser.parse_args()

automation_root = Path(os.environ.get("LACP_AUTOMATION_ROOT", str(Path.home() / "control/automation/ai-dev-optimization")))
snapshots = automation_root / "data" / "snapshots"
snapshots.mkdir(parents=True, exist_ok=True)
ts = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
out = snapshots / f"snapshot-{ts}.json"
payload = {
    "captured_at_utc": dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "hours": int(args.hours),
    "timing_runs": int(args.timing_runs),
    "source": "lacp-stub",
}
out.write_text(json.dumps(payload, indent=2) + "\n")
print("{}")
'
fi

ONBOARD_ARGS=()
if [[ "${WITH_VERIFY}" -eq 1 ]]; then
  ONBOARD_ARGS+=(--with-verify --hours "${HOURS}")
fi
if [[ "${AUTO_ADOPT}" -eq 0 ]]; then
  ONBOARD_ARGS+=(--no-auto-adopt)
fi
if [[ "${AUTO_HOOK_OPTIMIZE}" -eq 0 ]]; then
  ONBOARD_ARGS+=(--no-auto-hook-optimize)
fi

if [[ "${#ONBOARD_ARGS[@]}" -gt 0 ]]; then
  "${ROOT}/bin/lacp-onboard" "${ONBOARD_ARGS[@]}"
else
  "${ROOT}/bin/lacp-onboard"
fi

log "Install complete (profile=${PROFILE})"
log "Next: bin/lacp-doctor --json | jq"
