#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-install [--profile starter|existing] [--with-verify] [--hours N] [--force-scaffold] [--no-auto-deps] [--auto-deps-dry-run] [--auto-deps-force] [--with-obsidian-setup] [--no-obsidian-setup] [--no-auto-adopt] [--no-auto-hook-optimize] [--with-ollama] [--with-mcp]

Bootstraps LACP for first-time users.

Profiles:
  starter   Create safe local stub automation scripts when missing.
  existing  Do not scaffold automation scripts.

Notes:
  - Creates .env from config/lacp.env.example if missing.
  - Applies `starter` policy pack by default for starter profile when `.env` is managed.
  - Ensures root/data directories exist.
  - Runs lacp-onboard at the end (optionally with verify).
  - On macOS, dependency auto-detection is enabled by default and can install missing Homebrew formulas/casks plus npm global packages (including qmd).
  - Obsidian vault bootstrap is enabled by default and creates/syncs core vault links used by brain tooling.
  - Set LACP_OBSIDIAN_VAULT to override the vault path (default: ~/obsidian/vault).
  - --with-ollama installs Ollama and pulls recommended models for the quality gate.
  - --with-mcp installs recommended MCP servers (Context7, Tavily, Playwright).
EOF
}

PROFILE="starter"
WITH_VERIFY=0
HOURS="${LACP_VERIFY_HOURS}"
FORCE_SCAFFOLD=0
AUTO_DEPS=1
AUTO_DEPS_DRY_RUN=0
AUTO_DEPS_FORCE=0
OBSIDIAN_SETUP=1
AUTO_ADOPT=1
AUTO_HOOK_OPTIMIZE=1
WITH_OLLAMA=0
WITH_MCP=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE="$2"
      shift 2
      ;;
    --with-verify)
      WITH_VERIFY=1
      shift
      ;;
    --hours)
      HOURS="$2"
      shift 2
      ;;
    --force-scaffold)
      FORCE_SCAFFOLD=1
      shift
      ;;
    --auto-deps)
      AUTO_DEPS=1
      shift
      ;;
    --no-auto-deps)
      AUTO_DEPS=0
      shift
      ;;
    --auto-deps-dry-run)
      AUTO_DEPS=1
      AUTO_DEPS_DRY_RUN=1
      shift
      ;;
    --auto-deps-force)
      AUTO_DEPS_FORCE=1
      shift
      ;;
    --with-obsidian-setup)
      OBSIDIAN_SETUP=1
      shift
      ;;
    --no-obsidian-setup)
      OBSIDIAN_SETUP=0
      shift
      ;;
    --no-auto-adopt)
      AUTO_ADOPT=0
      shift
      ;;
    --no-auto-hook-optimize)
      AUTO_HOOK_OPTIMIZE=0
      shift
      ;;
    --with-ollama)
      WITH_OLLAMA=1
      shift
      ;;
    --with-mcp)
      WITH_MCP=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

case "${PROFILE}" in
  starter|existing) ;;
  *) die "--profile must be starter|existing" ;;
esac

if [[ "${AUTO_DEPS}" -eq 1 ]]; then
  lacp_auto_install_deps "$([[ "${AUTO_DEPS_DRY_RUN}" -eq 1 ]] && echo true || echo false)" "$([[ "${AUTO_DEPS_FORCE}" -eq 1 ]] && echo true || echo false)"
fi

setup_obsidian_vault() {
  local vault_root="${LACP_OBSIDIAN_VAULT:-${HOME}/obsidian/vault}"
  local docs_root="${HOME}/docs"
  local sessions_root="${LACP_SESSIONS_ROOT:-${HOME}/.lacp/sessions}"
  local skills_root="${LACP_SKILLS_ROOT:-${HOME}/.lacp/skills}"
  local automation_scripts="${LACP_AUTOMATION_ROOT}/scripts"

  mkdir -p "${vault_root}"
  mkdir -p "${vault_root}/.obsidian"
  mkdir -p "${vault_root}/00-home/daily" "${vault_root}/atlas" "${vault_root}/inbox" "${vault_root}/voice-notes" "${vault_root}/_generated"

  mkdir -p "${docs_root}" "${sessions_root}" "${skills_root}" "${automation_scripts}"

  link_or_keep() {
    local target="$1"
    local source="$2"
    if [[ -L "${target}" ]]; then
      ln -sfn "${source}" "${target}"
      log "Updated symlink: ${target} -> ${source}"
      return 0
    fi
    if [[ -e "${target}" ]]; then
      log "Keeping existing path (not symlink): ${target}"
      return 0
    fi
    ln -s "${source}" "${target}" 2>/dev/null || {
      if [[ -e "${target}" || -L "${target}" ]]; then
        log "Detected concurrent link creation, keeping existing path: ${target}"
        return 0
      fi
      return 1
    }
    log "Created symlink: ${target} -> ${source}"
  }

  link_or_keep "${vault_root}/sessions" "${sessions_root}"
  link_or_keep "${vault_root}/skills" "${skills_root}"
  link_or_keep "${vault_root}/knowledge" "${LACP_KNOWLEDGE_ROOT}"
  link_or_keep "${vault_root}/docs" "${docs_root}"
  link_or_keep "${vault_root}/automation-scripts" "${automation_scripts}"

  # Expose both agent-native skill trees inside the shared skills root.
  mkdir -p "${skills_root}"
  link_or_keep "${skills_root}/claude" "${HOME}/.agents/skills"
  link_or_keep "${skills_root}/codex" "${HOME}/.codex/skills"
}

if [[ ! -f "${ROOT}/.env" ]]; then
  if [[ "${LACP_SKIP_DOTENV:-0}" == "1" ]]; then
    log "Skipped .env creation because LACP_SKIP_DOTENV=1"
  else
    cp "${ROOT}/config/lacp.env.example" "${ROOT}/.env"
    log "Created ${ROOT}/.env from template"
  fi
fi

if [[ "${PROFILE}" == "starter" && "${LACP_SKIP_DOTENV:-0}" != "1" && -f "${ROOT}/.env" ]]; then
  "${ROOT}/bin/lacp-policy-pack" apply --pack starter >/dev/null
  log "Applied policy pack: starter"
fi

mkdir -p "${LACP_AUTOMATION_ROOT}" "${LACP_KNOWLEDGE_ROOT}" "${LACP_DRAFTS_ROOT}"
mkdir -p "${LACP_AUTOMATION_ROOT}/scripts"
mkdir -p "${LACP_AUTOMATION_ROOT}/data/snapshots"
mkdir -p "${LACP_KNOWLEDGE_ROOT}/data/benchmarks"
mkdir -p "${LACP_KNOWLEDGE_ROOT}/data"

if [[ "${OBSIDIAN_SETUP}" -eq 1 ]]; then
  setup_obsidian_vault
fi

write_stub_if_needed() {
  local path="$1"
  local mode="$2"
  local content="$3"
  if [[ -f "${path}" && "${FORCE_SCAFFOLD}" -eq 0 ]]; then
    log "Keeping existing file: ${path}"
    return 0
  fi
  printf '%s\n' "${content}" > "${path}"
  chmod "${mode}" "${path}"
  log "Wrote stub: ${path}"
}

if [[ "${PROFILE}" == "starter" ]]; then
  write_stub_if_needed "$(automation_script run_shared_memory.sh)" "755" '#!/usr/bin/env bash
set -euo pipefail
echo "[lacp-stub] run_shared_memory.sh noop"
'

  # shellcheck disable=SC2016
  write_stub_if_needed "$(automation_script run_memory_pipeline.sh)" "755" '#!/usr/bin/env bash
set -euo pipefail
HOURS="${1:-24}"
K="${4:-8}"
KNOWLEDGE_ROOT="${LACP_KNOWLEDGE_ROOT:-$HOME/.lacp/knowledge}"
mkdir -p "${KNOWLEDGE_ROOT}/data/benchmarks"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
OUT="${KNOWLEDGE_ROOT}/data/benchmarks/benchmark-${TS}.json"
cat > "${OUT}" <<JSON
{
  "gate_ok": true,
  "hours": ${HOURS},
  "summary": {
    "hit_rate_at_k": 1.0,
    "mrr_at_k": 1.0,
    "ndcg_at_k": 1.0,
    "precision_at_k": 1.0,
    "recall_at_k": 1.0
  },
  "config": {
    "top_k": ${K}
  }
}
JSON
echo "[lacp-stub] wrote benchmark: ${OUT}"
'

  # shellcheck disable=SC2016
  write_stub_if_needed "$(automation_script run_memory_benchmark_suite.sh)" "755" '#!/usr/bin/env bash
set -euo pipefail
KNOWLEDGE_ROOT="${LACP_KNOWLEDGE_ROOT:-$HOME/.lacp/knowledge}"
mkdir -p "${KNOWLEDGE_ROOT}/data"
echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [lacp-stub] benchmark suite refresh" >> "${KNOWLEDGE_ROOT}/data/benchmark.log"
echo "[lacp-stub] benchmark log updated"
'

  write_stub_if_needed "$(automation_script capture_snapshot.py)" "755" '#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
from pathlib import Path

parser = argparse.ArgumentParser()
parser.add_argument("--hours", default="24")
parser.add_argument("--timing-runs", default="3")
args = parser.parse_args()

automation_root = Path(os.environ.get("LACP_AUTOMATION_ROOT", str(Path.home() / ".lacp/automation")))
snapshots = automation_root / "data" / "snapshots"
snapshots.mkdir(parents=True, exist_ok=True)
ts = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
out = snapshots / f"snapshot-{ts}.json"
payload = {
    "captured_at_utc": dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "hours": int(args.hours),
    "timing_runs": int(args.timing_runs),
    "source": "lacp-stub",
}
out.write_text(json.dumps(payload, indent=2) + "\n")
print("{}")
'

  write_stub_if_needed "$(automation_script run_session_sync.sh)" "755" '#!/usr/bin/env bash
set -euo pipefail

SESSIONS_ROOT="${LACP_SESSIONS_ROOT:-$HOME/.lacp/sessions}"
SOURCE_ROOT="${LACP_SESSION_SYNC_SOURCE_ROOT:-$HOME/control/sessions}"
DRY_RUN=0
AS_JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    --json) AS_JSON=1; shift ;;
    -h|--help)
      cat <<'"'"'EOF'"'"'
Usage: run_session_sync.sh [--dry-run] [--json]

Mirror extracted agent session markdown notes from an external sessions root
into $LACP_SESSIONS_ROOT so the Obsidian vault sessions symlink has content.
EOF
      exit 0
      ;;
    *)
      echo "[lacp-session-sync] ERROR unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

mkdir -p "${SESSIONS_ROOT}"
copied=0
agents_with_content=0

for agent in claude codex hermes; do
  src_dir="${SOURCE_ROOT}/${agent}"
  dest_dir="${SESSIONS_ROOT}/${agent}"
  mkdir -p "${dest_dir}"
  agent_copied=0

  [[ -d "${src_dir}" ]] || continue

  while IFS= read -r -d "" src; do
    base="$(basename "${src}")"
    dest="${dest_dir}/${base}"
    if [[ -f "${dest}" && "${src}" -ot "${dest}" ]]; then
      continue
    fi
    if [[ "${DRY_RUN}" -eq 0 ]]; then
      cp -p "${src}" "${dest}"
    fi
    copied=$((copied + 1))
    agent_copied=$((agent_copied + 1))
  done < <(find "${src_dir}" -type f -name "*.md" -print0 2>/dev/null)

  if [[ "${agent_copied}" -gt 0 ]]; then
    agents_with_content=$((agents_with_content + 1))
  fi
done

python3 - <<'"'"'PY'"'"' "${SESSIONS_ROOT}" "${SOURCE_ROOT}" "${copied}" "${agents_with_content}" "${DRY_RUN}" "${AS_JSON}"
import json
import sys

payload = {
    "ok": True,
    "sessions_root": sys.argv[1],
    "source_root": sys.argv[2],
    "copied": int(sys.argv[3]),
    "agents_with_content": int(sys.argv[4]),
    "dry_run": sys.argv[5] == "1",
}

if sys.argv[6] == "1":
    print(json.dumps(payload, indent=2))
else:
    print(json.dumps(payload))
PY
'

  write_stub_if_needed "$(automation_script route_inbox.py)" "755" '#!/usr/bin/env python3
import argparse
import json
import shutil
from pathlib import Path

TYPE_DIRS = {
    "decision": "knowledge/decisions",
    "insight": "knowledge/insights",
    "learning": "knowledge/learnings",
    "blocker": "knowledge/blockers",
    "opportunity": "knowledge/opportunities",
    "idea": "knowledge/ideas",
}

TYPE_KEYWORDS = {
    "decision": ["decided", "decision", "chose", "trade-off", "tradeoff"],
    "insight": ["realized", "insight", "discovered", "aha", "takeaway"],
    "blocker": ["blocked", "blocker", "stuck", "failing", "broken", "error"],
    "opportunity": ["opportunity", "potential", "promising", "worth exploring"],
    "learning": ["learned", "learning", "guide", "reference", "tutorial"],
    "idea": ["idea", "brainstorm", "proposal", "concept", "what if"],
}


def parse_frontmatter(text: str) -> tuple[dict[str, str], str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---\n", 4)
    if end == -1:
        return {}, text
    frontmatter = {}
    raw = text[4:end]
    for line in raw.splitlines():
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        frontmatter[key.strip()] = value.strip().strip("\"").strip("'"'"'")
    return frontmatter, text[end + 5 :]


def classify_type(frontmatter: dict[str, str], body: str) -> str | None:
    note_type = frontmatter.get("type", "").strip().lower()
    if note_type:
        return note_type
    text = body.lower()
    scores = {key: 0 for key in TYPE_KEYWORDS}
    for key, keywords in TYPE_KEYWORDS.items():
        scores[key] = sum(1 for keyword in keywords if keyword in text)
    best = max(scores, key=scores.get)
    return best if scores[best] > 0 else None


parser = argparse.ArgumentParser()
parser.add_argument("--apply", action="store_true")
parser.add_argument("--json", action="store_true")
args = parser.parse_args()

vault_root = Path(Path.home() / "obsidian" / "vault")
vault_root = Path(Path(__import__("os").environ.get("LACP_OBSIDIAN_VAULT", str(vault_root))).expanduser())
inbox_dir = vault_root / "inbox"

routed = []
if inbox_dir.exists():
    for note_path in sorted(inbox_dir.glob("*.md")):
        text = note_path.read_text(encoding="utf-8", errors="replace")
        frontmatter, body = parse_frontmatter(text)
        note_type = classify_type(frontmatter, body)
        if not note_type:
            continue
        rel_dest = TYPE_DIRS.get(note_type, "knowledge/general")
        dest_dir = vault_root / rel_dest
        dest_path = dest_dir / note_path.name
        routed.append({
            "source": str(note_path),
            "destination": str(dest_path),
            "type": note_type,
        })
        if args.apply:
            dest_dir.mkdir(parents=True, exist_ok=True)
            shutil.move(str(note_path), str(dest_path))

payload = {
    "ok": True,
    "inbox": str(inbox_dir),
    "routed_count": len(routed),
    "dry_run": not args.apply,
    "routed": routed,
}

if args.json:
    print(json.dumps(payload, indent=2))
else:
    print(json.dumps(payload))
'

  write_stub_if_needed "$(automation_script archive_inbox.py)" "755" '#!/usr/bin/env python3
import argparse
import json
import shutil
from datetime import datetime, timedelta, timezone
from pathlib import Path

parser = argparse.ArgumentParser()
parser.add_argument("--days", type=int, default=30)
parser.add_argument("--apply", action="store_true")
parser.add_argument("--json", action="store_true")
args = parser.parse_args()

vault_root = Path(Path.home() / "obsidian" / "vault")
vault_root = Path(Path(__import__("os").environ.get("LACP_OBSIDIAN_VAULT", str(vault_root))).expanduser())
inbox_dir = vault_root / "inbox"
archive_root = inbox_dir / "archive"
cutoff = datetime.now(timezone.utc) - timedelta(days=args.days)

archived = []
if inbox_dir.exists():
    for note_path in sorted(inbox_dir.glob("*.md")):
        modified = datetime.fromtimestamp(note_path.stat().st_mtime, tz=timezone.utc)
        if modified >= cutoff:
            continue
        dated_dir = archive_root / modified.strftime("%Y") / modified.strftime("%m")
        dest_path = dated_dir / note_path.name
        archived.append({
            "source": str(note_path),
            "destination": str(dest_path),
        })
        if args.apply:
            dated_dir.mkdir(parents=True, exist_ok=True)
            shutil.move(str(note_path), str(dest_path))

payload = {
    "ok": True,
    "inbox": str(inbox_dir),
    "archive_root": str(archive_root),
    "archived_count": len(archived),
    "dry_run": not args.apply,
    "archived": archived,
}

if args.json:
    print(json.dumps(payload, indent=2))
else:
    print(json.dumps(payload))
'
fi

# Optional Ollama setup
if [[ "${WITH_OLLAMA}" -eq 1 ]]; then
  if ! command -v ollama >/dev/null 2>&1; then
    if command -v brew >/dev/null 2>&1; then
      log "Installing Ollama via Homebrew..."
      brew install ollama
    else
      log "Ollama not found and Homebrew unavailable. Install manually: https://ollama.com"
    fi
  else
    log "Ollama already installed: $(command -v ollama)"
  fi

  if command -v ollama >/dev/null 2>&1; then
    # Start Ollama if not running
    if ! curl -s --max-time 3 http://localhost:11434/api/tags >/dev/null 2>&1; then
      log "Starting Ollama..."
      ollama serve &>/dev/null &
      sleep 3
    fi

    # Pull recommended models
    log "Pulling recommended models (this may take a few minutes on first run)..."
    log ""
    log "  Quality gate (rationalization detection):"
    log "    llama3.1:8b — fast, good at structured JSON eval (~4.7GB)"
    log ""
    log "  Embeddings (brain-expand, knowledge search):"
    log "    mxbai-embed-large — high-quality embeddings (~670MB)"
    log ""

    for model in "llama3.1:8b" "mxbai-embed-large"; do
      if ollama list 2>/dev/null | grep -q "${model}"; then
        log "Model ${model} already pulled"
      else
        log "Pulling ${model}..."
        ollama pull "${model}"
      fi
    done
    log "Ollama setup complete"
  fi
fi

# Optional MCP server setup
if [[ "${WITH_MCP}" -eq 1 ]]; then
  if ! command -v claude >/dev/null 2>&1; then
    log "MCP setup requires Claude Code CLI. Install it first: https://docs.anthropic.com/en/docs/claude-code"
  else
    log "Setting up recommended MCP servers..."
    log ""
    log "  Recommended MCP servers:"
    log "    context7 — live library docs, prevents hallucinated APIs"
    log "    playwright — browser automation for UI verification"
    log "    tavily-search — structured web search for research tasks"
    log ""

    # Context7 — prevents hallucinated API methods
    if claude mcp list 2>/dev/null | grep -q "context7"; then
      log "context7 already configured"
    else
      log "Adding context7 (live library docs)..."
      claude mcp add context7 -- npx -y @upstash/context7-mcp 2>/dev/null && \
        log "context7 added" || \
        log "context7 setup failed — add manually: claude mcp add context7 -- npx -y @upstash/context7-mcp"
    fi

    # Playwright — browser automation
    if claude mcp list 2>/dev/null | grep -q "playwright"; then
      log "playwright already configured"
    else
      log "Adding playwright (browser automation)..."
      claude mcp add playwright -- npx -y @playwright/mcp@latest 2>/dev/null && \
        log "playwright added" || \
        log "playwright setup failed — add manually: claude mcp add playwright -- npx -y @playwright/mcp@latest"
    fi

    # Tavily — structured web search (requires API key)
    if claude mcp list 2>/dev/null | grep -q "tavily"; then
      log "tavily already configured"
    else
      tavily_key="${TAVILY_API_KEY:-}"
      if [[ -n "${tavily_key}" ]]; then
        log "Adding tavily-search (structured web search)..."
        claude mcp add tavily-search -e TAVILY_API_KEY="${tavily_key}" -- npx -y tavily-mcp 2>/dev/null && \
          log "tavily-search added" || \
          log "tavily-search setup failed — add manually"
      else
        log "Skipping tavily-search: TAVILY_API_KEY not set"
        log "  Get a key at https://tavily.com then run:"
        log "  claude mcp add tavily-search -e TAVILY_API_KEY=tvly-xxx -- npx -y tavily-mcp"
      fi
    fi

    log "MCP setup complete"
  fi
fi

ONBOARD_ARGS=()
if [[ "${WITH_VERIFY}" -eq 1 ]]; then
  ONBOARD_ARGS+=(--with-verify --hours "${HOURS}")
fi
if [[ "${AUTO_DEPS}" -eq 0 ]]; then
  ONBOARD_ARGS+=(--no-auto-deps)
fi
if [[ "${AUTO_DEPS_DRY_RUN}" -eq 1 ]]; then
  ONBOARD_ARGS+=(--auto-deps-dry-run)
fi
if [[ "${AUTO_DEPS_FORCE}" -eq 1 ]]; then
  ONBOARD_ARGS+=(--auto-deps-force)
fi
if [[ "${AUTO_ADOPT}" -eq 0 ]]; then
  ONBOARD_ARGS+=(--no-auto-adopt)
fi
if [[ "${AUTO_HOOK_OPTIMIZE}" -eq 0 ]]; then
  ONBOARD_ARGS+=(--no-auto-hook-optimize)
fi

if [[ "${#ONBOARD_ARGS[@]}" -gt 0 ]]; then
  "${ROOT}/bin/lacp-onboard" "${ONBOARD_ARGS[@]}"
else
  "${ROOT}/bin/lacp-onboard"
fi

log "Install complete (profile=${PROFILE})"
log "Next: bin/lacp-doctor --json | jq"
