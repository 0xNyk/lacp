#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-report [--hours N] [--json]

Build a compact operational summary from local artifacts:
- recent sandbox run outcomes
- block reasons (review/critical/budget)
- latest benchmark and snapshot paths
EOF
}

HOURS="${LACP_VERIFY_HOURS}"
AS_JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --hours)
      HOURS="$2"
      shift 2
      ;;
    --json)
      AS_JSON=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

require_cmd jq
require_cmd python3

RUNS_DIR="${LACP_KNOWLEDGE_ROOT}/data/sandbox-runs"
LATEST_BENCH="$(latest_file "${LACP_KNOWLEDGE_ROOT}/data/benchmarks/benchmark-*.json" || true)"
LATEST_SNAPSHOT="$(latest_file "${LACP_AUTOMATION_ROOT}/data/snapshots/snapshot-*.json" || true)"
WRAPPER_BIN_DIR="${LACP_WRAPPER_BIN_DIR}"

report_json="$(python3 - <<'PY' "${RUNS_DIR}" "${HOURS}" "${LATEST_BENCH}" "${LATEST_SNAPSHOT}" "${WRAPPER_BIN_DIR}"
import datetime as dt
import glob
import json
import pathlib
import re
import sys

runs_dir = pathlib.Path(sys.argv[1])
hours = int(sys.argv[2])
latest_bench = sys.argv[3]
latest_snapshot = sys.argv[4]
wrapper_bin_dir = pathlib.Path(sys.argv[5]).expanduser()
time_sessions_file = pathlib.Path(sys.argv[1]).parent / "time-tracking" / "sessions.jsonl"
now = dt.datetime.now(dt.timezone.utc)
cutoff = now - dt.timedelta(hours=hours)

runs = []
if runs_dir.exists():
    for p in runs_dir.glob("run-*.json"):
        try:
            payload = json.loads(p.read_text())
            ts = payload.get("started_at_utc")
            if not ts:
                continue
            started = dt.datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=dt.timezone.utc)
            if started >= cutoff:
                runs.append(payload)
        except Exception:
            continue

total = len(runs)
executed = sum(1 for r in runs if r.get("executed") is True)
success = sum(1 for r in runs if r.get("executed") is True and int(r.get("exit_code", 1)) == 0)
success_all = sum(1 for r in runs if int(r.get("exit_code", 1)) == 0)
blocked_review = sum(1 for r in runs if int(r.get("exit_code", 0)) == 8)
blocked_critical = sum(1 for r in runs if int(r.get("exit_code", 0)) == 9)
blocked_budget = sum(1 for r in runs if int(r.get("exit_code", 0)) == 10)

wrapper_tasks = {
    "interactive claude session": 0,
    "interactive codex session": 0,
}
wrapper_routed_runs = {"claude": 0, "codex": 0}
for r in runs:
    task = str(r.get("task", ""))
    if task in wrapper_tasks:
        wrapper_tasks[task] += 1
    cmd = r.get("command", []) or []
    first = str(cmd[0]) if isinstance(cmd, list) and cmd else ""
    base = pathlib.Path(first).name
    if base == "claude.native":
        wrapper_routed_runs["claude"] += 1
    elif base == "codex.native":
        wrapper_routed_runs["codex"] += 1

def wrapper_state(cmd_name: str):
    wrapper_path = wrapper_bin_dir / cmd_name
    native_path = wrapper_bin_dir / f"{cmd_name}.native"
    managed = False
    target = None
    if wrapper_path.exists():
        try:
            text = wrapper_path.read_text(errors="ignore")
            managed = "LACP_MANAGED_WRAPPER=1" in text
            match = re.search(r'^NATIVE=(.+)$', text, re.MULTILINE)
            if match:
                raw = match.group(1).strip()
                if raw and (raw[0] == raw[-1]) and raw[0] in {"'", '"'}:
                    raw = raw[1:-1]
                target = raw
        except Exception:
            managed = False
    return {
        "path": str(wrapper_path),
        "managed": managed,
        "native_backup": str(native_path) if native_path.exists() else None,
        "native_target": target,
    }

benchmark = {}
if latest_bench:
    try:
        b = json.loads(pathlib.Path(latest_bench).read_text())
        gate_ok = b.get("gate_ok")
        if not isinstance(gate_ok, bool):
            gate_ok = None
        benchmark = {
            "path": latest_bench,
            "gate_ok": gate_ok,
            "summary": b.get("summary", {}),
        }
    except Exception:
        benchmark = {"path": latest_bench, "gate_ok": None, "summary": {}}
else:
    benchmark = {"path": None, "gate_ok": None, "summary": {}}

month_key = now.strftime("%Y-%m")
time_rows = []
if time_sessions_file.exists():
    for line in time_sessions_file.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            item = json.loads(line)
        except Exception:
            continue
        ts = str(item.get("started_at_utc", ""))
        if ts.startswith(month_key + "-"):
            time_rows.append(item)

time_total_seconds = sum(int(r.get("duration_seconds", 0) or 0) for r in time_rows)
time_by_project = {}
split_types = ("clients", "projects", "experiments")
split_map = {k: {} for k in split_types}
split_other = {}

def classify_project(raw):
    p = str(raw or "").strip()
    if not p:
        return ("other", "<unknown>")
    norm = p.replace("\\", "/")
    segments = [s for s in norm.split("/") if s]
    for idx, seg in enumerate(segments):
        if seg in split_types:
            if idx + 1 < len(segments) and segments[idx + 1]:
                return (seg, segments[idx + 1])
            return (seg, "<root>")
    return ("other", p)

for r in time_rows:
    p = str(r.get("project") or "<unknown>")
    s = int(r.get("duration_seconds", 0) or 0)
    time_by_project[p] = time_by_project.get(p, 0) + s
    split_kind, split_name = classify_project(p)
    if split_kind in split_map:
        split_map[split_kind][split_name] = split_map[split_kind].get(split_name, 0) + s
    else:
        split_other[split_name] = split_other.get(split_name, 0) + s

overall_ok = True
if benchmark.get("gate_ok") is False:
    overall_ok = False

payload = {
    "schema_version": "1",
    "kind": "report",
    "generated_at_utc": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
    "ok": overall_ok,
    "window_hours": hours,
    "summary": {
        "window_hours": hours,
        "runs_total": total,
        "runs_executed": executed,
        "runs_success": success,
        "blocked_total": blocked_review + blocked_critical + blocked_budget,
        "benchmark_gate_ok": benchmark.get("gate_ok"),
    },
    "runs": {
        "total": total,
        "executed": executed,
        "success": success,
        "success_all": success_all,
        "blocked_review": blocked_review,
        "blocked_critical": blocked_critical,
        "blocked_budget": blocked_budget,
    },
    "artifacts": {
        "latest_benchmark": benchmark,
        "latest_snapshot": latest_snapshot or None,
    },
    "observability": {
        "wrappers": {
            "bin_dir": str(wrapper_bin_dir),
            "claude": wrapper_state("claude"),
            "codex": wrapper_state("codex"),
        },
        "wrapper_routed_runs": {
            "claude": wrapper_routed_runs["claude"],
            "codex": wrapper_routed_runs["codex"],
            "total": wrapper_routed_runs["claude"] + wrapper_routed_runs["codex"],
        },
        "wrapper_task_runs": {
            "claude": wrapper_tasks["interactive claude session"],
            "codex": wrapper_tasks["interactive codex session"],
            "total": wrapper_tasks["interactive claude session"] + wrapper_tasks["interactive codex session"],
        },
    },
    "time_tracking": {
        "month": month_key,
        "sessions": len(time_rows),
        "total_seconds": time_total_seconds,
        "total_hours": round(time_total_seconds / 3600, 3),
        "top_projects": [
            {"project": k, "seconds": v, "hours": round(v / 3600, 3)}
            for k, v in sorted(time_by_project.items(), key=lambda kv: kv[1], reverse=True)[:5]
        ],
        "directory_split": {
            "clients": [
                {"name": k, "seconds": v, "hours": round(v / 3600, 3)}
                for k, v in sorted(split_map["clients"].items(), key=lambda kv: kv[1], reverse=True)
            ],
            "projects": [
                {"name": k, "seconds": v, "hours": round(v / 3600, 3)}
                for k, v in sorted(split_map["projects"].items(), key=lambda kv: kv[1], reverse=True)
            ],
            "experiments": [
                {"name": k, "seconds": v, "hours": round(v / 3600, 3)}
                for k, v in sorted(split_map["experiments"].items(), key=lambda kv: kv[1], reverse=True)
            ],
            "other": [
                {"name": k, "seconds": v, "hours": round(v / 3600, 3)}
                for k, v in sorted(split_other.items(), key=lambda kv: kv[1], reverse=True)
            ],
        },
        "sessions_file": str(time_sessions_file) if time_sessions_file.exists() else None,
    },
}
print(json.dumps(payload, indent=2))
PY
)"

if [[ "${AS_JSON}" -eq 1 ]]; then
  printf '%s\n' "${report_json}"
else
  echo "${report_json}" | jq -r '
    "LACP Report",
    "  generated_at_utc=\(.generated_at_utc)",
    "  window_hours=\(.window_hours)",
    "  runs.total=\(.runs.total) runs.executed=\(.runs.executed) runs.success=\(.runs.success) runs.success_all=\(.runs.success_all)",
    "  blocked.review=\(.runs.blocked_review) blocked.critical=\(.runs.blocked_critical) blocked.budget=\(.runs.blocked_budget)",
    "  wrappers.bin_dir=\(.observability.wrappers.bin_dir)",
    "  wrappers.claude.managed=\(.observability.wrappers.claude.managed) wrappers.codex.managed=\(.observability.wrappers.codex.managed)",
    "  wrapper_runs.total=\(.observability.wrapper_routed_runs.total) wrapper_tasks.total=\(.observability.wrapper_task_runs.total)",
    "  time.month=\(.time_tracking.month) time.sessions=\(.time_tracking.sessions) time.total_hours=\(.time_tracking.total_hours)",
    "  benchmark.path=\(.artifacts.latest_benchmark.path // "<none>")",
    "  benchmark.gate_ok=\(.artifacts.latest_benchmark.gate_ok)",
    "  snapshot.path=\(.artifacts.latest_snapshot // "<none>")"
  '
fi
