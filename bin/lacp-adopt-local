#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lacp-lib.sh"

usage() {
  cat <<'EOF'
Usage: lacp-adopt-local [options]

Install local wrapper commands for `claude` and `codex` so sessions route through `lacp run` by default.

Options:
  --bin-dir <dir>        Wrapper target directory (default: $HOME/.local/bin)
  --claude-native <path> Explicit native claude binary path
  --codex-native <path>  Explicit native codex binary path
  --force                Overwrite existing wrappers even without LACP marker
  --dry-run              Print actions only
  --json                 Emit JSON summary
  -h, --help             Show help

Behavior:
  - Existing command shims are backed up to <cmd>.native once.
  - Wrappers can be bypassed at runtime with: LACP_BYPASS=1
EOF
}

BIN_DIR="${HOME}/.local/bin"
CLAUDE_NATIVE=""
CODEX_NATIVE=""
FORCE=0
DRY_RUN=0
AS_JSON=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --bin-dir) BIN_DIR="$2"; shift 2 ;;
    --claude-native) CLAUDE_NATIVE="$2"; shift 2 ;;
    --codex-native) CODEX_NATIVE="$2"; shift 2 ;;
    --force) FORCE=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --json) AS_JSON=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown argument: $1" ;;
  esac
done

resolve_path() {
  local in="$1"
  python3 - <<'PY' "${in}"
import pathlib, sys
print(pathlib.Path(sys.argv[1]).expanduser().resolve())
PY
}

detect_cmd() {
  local name="$1"
  command -v "${name}" || true
}

is_managed_wrapper() {
  local path="$1"
  [[ -f "${path}" ]] || return 1
  rg -q 'LACP_MANAGED_WRAPPER=1' "${path}"
}

quote_for_shell() {
  local value="$1"
  printf "%q" "${value}"
}

declare -a EVENTS=()

log_event() {
  EVENTS+=("$1")
  if [[ "${AS_JSON}" -eq 0 ]]; then
    log "$1"
  fi
}

write_wrapper() {
  local cmd_name="$1"
  local native_path="$2"
  local wrapper_path="${BIN_DIR}/${cmd_name}"
  local wrapper_q native_q
  wrapper_q="$(quote_for_shell "${ROOT}")"
  native_q="$(quote_for_shell "${native_path}")"

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    log_event "write_wrapper:${wrapper_path} -> ${native_path}"
    return 0
  fi

  cat > "${wrapper_path}" <<EOF
#!/usr/bin/env bash
set -euo pipefail
# LACP_MANAGED_WRAPPER=1
LACP_ROOT=${wrapper_q}
NATIVE=${native_q}
if [[ "\${LACP_BYPASS:-0}" == "1" ]]; then
  exec "\${NATIVE}" "\$@"
fi
exec "\${LACP_ROOT}/bin/lacp" run \\
  --task "interactive ${cmd_name} session" \\
  --repo-trust "\${LACP_REPO_TRUST:-trusted}" \\
  -- "\${NATIVE}" "\$@"
EOF
  chmod +x "${wrapper_path}"
  log_event "wrapper_installed:${wrapper_path}"
}

adopt_one() {
  local cmd_name="$1"
  local explicit_native="$2"
  local wrapper_path="${BIN_DIR}/${cmd_name}"
  local native_backup="${BIN_DIR}/${cmd_name}.native"
  local detected_native native_target

  detected_native="$(detect_cmd "${cmd_name}")"
  native_target="${explicit_native}"

  if [[ -z "${native_target}" ]]; then
    if [[ -x "${native_backup}" ]]; then
      native_target="${native_backup}"
    elif [[ -n "${detected_native}" && "${detected_native}" != "${wrapper_path}" ]]; then
      native_target="${detected_native}"
    fi
  fi

  if [[ -z "${native_target}" ]]; then
    die "Unable to determine native binary for ${cmd_name}. Pass --${cmd_name}-native <path>."
  fi

  native_target="$(resolve_path "${native_target}")"
  [[ -x "${native_target}" ]] || die "Native ${cmd_name} is not executable: ${native_target}"

  if [[ -e "${wrapper_path}" ]]; then
    if is_managed_wrapper "${wrapper_path}"; then
      log_event "wrapper_exists:${wrapper_path}"
    else
      if [[ "${FORCE}" -ne 1 && ! -e "${native_backup}" ]]; then
        die "Refusing to overwrite non-LACP ${cmd_name} wrapper at ${wrapper_path}. Use --force."
      fi
      if [[ ! -e "${native_backup}" ]]; then
        if [[ "${DRY_RUN}" -eq 1 ]]; then
          log_event "backup_create:${wrapper_path} -> ${native_backup}"
        else
          mv "${wrapper_path}" "${native_backup}"
          log_event "backup_created:${native_backup}"
        fi
      fi
    fi
  fi

  if [[ -e "${native_backup}" ]]; then
    native_target="${native_backup}"
  fi

  write_wrapper "${cmd_name}" "${native_target}"
}

mkdir_event="mkdir:${BIN_DIR}"
if [[ "${DRY_RUN}" -eq 1 ]]; then
  log_event "${mkdir_event}"
else
  mkdir -p "${BIN_DIR}"
  log_event "${mkdir_event}:ok"
fi

adopt_one "claude" "${CLAUDE_NATIVE}"
adopt_one "codex" "${CODEX_NATIVE}"

if [[ "${AS_JSON}" -eq 1 ]]; then
  jq -n \
    --arg bin_dir "${BIN_DIR}" \
    --arg lacp_root "${ROOT}" \
    --argjson dry_run "$([[ "${DRY_RUN}" -eq 1 ]] && echo true || echo false)" \
    --argjson force "$([[ "${FORCE}" -eq 1 ]] && echo true || echo false)" \
    --argjson events "$(printf '%s\n' "${EVENTS[@]}" | jq -R . | jq -s .)" \
    '{
      ok: true,
      bin_dir: $bin_dir,
      lacp_root: $lacp_root,
      dry_run: $dry_run,
      force: $force,
      events: $events
    }'
fi
