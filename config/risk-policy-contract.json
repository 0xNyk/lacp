{
  "version": "1",
  "riskTierRules": {
    "high": [
      "bin/**",
      "scripts/runners/**",
      "config/sandbox-policy.json",
      "config/mcp-auth-policy.json"
    ],
    "medium": [
      "scripts/ci/**",
      "config/harness/**",
      "app/api/**",
      "api/**",
      "contracts/**",
      "src/contracts/**",
      "docs/runbook.md"
    ],
    "low": ["**"]
  },
  "mergePolicy": {
    "high": {
      "requiredChecks": [
        "risk-policy-gate",
        "harness-smoke",
        "Browser Evidence",
        "CI Pipeline"
      ]
    },
    "medium": {
      "requiredChecks": [
        "risk-policy-gate",
        "harness-smoke",
        "CI Pipeline"
      ]
    },
    "low": {
      "requiredChecks": [
        "risk-policy-gate",
        "CI Pipeline"
      ]
    }
  },
  "docsDriftRules": [
    {
      "match": ["config/**", "bin/**", "scripts/**"],
      "requiresAny": ["docs/runbook.md", "docs/framework-scope.md"]
    }
  ],
  "reviewAgent": {
    "requiredTiers": ["high", "medium"],
    "mustMatchHeadSha": true,
    "maxWaitMinutes": 20,
    "actionableSeverities": ["critical", "high", "medium"]
  },
  "browserEvidence": {
    "requiredTiers": ["high", "medium"],
    "manifestSchema": "config/harness/browser-evidence.schema.json",
    "requiredEntrypointKinds": ["ui-flow", "auth-flow"],
    "requiredMatchGlobs": ["app/**", "web/**", "frontend/**", "ui/**", "pages/**", "routes/**", "docs/**"],
    "maxArtifactAgeHours": 24
  },
  "apiEvidence": {
    "requiredTiers": ["high", "medium"],
    "requiredMatchGlobs": ["app/api/**", "api/**", "openapi/**", "graphql/**", "services/**"],
    "manifestSchema": "config/harness/browser-evidence.schema.json",
    "requiredEntrypointKinds": ["api-flow"],
    "requiredEntrypointPrefixes": ["/api/"],
    "requiredAssertionSubstringsAny": ["status", "http", "authz", "forbidden", "unauthorized"],
    "maxArtifactAgeHours": 24
  },
  "contractEvidence": {
    "requiredTiers": ["high", "medium"],
    "requiredMatchGlobs": ["contracts/**", "src/contracts/**", "foundry.toml", "hardhat.config.*"],
    "manifestSchema": "config/harness/browser-evidence.schema.json",
    "requiredEntrypointKinds": ["contract-flow"],
    "requiredAssertionSubstringsAny": ["invariant", "revert", "event", "gas"],
    "maxArtifactAgeHours": 24
  }
}
