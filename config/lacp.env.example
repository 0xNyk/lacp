# LACP environment overrides (copy to .env)

LACP_AUTOMATION_ROOT="$HOME/.lacp/automation"
LACP_KNOWLEDGE_ROOT="$HOME/.lacp/knowledge"
LACP_KNOWLEDGE_GRAPH_ROOT="$HOME/.lacp/knowledge"
LACP_DRAFTS_ROOT="$HOME/.lacp/drafts"
LACP_LOCAL_FIRST="true"
LACP_NO_EXTERNAL_CI="true"
LACP_AUTO_HOOK_OPTIMIZE="true"
LACP_TIME_TRACKING_ROOT="$HOME/.lacp/knowledge/data/time-tracking"

# Obsidian vault path (used by brain-doctor, brain-expand, write_validate)
# LACP_OBSIDIAN_VAULT="$HOME/obsidian/vault"

# Pipeline defaults
LACP_VERIFY_HOURS="24"
LACP_BENCH_TOP_K="8"
LACP_BENCH_LOOKBACK="30"
LACP_SANDBOX_POLICY_FILE="$LACP_ROOT/config/sandbox-policy.json"
LACP_MCP_AUTH_POLICY_FILE="$LACP_ROOT/config/mcp-auth-policy.json"
LACP_ALLOW_EXTERNAL_REMOTE="false"
LACP_REMOTE_APPROVAL_TTL_MIN="30"
LACP_REMOTE_APPROVAL_FILE="$HOME/.lacp/knowledge/data/approvals/remote-approval.json"

# Optional sandbox adapter runners. Keep empty to use defaults.
# local_sandbox default behavior falls back to direct execution with warning.
# remote_sandbox picks provider default runner from policy when unset.
LACP_LOCAL_SANDBOX_RUNNER=""
LACP_REMOTE_SANDBOX_RUNNER=""

# Orchestrator defaults
LACP_ORCHESTRATOR_BACKEND="dmux"
# Required for dmux live runs:
# LACP_DMUX_RUN_TEMPLATE='dmux run --session "{session}" --command "{command}"'

# Daytona remote runner settings (used when LACP_REMOTE_SANDBOX_RUNNER points to daytona-runner.sh)
LACP_DAYTONA_NAME_PREFIX="lacp-remote"
LACP_DAYTONA_CLASS="small"
LACP_DAYTONA_TARGET=""
LACP_DAYTONA_SNAPSHOT=""
LACP_DAYTONA_NETWORK_BLOCK_ALL="false"
LACP_DAYTONA_NETWORK_ALLOW_LIST=""
LACP_DAYTONA_AUTO_STOP_MIN="15"
LACP_DAYTONA_AUTO_ARCHIVE_MIN="10080"
LACP_DAYTONA_AUTO_DELETE_MIN="0"

# E2B runner settings (used by scripts/runners/e2b-runner.sh)
E2B_CLI_BIN="e2b"
# Optional existing-sandbox mode; when set, e2b CLI is used.
E2B_SANDBOX_ID=""
# Lifecycle mode defaults (used when E2B_SANDBOX_ID is empty).
E2B_TEMPLATE="base"
E2B_TIMEOUT_MS="300000"
# Optional custom launcher, e.g. "node" or "npx -y -p @e2b/code-interpreter@latest node"
E2B_NODE_LAUNCHER=""

# Tool-input contract gate for risky runs.
LACP_REQUIRE_INPUT_CONTRACT="true"
LACP_INPUT_CONTRACT_CONFIDENCE_MIN="0.70"

# Context contract gate for mutating runs.
LACP_REQUIRE_CONTEXT_CONTRACT="true"

# Session fingerprint gate (recommended true when using starter/strict policy packs).
LACP_REQUIRE_SESSION_FINGERPRINT="false"

# Runtime pressure controls for orchestration/swarm launch backoff.
LACP_RUNTIME_MAX_LOAD_PER_CPU="2.00"
LACP_RUNTIME_MIN_FORK_HEADROOM="64"
LACP_RUNTIME_BACKOFF_SEC="2"
LACP_RUNTIME_BACKOFF_MAX_ATTEMPTS="3"
# Test override only: auto|high|normal
LACP_RUNTIME_PRESSURE_OVERRIDE="auto"

# Auto dependency install defaults (macOS/Homebrew + npm globals)
LACP_AUTO_DEPS_FORMULAS="jq ripgrep python@3.11 git tmux gh node"
LACP_AUTO_DEPS_CASKS="obsidian"
LACP_AUTO_DEPS_NPM_PACKAGES="@tobilu/qmd"

# GPU resource management (for machines with nvidia GPUs)
LACP_RUNTIME_MIN_GPU_HEADROOM_MB="2048"
LACP_RUNTIME_GPU_LOCK_FILE="$HOME/.lacp/state/gpu.lock"

# Memory decay zones (inspired by ACT-R cognitive science / Ori-Mnemos)
# Lower = slower decay. Identity barely fades; operations burn hot.
LACP_MEMORY_DECAY_IDENTITY="0.1"
LACP_MEMORY_DECAY_KNOWLEDGE="1.0"
LACP_MEMORY_DECAY_OPERATIONS="3.0"
