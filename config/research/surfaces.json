{
  "hooks": {
    "description": "Quality gate threshold and scoring weight optimization",
    "target_file": "hooks/stop_quality_gate.py",
    "parameters": [
      {"name": "QUALITY_GATE_THRESHOLD", "env": "LACP_QUALITY_GATE_THRESHOLD", "type": "float", "min": 1.5, "max": 4.0, "default": 2.5, "step": 0.1},
      {"name": "completeness_weight", "type": "float", "min": 0.15, "max": 0.50, "default": 0.35, "step": 0.05},
      {"name": "honesty_weight", "type": "float", "min": 0.10, "max": 0.45, "default": 0.30, "step": 0.05},
      {"name": "deferral_weight", "type": "float", "min": 0.05, "max": 0.30, "default": 0.20, "step": 0.05},
      {"name": "evidence_weight", "type": "float", "min": 0.05, "max": 0.25, "default": 0.15, "step": 0.05}
    ],
    "eval_command": "bin/lacp-scaffold-audit --json --days 7",
    "baseline_command": "bin/lacp-test --quick",
    "iteration_minutes": 1
  },
  "brain": {
    "description": "Brain expansion gap detection and health tuning",
    "parameters": [
      {"name": "stale_days", "env": "LACP_BRAIN_STALE_DAYS", "type": "int", "min": 14, "max": 60, "default": 30, "step": 5},
      {"name": "max_inbox_size", "env": "LACP_BRAIN_MAX_INBOX", "type": "int", "min": 50, "max": 500, "default": 200, "step": 25}
    ],
    "eval_command": "bin/lacp-brain-doctor --json",
    "baseline_command": "bin/lacp-brain-doctor --json",
    "iteration_minutes": 3
  },
  "sms": {
    "description": "Self-Memory System significance thresholds and decay",
    "parameters": [
      {"name": "significance_baseline", "type": "float", "min": 0.1, "max": 0.5, "default": 0.3, "step": 0.05},
      {"name": "epoch_min_significance", "type": "float", "min": 0.2, "max": 0.7, "default": 0.3, "step": 0.05},
      {"name": "episode_retrieval_days", "type": "int", "min": 3, "max": 30, "default": 7, "step": 1}
    ],
    "eval_command": "bin/lacp-sms significance --json",
    "baseline_command": "bin/lacp-test --quick",
    "iteration_minutes": 1
  }
}
