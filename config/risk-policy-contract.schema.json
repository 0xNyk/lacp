{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lacp.local/schemas/risk-policy-contract.schema.json",
  "type": "object",
  "required": [
    "version",
    "riskTierRules",
    "mergePolicy",
    "docsDriftRules",
    "reviewAgent",
    "browserEvidence"
  ],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "riskTierRules": {
      "type": "object",
      "required": ["high", "medium", "low"],
      "properties": {
        "high": { "$ref": "#/$defs/globArray" },
        "medium": { "$ref": "#/$defs/globArray" },
        "low": { "$ref": "#/$defs/globArray" }
      },
      "additionalProperties": false
    },
    "mergePolicy": {
      "type": "object",
      "required": ["high", "medium", "low"],
      "properties": {
        "high": { "$ref": "#/$defs/mergeTier" },
        "medium": { "$ref": "#/$defs/mergeTier" },
        "low": { "$ref": "#/$defs/mergeTier" }
      },
      "additionalProperties": false
    },
    "docsDriftRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["match", "requiresAny"],
        "properties": {
          "match": { "$ref": "#/$defs/globArray" },
          "requiresAny": { "$ref": "#/$defs/pathArray" }
        },
        "additionalProperties": false
      }
    },
    "reviewAgent": {
      "type": "object",
      "required": ["requiredTiers", "mustMatchHeadSha", "maxWaitMinutes", "actionableSeverities"],
      "properties": {
        "requiredTiers": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["high", "medium", "low"] }
        },
        "mustMatchHeadSha": { "type": "boolean" },
        "maxWaitMinutes": { "type": "integer", "minimum": 1, "maximum": 120 },
        "actionableSeverities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "browserEvidence": {
      "$ref": "#/$defs/evidenceGate"
    },
    "apiEvidence": {
      "$ref": "#/$defs/evidenceGate"
    },
    "contractEvidence": {
      "$ref": "#/$defs/evidenceGate"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "globArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "pathArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mergeTier": {
      "type": "object",
      "required": ["requiredChecks"],
      "properties": {
        "requiredChecks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "evidenceGate": {
      "type": "object",
      "required": ["requiredTiers", "manifestSchema", "requiredEntrypointKinds", "maxArtifactAgeHours"],
      "properties": {
        "requiredTiers": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["high", "medium", "low"] }
        },
        "requiredMatchGlobs": { "$ref": "#/$defs/globArray" },
        "manifestSchema": { "type": "string", "minLength": 1 },
        "requiredEntrypointKinds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredEntrypointPrefixes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredAssertionSubstringsAny": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "maxArtifactAgeHours": { "type": "integer", "minimum": 1, "maximum": 168 }
      },
      "additionalProperties": false
    }
  }
}
